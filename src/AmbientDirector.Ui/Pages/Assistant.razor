@page "/assistant"
@inject Localizer L

<PageTitle>Ambient Director — @L["assistant.title"]</PageTitle>

<div class="page-head"><h1>@L["assistant.title"]</h1></div>

@* Thin host over the shared chat surface. The chat owns polling/state; this page keeps the route,
   the ctx deep-link pre-fill and the "no API key" panel (still handy for bookmarks — an editor's
   "Ask the assistant" button now opens the in-editor drawer instead of navigating here). *@
<AssistantChat InitialDraft="@_draft">
    <NotConfigured>
        <div class="panel">
            <p class="hint" style="margin-top:0">@L["assistant.noKeyNotice"]</p>
            <div class="btn-row">
                <button class="btn btn--primary" @onclick='() => Nav.NavigateTo("settings")'>@L["assistant.openSettings"]</button>
            </div>
        </div>
    </NotConfigured>
</AssistantChat>

@code {
    [Inject] private NavigationManager Nav { get; set; } = default!;

    [Parameter]
    [SupplyParameterFromQuery(Name = "ctx")]
    public string? Ctx { get; set; }

    private string? _draft;

    protected override void OnInitialized() => _draft = DraftFromContext();

    // An editor's deep link arrives as ?ctx=<kind>:<id>. Build an editable draft naming the entity so
    // the assistant (via its get_* tools) can read it; the user confirms/edits before sending. Malformed
    // or unknown ctx yields no draft.
    private string? DraftFromContext()
    {
        if (string.IsNullOrEmpty(Ctx)) return null;

        var sep = Ctx.IndexOf(':');
        if (sep <= 0 || sep == Ctx.Length - 1) return null;

        var kind = Ctx[..sep];
        var id = Uri.UnescapeDataString(Ctx[(sep + 1)..]);
        if (string.IsNullOrWhiteSpace(id)) return null;

        var key = kind switch
        {
            "scene" => "assistant.ctxDraft.scene",
            "event" => "assistant.ctxDraft.event",
            "effect" => "assistant.ctxDraft.effect",
            _ => null,
        };
        return key is null ? null : L.Format(key, id);
    }
}
