@page "/tv"
@layout TvLayout
@implements IAsyncDisposable
@inject ApiClient Api
@inject IJSRuntime JS

@* The player-facing display: a chrome-less black stage a table TV / tablet / cast tab points at.
   Polls /tv/state every 2 s (both routes are outside the API-key gate, so this device needs no key)
   and crossfades between pushed content — a full image OR a composed board (see BoardCanvas). The rev is
   the server's word — it resets to 1 on a restart, so ANY change (not just growth, and including a live
   edit of the shown board) triggers a refresh. *@

<PageTitle>Ambient Director — TV</PageTitle>

<div class="tv-stage">
    @* Both layers render in ONE keyed loop (display first = under, incoming second = on top). Keying by Seq
       across the single loop is what lets Blazor REUSE a layer's DOM node when the incoming layer is promoted
       to the display slot (OnIncomingLoaded) — the surviving Seq stays put instead of being destroyed and
       recreated. The old two-separate-@if-blocks layout defeated that: promotion recreated the board, briefly
       painting both copies (a doubled party) and remounting BoardCanvas (reloading images — a visible jump). *@
    @foreach (var layer in ActiveLayers())
    {
        var visible = ReferenceEquals(layer, _incoming) ? _incomingLoaded : !_clearing;
        @if (layer.Kind == "board")
        {
            <div @key="layer.Seq" class="tv-layer tv-board-wrap @(visible ? "is-visible" : "")">
                <BoardCanvas Model="layer.Board!" FearAnimateFrom="layer.FearFrom" />
            </div>
        }
        else
        {
            @* @onload/@onerror only ever fire for the incoming image (a cached, already-shown display image
               does not re-raise load); OnIncomingLoaded/Error guard on _token/_incoming anyway. *@
            <img @key="layer.Seq" class="tv-layer tv-img @(visible ? "is-visible" : "")" src="@layer.Url" alt=""
                 @onload="OnIncomingLoaded" @onerror="OnIncomingError" />
        }
    }
    @if (_display is null && _incoming is null)
    {
        @* Idle: near-black with a small dim wordmark — no bright UI on a table TV. Literal brand text,
           like the top bar's; the TV shows no other chrome to localize. *@
        <div class="tv-idle">
            <svg viewBox="0 0 256 256" fill="currentColor" aria-hidden="true"><path d="M192,32H64A32,32,0,0,0,32,64V192a32,32,0,0,0,32,32H192a32,32,0,0,0,32-32V64A32,32,0,0,0,192,32ZM92,176a12,12,0,1,1,12-12A12,12,0,0,1,92,176Zm0-72a12,12,0,1,1,12-12A12,12,0,0,1,92,104Zm36,36a12,12,0,1,1,12-12A12,12,0,0,1,128,140Zm36,36a12,12,0,1,1,12-12A12,12,0,0,1,164,176Zm0-72a12,12,0,1,1,12-12A12,12,0,0,1,164,104Z"/></svg>
            <span>AMBIENT DIRECTOR</span>
        </div>
    }
</div>

@code {
    // How long the CSS opacity transition runs (see .tv-layer in _tv.scss) plus a little slack, so the
    // covered layer is only dropped after the crossfade has finished.
    private const int FadeMs = 700;

    // One shown layer, image or board. Seq (the monotonic token at push time) keys the element so promoting an
    // incoming layer to the display slot reuses the same DOM node — no flash — and a new push forces a fresh one.
    // FearFrom (issue #144) drives a board's fear skull cascade: the index from which lit skulls pop, or null
    // for no animation (see FearValue + PollAsync). Only a board layer ever sets it.
    private record Layer(int Seq, string Kind, string? Url, TvBoardDto? Board, int? FearFrom = null);

    private long _rev;             // last applied server revision (0 = nothing seen yet; server starts at 1)
    private Layer? _display;       // the fully shown layer
    private Layer? _incoming;      // the layer loading / fading in on top
    private bool _incomingLoaded;
    private bool _clearing;        // display layer fading out after /tv/clear
    private int _token;            // invalidates delayed swaps when a newer push/clear arrives
    private bool _boardPromoting;  // guards the one-shot "board has no load event" promote from OnAfterRender
    private Timer? _timer;

    // Layers to paint, bottom→top: the shown layer under the incoming one. Rendered in a single keyed loop so a
    // promotion reuses the surviving layer's node (see the markup comment) rather than recreating it.
    private IEnumerable<Layer> ActiveLayers()
    {
        if (_display is not null) yield return _display;
        if (_incoming is not null) yield return _incoming;
    }

    protected override async Task OnInitializedAsync()
    {
        await PollAsync();
        _timer = new Timer(_ => _ = InvokeAsync(PollAsync), null, 2000, 2000);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Best-effort screen wake lock; unsupported browsers just ignore it (see js/tv.js).
            try { await JS.InvokeVoidAsync("rpgTv.keepAwake"); } catch { /* degrade silently */ }
        }

        // A board layer has no single <img> load event, so mark it loaded shortly after its first paint: the
        // browser paints it at opacity 0, then we add .is-visible so the opacity transition actually runs.
        if (_incoming is { Kind: "board" } && !_incomingLoaded && !_boardPromoting)
        {
            _boardPromoting = true;
            var token = _token;
            await Task.Delay(30);
            if (token != _token) return; // a newer push/clear took over meanwhile
            await OnIncomingLoaded();
        }
    }

    private async Task PollAsync()
    {
        var state = await Api.GetTvStateAsync(_rev);
        if (state is null) return;        // offline blip — keep showing what we have, retry next tick
        if (state.Rev == _rev) return;    // unchanged; compare by inequality, never by growth (rev resets on restart)
        _rev = state.Rev;

        if (state.Content is not { } content)
        {
            await BeginClearAsync();
        }
        else if (content.Kind == "board" && content.Board is { } board)
        {
            // WHY diff Fear here: the TV crossfades a WHOLE new layer on every rev bump, so without this an
            // unrelated party change (an HP adjust, a rename) would replay the entire skull cascade each poll.
            // Compare the outgoing board's Fear (the still-loading incoming, else the shown display) to the
            // incoming one's, and only pop what genuinely grew.
            var prev = FearValue((_incoming ?? _display)?.Board);
            var next = FearValue(board);
            int? fearFrom = (prev, next) switch
            {
                (null, > 0) => 0,               // fear track just appeared (first show, or image→board): full cascade
                ({ } p, { } n) when n > p => p, // fear rose: pop only the new skulls (indices >= the old value)
                _ => null,                      // fell / unchanged / no track: no animation
            };
            BeginShow("board", null, board, fearFrom);
        }
        else if (content.Url is { } url)
        {
            BeginShow("image", url, null);
        }
        else
        {
            await BeginClearAsync();
        }
    }

    private void BeginShow(string kind, string? url, TvBoardDto? board, int? fearFrom = null)
    {
        _token++;
        _clearing = false;
        _boardPromoting = false;
        _incoming = new Layer(_token, kind, url, board, fearFrom);   // loads on top; the old layer stays until it's faded in
        _incomingLoaded = false;
        StateHasChanged();
    }

    // The current Fear value a board would display: the first fear element's fear-keyed table counter (matched
    // by key — the localized label can't be), clamped to non-negative; null when the board is null, has no fear
    // element, or that element carries no fear-keyed counter. Diffed across polls so only a genuine Fear
    // INCREASE animates (an unchanged Fear on an unrelated re-render must NOT replay the cascade).
    private static int? FearValue(TvBoardDto? board)
    {
        var counter = board?.Elements
            .FirstOrDefault(e => e.Kind == "fear" && e.Party is not null)
            ?.Party!.Counters.FirstOrDefault(c => string.Equals(c.Key, "fear", StringComparison.OrdinalIgnoreCase));
        return counter is null ? null : Math.Max(0, counter.Value);
    }

    private async Task OnIncomingLoaded()
    {
        _incomingLoaded = true;           // adds .is-visible → the crossfade runs
        var token = _token;
        StateHasChanged();
        await Task.Delay(FadeMs);
        if (token != _token || _incoming is null) return; // a newer push/clear took over meanwhile
        _display = _incoming;             // promote: swap happens under a fully opaque layer
        _incoming = null;
        _incomingLoaded = false;
        StateHasChanged();
    }

    private void OnIncomingError()
    {
        // The pushed image failed to load (deleted meanwhile?) — drop the layer; the old one stays up.
        _incoming = null;
        _incomingLoaded = false;
    }

    private async Task BeginClearAsync()
    {
        _token++;
        var token = _token;
        _incoming = null;                 // abandon any half-loaded push
        _incomingLoaded = false;
        _boardPromoting = false;
        if (_display is null)
        {
            StateHasChanged();
            return;
        }
        _clearing = true;                 // removes .is-visible → fades to black
        StateHasChanged();
        await Task.Delay(FadeMs);
        if (token != _token) return;
        _display = null;
        _clearing = false;
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        _timer?.Dispose();
        try { await JS.InvokeVoidAsync("rpgTv.release"); } catch { /* page is going away */ }
    }
}
