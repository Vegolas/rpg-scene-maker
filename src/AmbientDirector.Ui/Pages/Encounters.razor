@page "/encounters"
@inject ApiClient Api
@inject UiState Ui
@inject ViewTransition Vt
@inject Localizer L

@* Encounters (Starcia) hub: one PageTabs switcher over three sections —
   • Players  — the campaign roster + table-level counters (Fear); the fast mid-session ± tracker.
   • Enemies  — the bestiary of reusable statblock templates (name, portrait, base counters). No live ± here.
   • Encounters — prepped fights (heroes + enemy instances) you build and run to the TV.
   The per-entity editors live at their own routes (/party/{id}, /party/enemies/{id}, /encounters/{id}); the
   ?tab= query lets a "back" land on the right section. *@

<PageTitle>Ambient Director — @L["encounters.title"]</PageTitle>

<div class="page-head">
    <h1>@L["encounters.title"]</h1>
</div>

<PageTabs TValue="string" Options="TabOptions" Value="@_tab" ValueChanged="t => _tab = t" />

@if (!_loaded)
{
    <p class="empty-note">@L["party.loading"]</p>
}
else
{
    var party = _party ?? new PartyDto([], [], [], null);

    // One counter's value: pips (dots) for a "pips" counter, else tabular text. Same rule as BoardCanvas.
    RenderFragment<PartyCounterDto> counterValue = c =>
    @<span class="party-cval">
        @if (IsPips(c))
        {
            var pipMax = Math.Min(c.Max ?? 0, 24);
            var filled = Math.Clamp(c.Value, 0, pipMax);
            <span class="party-pips">
                @for (var i = 0; i < pipMax; i++)
                {
                    <span class="party-pip@(i < filled ? " is-on" : "")"></span>
                }
            </span>
        }
        else
        {
            <span class="party-num">@(c.Max is { } m ? $"{c.Value}/{m}" : c.Value.ToString())</span>
        }
    </span>;

    @* ============================ PLAYERS ============================ *@
    @if (_tab == "players")
    {
        @* ---- table-level counters (Fear etc.) ---- *@
        <SectionHeading>@L["party.tableCounters"]</SectionHeading>
        <div class="panel">
            @if (_editingCounters)
            {
                <div class="party-ceditor">
                    @foreach (var (c, index) in _counters.Select((c, i) => (c, i)))
                    {
                        <div @key="c" class="party-crow-edit">
                            <input class="party-input party-input--label" type="text" value="@c.Label"
                                   placeholder='@L["partyEditor.labelLabel"]'
                                   @oninput="e => c.Label = e.Value?.ToString() ?? string.Empty" />
                            <label class="party-mini">
                                <span>@L["partyEditor.valueLabel"]</span>
                                <input type="number" min="0" max="999" value="@c.Value"
                                       @onchange="e => c.Value = ClampInt(e.Value, c.Value, 0, 999)" />
                            </label>
                            <label class="party-mini">
                                <span>@L["partyEditor.maxLabel"]</span>
                                <input type="number" min="1" max="999" value="@(c.Max?.ToString() ?? "")"
                                       @onchange="e => SetMax(c, e.Value)" />
                            </label>
                            <div class="party-style">
                                <span class="art-label">@L["partyEditor.styleLabel"]</span>
                                <Segmented TValue="string" Options="StyleOptions" Value="@c.Style"
                                           ValueChanged="v => SetStyle(c, v)" />
                            </div>
                            <button class="btn btn--icon btn--danger party-crow-edit__del" @onclick="() => _counters.RemoveAt(index)"
                                    aria-label='@L["boardEditor.removeElement"]'><Icon Name="close" /></button>
                        </div>
                    }
                    <div class="btn-row" style="margin-top:var(--s-3)">
                        <button class="btn btn--small" @onclick="AddCounter"><Icon Name="add" /> @L["party.addCounter"]</button>
                        @* One "Add {counter}" button per active-system table preset (issue #129) — Daggerheart's
                           Fear; a system with no table counters (D&D 5e) shows only the generic add button. *@
                        @foreach (var preset in _system?.TableCounters ?? [])
                        {
                            <button class="btn btn--small" @onclick="() => AddTablePreset(preset)">@L.Format("party.addPreset", L[preset.LabelKey])</button>
                        }
                        <button class="btn btn--primary btn--small" @onclick="SaveCounters" disabled="@_busy">@L["party.doneEditing"]</button>
                    </div>
                </div>
            }
            else
            {
                <div class="party-tstrip">
                    @foreach (var c in party.Counters)
                    {
                        <div class="party-tcounter">
                            <span class="party-tlabel">@c.Label</span>
                            <div class="party-adjust">
                                <button class="party-step" @onclick="() => AdjustTable(c.Label, -1)"
                                        disabled="@(_busy || _pendingCounter is not null)" aria-label='@L["party.decrease"]'><Icon Name="minus" /></button>
                                @counterValue(c)
                                <button class="party-step" @onclick="() => AdjustTable(c.Label, 1)"
                                        disabled="@(_busy || _pendingCounter is not null)" aria-label='@L["party.increase"]'><Icon Name="add" /></button>
                            </div>
                        </div>
                    }
                    <button class="btn btn--small party-editbtn" @onclick="StartEditingCounters">
                        <Icon Name="edit" /> @L["party.editCounters"]
                    </button>
                </div>
            }
        </div>

        <SectionHeading>@L["party.players"]</SectionHeading>
        @if (party.Players.Count == 0)
        {
            <p class="empty-note">@L["party.empty"]</p>
        }
        else
        {
            <div class="party-grid">
                @foreach (var p in party.Players)
                {
                    <div @key="p.Id" class="party-card">
                        <div class="party-card__head">
                            <div class="party-portrait">
                                @if (Api.ImageUrl(p.Portrait) is { } url)
                                {
                                    <img src="@url" alt="" />
                                }
                                else
                                {
                                    <span class="party-initial">@Initial(p.Name)</span>
                                }
                            </div>
                            <span class="party-name">@p.Name</span>
                            <span class="card-edit" role="button" tabindex="0" aria-label='@L.Format("party.editAria", p.Name)'
                                  @onclick="() => EditPlayer(p.Id)" @onkeydown="e => OnKey(e, () => EditPlayer(p.Id))"><Icon Name="edit" /></span>
                        </div>
                        @if (p.Counters is { Count: > 0 })
                        {
                            <div class="party-crows">
                                @foreach (var c in p.Counters)
                                {
                                    <div class="party-crow">
                                        <span class="party-clabel">@c.Label</span>
                                        <div class="party-adjust">
                                            <button class="party-step" @onclick="() => AdjustPlayer(p.Id, c.Label, -1)"
                                                    disabled="@IsRowBusy(p.Id, c.Label)" aria-label='@L["party.decrease"]'><Icon Name="minus" /></button>
                                            @counterValue(c)
                                            <button class="party-step" @onclick="() => AdjustPlayer(p.Id, c.Label, 1)"
                                                    disabled="@IsRowBusy(p.Id, c.Label)" aria-label='@L["party.increase"]'><Icon Name="add" /></button>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="party-nocounters">@L["party.noCounters"]</p>
                        }
                    </div>
                }
            </div>
        }

        <SectionHeading>@L["party.newPlayer"]</SectionHeading>
        <div class="panel">
            <div class="party-new">
                <input class="party-input" type="text" value="@_newName"
                       placeholder='@L["party.namePlaceholder"]'
                       @oninput="e => _newName = e.Value?.ToString() ?? string.Empty"
                       @onkeydown="e => OnEnter(e, CreatePlayer)" />
                <button class="btn btn--primary" @onclick="CreatePlayer" disabled="@_busy">@L["party.createBtn"]</button>
            </div>
            <p class="hint" style="margin-top:var(--s-3)">@L["party.createHint"]</p>
            <div class="btn-row" style="margin-top:var(--s-3)">
                <ImportPackButton Variant="button" Class="btn--ghost btn--small" OnImported="Reload" />
            </div>
        </div>
    }

    @* ============================ ENEMIES (bestiary) ============================ *@
    else if (_tab == "enemies")
    {
        <SectionHeading>@L["bestiary.title"]</SectionHeading>
        <p class="hint" style="margin-top:calc(-1 * var(--s-2))">@L["bestiary.intro"]</p>
        @if (party.Enemies.Count == 0)
        {
            <p class="empty-note">@L["bestiary.empty"]</p>
        }
        else
        {
            <div class="party-grid">
                @foreach (var e in party.Enemies)
                {
                    <div @key="e.Id" class="party-card party-card--link" role="button" tabindex="0"
                         aria-label='@L.Format("party.editAria", e.Name)'
                         @onclick="() => EditEnemy(e.Id)" @onkeydown="ev => OnKey(ev, () => EditEnemy(e.Id))">
                        <div class="party-card__head">
                            <div class="party-portrait">
                                @if (Api.ImageUrl(e.Portrait) is { } url)
                                {
                                    <img src="@url" alt="" />
                                }
                                else
                                {
                                    <span class="party-initial">@Initial(e.Name)</span>
                                }
                            </div>
                            <span class="party-name">@e.Name</span>
                            <span class="card-edit"><Icon Name="edit" /></span>
                        </div>
                        @if (e.Counters is { Count: > 0 })
                        {
                            <div class="bestiary-tags">
                                @foreach (var c in e.Counters)
                                {
                                    <span class="bestiary-tag">@c.Label@(c.Max is { } m ? $" {m}" : "")</span>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="party-nocounters">@L["party.noCounters"]</p>
                        }
                    </div>
                }
            </div>
        }

        <SectionHeading>@L["bestiary.newEnemy"]</SectionHeading>
        <div class="panel">
            <div class="party-new">
                <input class="party-input" type="text" value="@_newEnemyName"
                       placeholder='@L["party.enemyNamePlaceholder"]'
                       @oninput="e => _newEnemyName = e.Value?.ToString() ?? string.Empty"
                       @onkeydown="e => OnEnter(e, CreateEnemy)" />
                <button class="btn btn--primary" @onclick="CreateEnemy" disabled="@_busy">@L["bestiary.addBtn"]</button>
            </div>
            <p class="hint" style="margin-top:var(--s-3)">@L["bestiary.createHint"]</p>
            <div class="btn-row" style="margin-top:var(--s-3)">
                <ImportPackButton Variant="button" Class="btn--ghost btn--small" OnImported="Reload" />
            </div>
        </div>
    }

    @* ============================ ENCOUNTERS ============================ *@
    else
    {
        <SectionHeading>@L["encounters.listTitle"]</SectionHeading>
        <p class="hint" style="margin-top:calc(-1 * var(--s-2))">@L["encounters.intro"]</p>
        @if (_encounters.Count == 0)
        {
            <p class="empty-note">@L["encounters.empty"]</p>
        }
        else
        {
            <div class="party-grid">
                @foreach (var enc in _encounters)
                {
                    <div @key="enc.Id" class="party-card">
                        <div class="party-card__head">
                            <span class="party-name">@enc.Name</span>
                            <span class="card-edit" role="button" tabindex="0" aria-label='@L.Format("party.editAria", enc.Name)'
                                  @onclick="() => EditEncounter(enc.Id)" @onkeydown="ev => OnKey(ev, () => EditEncounter(enc.Id))"><Icon Name="edit" /></span>
                        </div>
                        <p class="encounter-summary">
                            @L.Format("encounters.heroCount", enc.HeroIds?.Count ?? 0)
                            · @L.Format("encounters.enemyCount", enc.Enemies?.Count ?? 0)
                        </p>
                        <div class="btn-row">
                            <button class="btn btn--primary btn--small" @onclick="() => RunEncounter(enc.Id)" disabled="@_busy">
                                <Icon Name="play" /> @L["encounters.run"]
                            </button>
                        </div>
                    </div>
                }
            </div>
        }

        <SectionHeading>@L["encounters.newEncounter"]</SectionHeading>
        <div class="panel">
            <div class="party-new">
                <input class="party-input" type="text" value="@_newEncounterName"
                       placeholder='@L["encounters.namePlaceholder"]'
                       @oninput="e => _newEncounterName = e.Value?.ToString() ?? string.Empty"
                       @onkeydown="e => OnEnter(e, CreateEncounter)" />
                <button class="btn btn--primary" @onclick="CreateEncounter" disabled="@_busy">@L["encounters.createBtn"]</button>
            </div>
            <p class="hint" style="margin-top:var(--s-3)">@L["encounters.createHint"]</p>
            <div class="btn-row" style="margin-top:var(--s-3)">
                <ImportPackButton Variant="button" Class="btn--ghost btn--small" OnImported="Reload" />
            </div>
        </div>
    }
}

@code {
    [SupplyParameterFromQuery] public string? Tab { get; set; }

    private PartyDto? _party;
    private GameSystemDto? _system;
    private List<EncounterDto> _encounters = [];
    private bool _loaded;
    private bool _busy;
    private string _tab = "encounters";

    private bool _editingCounters;
    private List<CounterEdit> _counters = [];
    private string _newName = "";
    private string _newEnemyName = "";
    private string _newEncounterName = "";
    private string? _pendingCounter;
    private readonly HashSet<string> _pendingRows = new(StringComparer.Ordinal);

    private IReadOnlyList<(string, string, string?)> TabOptions =>
    [
        ("players", L["encounters.tab.players"], "party"),
        ("enemies", L["encounters.tab.enemies"], "enemies"),
        ("encounters", L["encounters.tab.encounters"], "encounters"),
    ];

    private (string, string)[] StyleOptions =>
        [("pips", L["partyEditor.stylePips"]), ("number", L["partyEditor.styleNumber"])];

    protected override void OnParametersSet()
    {
        // ?tab= (set by a "back" from an editor) selects the initial section; default is the Encounters list.
        if (Tab is "players" or "enemies" or "encounters") _tab = Tab;
    }

    protected override async Task OnInitializedAsync()
    {
        await Api.GetApiKeyAsync(); // cache the key so portrait image urls carry it
        _party = await Api.GetPartyAsync();
        _system = (await Api.GetGameSystemsAsync())?.Active; // table-counter presets + the create-enemy seed
        _encounters = await Api.GetEncountersAsync();
        _loaded = true;
    }

    private static bool IsPips(PartyCounterDto c) =>
        string.Equals(c.Style, "pips", StringComparison.Ordinal) || (c.Style is null && c.Max is >= 1 and <= 24);

    private static string Initial(string name)
    {
        name = name.Trim();
        if (name.Length == 0) return "?";
        return name.EnumerateRunes().First().ToString().ToUpperInvariant();
    }

    // ---------- table counters ----------

    private async Task AdjustTable(string label, int delta)
    {
        if (_busy || _pendingCounter is not null) return;
        _pendingCounter = label;
        try
        {
            var (result, error) = await Api.AdjustTableCounterAsync(label, delta);
            if (error is not null) { Ui.ReportError(error); return; }
            if (result is not null && _party is not null) _party = _party with { Counters = result };
        }
        finally { _pendingCounter = null; }
    }

    private void StartEditingCounters()
    {
        _counters = [.. (_party?.Counters ?? []).Select(CounterEdit.FromDto)];
        _editingCounters = true;
    }

    private void AddCounter() => _counters.Add(new CounterEdit { Label = "", Value = 0, Max = 6, Style = "pips" });

    // Add one table-level preset from the active system (issue #129) — Daggerheart's Fear. CounterPresets stamps
    // the semantic key + localized label and skips it if the key/label already exists (re-click never dupes).
    private void AddTablePreset(CounterPresetDto preset) => CounterPresets.AddOne(_counters, preset, k => L[k]);

    private async Task SaveCounters()
    {
        if (_busy) return;
        _busy = true;
        try
        {
            var (result, error) = await Api.SaveTableCountersAsync([.. _counters.Select(c => c.ToDto())]);
            if (error is not null) { Ui.ReportError(error); return; }
            if (result is not null && _party is not null) _party = _party with { Counters = result };
            _editingCounters = false;
        }
        finally { _busy = false; }
    }

    // ---------- player counters ----------

    private async Task AdjustPlayer(string id, string label, int delta)
    {
        var key = RowKey(id, label);
        if (_pendingRows.Contains(key)) return;
        _pendingRows.Add(key);
        try
        {
            var (result, error) = await Api.AdjustPlayerCounterAsync(id, label, delta);
            if (error is not null) { Ui.ReportError(error); return; }
            if (result is not null) ReplacePlayer(result);
        }
        finally { _pendingRows.Remove(key); }
    }

    private static string RowKey(string id, string label) => $"{id} {label}";
    private bool IsRowBusy(string id, string label) => _pendingRows.Contains(RowKey(id, label));

    private void ReplacePlayer(PartyPlayerDto updated)
    {
        if (_party is null) return;
        var players = _party.Players
            .Select(p => string.Equals(p.Id, updated.Id, StringComparison.OrdinalIgnoreCase) ? updated : p)
            .ToList();
        _party = _party with { Players = players };
    }

    // ---------- create flows ----------

    private async Task CreatePlayer()
    {
        if (_busy) return;
        if (string.IsNullOrWhiteSpace(_newName)) { Ui.ReportError(L["party.toast.nameFirst"]); return; }
        var existing = _party?.Players.Select(p => p.Id).ToList() ?? [];
        var id = SceneNaming.MakeUnique(SceneNaming.Slugify(_newName), existing);
        if (string.IsNullOrEmpty(id)) { Ui.ReportError(L["party.toast.badId"]); return; }
        _busy = true;
        try
        {
            var nextOrder = existing.Count > 0 ? _party!.Players.Max(p => p.SortOrder) + 1 : 0;
            var (_, error) = await Api.SavePlayerAsync(id, new PartyPlayerDto(id, _newName.Trim(), null, nextOrder, []));
            if (error is not null) { Ui.ReportError(error); return; }
            await Vt.NavigateAsync($"party/{id}");
        }
        finally { _busy = false; }
    }

    private async Task CreateEnemy()
    {
        if (_busy) return;
        if (string.IsNullOrWhiteSpace(_newEnemyName)) { Ui.ReportError(L["party.toast.nameFirst"]); return; }
        var existing = _party?.Enemies.Select(e => e.Id).ToList() ?? [];
        var id = SceneNaming.MakeUnique(SceneNaming.Slugify(_newEnemyName), existing);
        if (string.IsNullOrEmpty(id)) { Ui.ReportError(L["party.toast.badId"]); return; }
        _busy = true;
        try
        {
            var nextOrder = existing.Count > 0 ? _party!.Enemies.Max(e => e.SortOrder) + 1 : 0;
            // Seed the new enemy with the active system's enemy preset loadout (issue #129); keys + localized
            // labels are stamped by CounterPresets. No system (or one with no enemy presets) → no counters.
            var seed = new List<CounterEdit>();
            CounterPresets.Apply(seed, _system?.EnemyCounters ?? [], k => L[k]);
            var counters = seed.Select(c => c.ToDto()).ToList();
            var (_, error) = await Api.SaveEnemyAsync(id, new PartyEnemyDto(id, _newEnemyName.Trim(), null, nextOrder, counters));
            if (error is not null) { Ui.ReportError(error); return; }
            await Vt.NavigateAsync($"party/enemies/{id}");
        }
        finally { _busy = false; }
    }

    private async Task CreateEncounter()
    {
        if (_busy) return;
        if (string.IsNullOrWhiteSpace(_newEncounterName)) { Ui.ReportError(L["party.toast.nameFirst"]); return; }
        var existing = _encounters.Select(e => e.Id).ToList();
        var id = SceneNaming.MakeUnique(SceneNaming.Slugify(_newEncounterName), existing);
        if (string.IsNullOrEmpty(id)) { Ui.ReportError(L["party.toast.badId"]); return; }
        _busy = true;
        try
        {
            var nextOrder = existing.Count > 0 ? _encounters.Max(e => e.SortOrder) + 1 : 0;
            var edit = new EncounterEdit { Id = id, Name = _newEncounterName.Trim(), SortOrder = nextOrder };
            var (_, error) = await Api.SaveEncounterAsync(id, edit);
            if (error is not null) { Ui.ReportError(error); return; }
            await Vt.NavigateAsync($"encounters/{id}");
        }
        finally { _busy = false; }
    }

    // ---------- run an encounter straight from the list ----------

    private async Task RunEncounter(string id)
    {
        if (_busy) return;
        _busy = true;
        try
        {
            var (result, error) = await Api.RunEncounterAsync(id);
            if (error is not null) { Ui.ReportError(error); return; }
            if (result is not null) Ui.ReportOk(L["encounters.toast.ran"]);
        }
        finally { _busy = false; }
    }

    // ---------- import (content packs) ----------

    // Reload every list the hub shows after a pack import (players/enemies live on the party DTO).
    private async Task Reload()
    {
        _party = await Api.GetPartyAsync();
        _encounters = await Api.GetEncountersAsync();
        StateHasChanged();
    }

    // ---------- navigation ----------

    private Task EditPlayer(string id) => Vt.NavigateAsync($"party/{id}");
    private Task EditEnemy(string id) => Vt.NavigateAsync($"party/enemies/{id}");
    private Task EditEncounter(string id) => Vt.NavigateAsync($"encounters/{id}");

    private static async Task OnKey(KeyboardEventArgs e, Func<Task> action)
    {
        if (e.Key is "Enter" or " ") await action();
    }

    private static async Task OnEnter(KeyboardEventArgs e, Func<Task> action)
    {
        if (e.Key == "Enter") await action();
    }

    // ---------- shared counter-input helpers ----------

    private static void SetStyle(CounterEdit c, string style)
    {
        c.Style = style;
        if (style == "pips") c.Max = Math.Clamp(c.Max ?? 6, 1, 24);
    }

    private static void SetMax(CounterEdit c, object? raw)
    {
        var text = raw?.ToString();
        if (string.IsNullOrWhiteSpace(text)) c.Max = null;
        else if (int.TryParse(text, out var v)) c.Max = Math.Clamp(v, 1, 999);
        if (c.Style == "pips") c.Max = Math.Min(c.Max ?? 6, 24);
    }

    private static int ClampInt(object? raw, int fallback, int min, int max) =>
        int.TryParse(raw?.ToString(), out var v) ? Math.Clamp(v, min, max) : fallback;
}
