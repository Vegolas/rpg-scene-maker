@inject ApiClient Api
@inject UiState Ui
@inject Localizer L

@* The local-music import field (file pick → multipart upload → toast), extracted from the Music tab so
   the first-run onboarding wizard reuses the exact same flow. The host reacts to OnImported (refresh
   its track list, re-poll the transport, count imports). *@

<div class="field" style="margin-bottom:0">
    <label for="@InputId">@L["music.local.importLabel"]</label>
    <InputFile id="@InputId" OnChange="OnFilePicked" accept=".mp3,.wav,.ogg" disabled="@_uploading" />
    <p class="hint" style="margin-top:0.5rem">
        @if (_uploading)
        {
            <span>@L.Format("music.local.importing", _uploadName)</span>
        }
        else
        {
            <span>@L["music.local.importHint"]</span>
        }
    </p>
</div>

@code {
    /// <summary>DOM id for the file input — override when two instances could coexist (wizard over Music tab).</summary>
    [Parameter] public string InputId { get; set; } = "music-import";

    /// <summary>Raised with the new track after a successful import.</summary>
    [Parameter] public EventCallback<MusicTrackDto> OnImported { get; set; }

    private bool _uploading;
    private string _uploadName = "";

    private async Task OnFilePicked(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;

        _uploading = true;
        _uploadName = file.Name;
        StateHasChanged();
        try
        {
            var name = Path.GetFileNameWithoutExtension(file.Name);
            var (result, error) = await Api.UploadMusicTrackAsync(file, name, "");
            if (result is not null)
            {
                Ui.ReportOk(L.Format("music.local.toast.imported", result.Name));
                await OnImported.InvokeAsync(result);
            }
            else
            {
                Ui.ReportError(error ?? L["music.local.toast.importFailed"]);
            }
        }
        finally
        {
            _uploading = false;
            _uploadName = "";
            StateHasChanged();
        }
    }
}
