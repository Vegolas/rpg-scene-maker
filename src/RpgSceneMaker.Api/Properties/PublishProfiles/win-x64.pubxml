<?xml version="1.0" encoding="utf-8"?>
<!--
  One-artifact Windows build for non-technical users (issue #75).

  Produces a self-contained win-x64 build: a single RpgSceneMaker.Api.exe (the .NET runtime, the API
  and all server DLLs collapsed into one file, native libs self-extracted at runtime) next to a small
  wwwroot/ folder (the hosted Blazor WASM panel) and a couple of editable config files. The whole publish
  folder is zipped by the release workflow into rpg-scene-maker-win-x64.zip — the user unzips it and
  double-clicks the exe, no SDK install.

  Why not a single self-extracting exe (IncludeAllContentForSelfExtract)? The panel's Blazor WASM assets
  (wwwroot/_framework/*.wasm — the runtime the browser downloads) are tracked by the static-web-assets
  system, not as bundle-able "content", so they stay loose next to the exe regardless. Keeping the config
  loose is also deliberate: appsettings.json is user-editable (port, API key) and scenes.json is the
  starter-scene template LegacyImporter reads from the content root on first run.

  These flags live here (not on the `dotnet publish` command line) on purpose: command-line
  -p:PublishSingleFile=true propagates to the referenced Blazor WASM UI project, which cannot be
  single-file (NETSDK1098). A publish profile scopes them to this project only.

  Build it with:  dotnet publish src/RpgSceneMaker.Api -p:PublishProfile=win-x64
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishProtocol>FileSystem</PublishProtocol>
    <_TargetId>Folder</_TargetId>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
  </PropertyGroup>
</Project>
