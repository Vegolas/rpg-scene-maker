@inherits LayoutComponentBase
@implements IDisposable
@inject UiState Ui
@inject ApiClient Api
@inject NavigationManager Nav
@inject ViewTransition Vt
@inject Localizer L

@* Keyed on the language so a runtime switch rebuilds the whole subtree — components that read strings
   internally (QuickControls, NowRunningStrip, SwatchGrid, …) don't otherwise re-render on L.Changed. *@
<div class="shell" @key="L.CurrentCode">
    <nav class="rail">
        @foreach (var tab in VisibleTabs)
        {
            <a @key="tab.Href" href="@tab.Href" class="rail__item @ActiveClass(tab)"
               @onclick:preventDefault @onclick="() => Vt.NavigateAsync(tab.Href)">
                <span class="icon"><Icon Name="@tab.Icon" /></span>@L[tab.LabelKey]
            </a>
        }
    </nav>

    <div class="main-col">
        <header class="topbar">
            <span class="topbar__title">SCENE MAKER</span>
            @if (SearchPlaceholder is { } placeholder)
            {
                <div class="searchbar">
                    <span class="searchbar-ico" aria-hidden="true"><Icon Name="search" /></span>
                    <input type="search" inputmode="search" placeholder="@placeholder" value="@Ui.SearchQuery"
                           aria-label="@placeholder" @oninput="e => Ui.SetSearchQuery(e.Value?.ToString())" />
                    @if (Ui.SearchQuery.Length > 0)
                    {
                        <button class="searchbar-clear" @onclick='() => Ui.SetSearchQuery("")' aria-label='@L["topbar.clearSearch"]'><Icon Name="close" /></button>
                    }
                </div>
            }
            else
            {
                <span class="topbar__spacer"></span>
            }
            @if (Ui.Connected)
            {
                <span class="badge badge--online" title='@L["topbar.onlineTitle"]'><span class="dot"></span>@L["topbar.online"]</span>
            }
            else
            {
                <span class="badge badge--offline" title='@L["topbar.offlineTitle"]'><span class="dot"></span>@L["topbar.offline"]</span>
            }
            <QuickControls />
            <button class="btn btn--icon" @onclick='() => Vt.NavigateAsync("settings")' aria-label='@L["nav.settings"]'><Icon Name="settings" /></button>
        </header>

        <main class="page">
            <NowRunningStrip />
            @Body
        </main>
    </div>

    <nav class="tabbar">
        @foreach (var tab in VisibleTabs)
        {
            <a @key="tab.Href" href="@tab.Href" class="@ActiveClass(tab)"
               @onclick:preventDefault @onclick="() => Vt.NavigateAsync(tab.Href)">
                <span class="tab-ico"><Icon Name="@tab.Icon" /></span>@L[tab.LabelKey]
            </a>
        }
    </nav>

    @if (Ui.Toast is not null)
    {
        <div class="toast @(Ui.ToastIsError ? "error" : "")">@Ui.Toast</div>
    }
</div>

@code {
    // LabelKey is an i18n key ("nav.scenes"); the rail/tabbar render it through the localizer.
    private record Tab(string Href, string Icon, string LabelKey, bool Exact = false);

    private static readonly Tab[] Tabs =
    [
        new("", "scenes", "nav.scenes", Exact: true),
        new("screens", "screens", "nav.screens"),
        new("music", "music", "nav.music"),
        new("lights", "lights", "nav.lights"),
        new("sounds", "sounds", "nav.sounds"),
        new("events", "events", "nav.events"),
        new("effects", "effects", "nav.effects"),
    ];

    // The Assistant tab only appears once an AI provider key is configured (Settings → Assistant).
    private static readonly Tab AssistantTab = new("assistant", "assistant", "Assistant");

    // The Logs tab (with its diagnostics panel) only appears when developer mode is on.
    private static readonly Tab LogsTab = new("logs", "logs", "nav.logs");

    // Routes that show the header search bar, mapped to the i18n key of their placeholder. Exact path match,
    // so deep pages (a board, an editor) don't inherit it. Each page filters its contents by Ui.SearchQuery.
    private static readonly Dictionary<string, string> SearchablePages = new(StringComparer.OrdinalIgnoreCase)
    {
        [""] = "search.scenes",
        ["screens"] = "search.screens",
        ["music"] = "search.playlists",
        ["sounds"] = "search.sounds",
        ["events"] = "search.events",
    };

    // The built-in tabs, plus the Assistant tab when a provider key is configured and the Logs tab in dev mode.
    private IEnumerable<Tab> KnownTabs
    {
        get
        {
            List<Tab> tabs = [.. Tabs];
            if (Ui.AssistantConfigured) tabs.Add(AssistantTab);
            if (Ui.DevMode) tabs.Add(LogsTab);
            return tabs;
        }
    }

    // Tabs in the user's saved order; tabs missing from it (new build, or Logs when it wasn't ordered)
    // keep their built-in order at the end (OrderBy is stable, so equal keys don't shuffle).
    private List<Tab> VisibleTabs
    {
        get
        {
            var order = Ui.TabOrder;
            if (order.Count == 0) return [.. KnownTabs];
            return [.. KnownTabs.OrderBy(t => Rank(order, t.Href))];
        }
    }

    private static int Rank(IReadOnlyList<string> order, string href)
    {
        for (var i = 0; i < order.Count; i++)
            if (order[i] == href) return i;
        return int.MaxValue; // unknown/new tab (or Logs when it wasn't ordered) → falls to the end
    }

    private string? SearchPlaceholder =>
        SearchablePages.TryGetValue(CurrentPath(), out var key) ? L[key] : null;

    protected override async Task OnInitializedAsync()
    {
        Ui.Changed += OnUiChanged;
        // A language switch re-renders the whole app from here (cascades through @Body to every page).
        L.Changed += OnUiChanged;
        // The active tab is derived from the URL, so re-render whenever it changes.
        Nav.LocationChanged += OnLocationChanged;
        // Load the per-device flags so the nav renders correctly from the first paint.
        Ui.SetDevMode(await Api.GetDevModeAsync());
        Ui.SetTabOrder(await Api.GetTabOrderAsync());
        // The Assistant tab is gated on a server-side provider key; load it too.
        var (assistant, _) = await Api.GetAssistantConfigAsync();
        Ui.SetAssistantConfigured(assistant?.Configured ?? false);
    }

    private void OnUiChanged() => InvokeAsync(StateHasChanged);

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        Ui.SetSearchQuery(""); // a fresh search per page
        InvokeAsync(StateHasChanged);
    }

    // Current base-relative path, without any query string, trimmed of slashes.
    private string CurrentPath()
    {
        var current = Nav.ToBaseRelativePath(Nav.Uri);
        var query = current.IndexOf('?');
        if (query >= 0) current = current[..query];
        return current.Trim('/');
    }

    // Mirrors NavLink: exact match for the Scenes root, prefix match for the rest.
    private string ActiveClass(Tab tab)
    {
        var current = CurrentPath();
        var active = tab.Exact
            ? current.Length == 0
            : current == tab.Href || current.StartsWith(tab.Href + "/", StringComparison.OrdinalIgnoreCase);
        return active ? "active" : "";
    }

    public void Dispose()
    {
        Ui.Changed -= OnUiChanged;
        L.Changed -= OnUiChanged;
        Nav.LocationChanged -= OnLocationChanged;
    }
}
