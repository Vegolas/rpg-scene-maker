@page "/music"
@implements IDisposable
@inject ApiClient Api
@inject UiState Ui

<PageTitle>Scene Maker — Music</PageTitle>

@if (_connected == false)
{
    <RuneHeading>Music</RuneHeading>
    <p class="empty-note">Spotify isn't connected yet — open <a href="settings">Settings</a> to connect it.</p>
}
else
{
    <RuneHeading>Now Playing</RuneHeading>

    <div class="panel">
        <p class="now-title">@(_state?.TrackName ?? "Nothing playing")</p>
        <p class="now-sub">
            @if (_state is not null)
            {
                @(_state.ArtistName ?? "—")
                @if (!string.IsNullOrEmpty(_state.DeviceName))
                {
                    <span class="hint"> · @_state.DeviceName</span>
                }
            }
            else
            {
                <span>Open Spotify on a device to start</span>
            }
        </p>

        @if (_state is { DurationSeconds: > 0 })
        {
            <div class="progress"><div style="width:@(ProgressPercent().ToString("0.#", System.Globalization.CultureInfo.InvariantCulture))%"></div></div>
        }

        <div class="transport">
            <button class="btn" @onclick="@(() => Send("music/previous"))" aria-label="Previous">⏮</button>
            @if (_state?.IsPlaying == true)
            {
                <button class="btn primary play" @onclick="@(() => Send("music/pause"))" aria-label="Pause">⏸</button>
            }
            else
            {
                <button class="btn primary play" @onclick="@(() => Send("music/resume"))" aria-label="Play">▶</button>
            }
            <button class="btn" @onclick="@(() => Send("music/next"))" aria-label="Next">⏭</button>
        </div>

        <SliderRow LeftIcon="🔉" Min="0" Max="100" Suffix="%" Value="_volumePercent"
                   ValueChanged="OnVolumeChanged" AriaLabel="Volume" />

        <div class="chip-row">
            <Chip On="ShuffleOn" OnClick="ToggleShuffle">🔀 Shuffle</Chip>
            <Chip On="RepeatOn" OnClick="CycleRepeat">@RepeatLabel()</Chip>
        </div>
    </div>

    <RuneHeading>Search</RuneHeading>
    <div class="panel">
        <div class="field">
            <label for="spotify-search">Search tracks</label>
            <div class="field-row">
                <input id="spotify-search" type="text" @bind="_query" @bind:event="oninput"
                       @onkeydown="OnSearchKeyDown" placeholder="song or artist…" />
                <button class="btn" @onclick="SearchAsync" disabled="@_searching">Search</button>
            </div>
        </div>
        @if (_results is { Count: > 0 })
        {
            <div class="klist">
                @foreach (var t in _results)
                {
                    var label = string.IsNullOrEmpty(t.Artist) ? t.Name : $"{t.Name} — {t.Artist}";
                    <KRow Icon="♪" Title="@t.Name" Hint="@t.Artist" OnClick="() => Play(t.Uri, label)" />
                }
            </div>
        }
    </div>

    <RuneHeading>Playlists</RuneHeading>
    <PlaylistPicker Playlists="_playlists" OnPick="pl => Play(pl.Uri, pl.Name)">
        <EmptyContent>
            <p class="empty-note">No Spotify playlists found.</p>
        </EmptyContent>
    </PlaylistPicker>
}

@code {
    private bool? _connected;
    private SpotifyStateDto? _state;
    private List<SpotifyPlaylistDto>? _playlists;
    private List<SpotifyTrackDto>? _results;
    private string _query = "";
    private bool _searching;
    private int _volumePercent = 50;
    private Timer? _timer;

    private bool ShuffleOn => _state?.IsShuffling == true;
    private bool RepeatOn => _state is { Repeat: "playlist" or "track" };

    protected override async Task OnInitializedAsync()
    {
        var (spotify, _) = await Api.GetSpotifyConfigAsync();
        _connected = spotify?.Connected == true;
        if (_connected != true) return;

        await PollAsync();
        _timer = new Timer(_ => _ = InvokeAsync(PollAsync), null, 3000, 3000);

        var (playlists, error) = await Api.GetSpotifyPlaylistsAsync();
        _playlists = playlists ?? [];
        if (playlists is null && error is not null) Ui.ReportError(error);
    }

    private async Task PollAsync()
    {
        _state = await Api.GetSpotifyStateAsync();
        if (_state?.VolumePercent is { } vp) _volumePercent = vp;
        StateHasChanged();
    }

    private double ProgressPercent() =>
        _state is { ProgressSeconds: { } p, DurationSeconds: { } d } && d > 0
            ? Math.Clamp(p / d * 100, 0, 100)
            : 0;

    private string RepeatLabel() => _state?.Repeat switch
    {
        "track" => "🔂 Repeat track",
        "playlist" => "🔁 Repeat list",
        _ => "🔁 No repeat",
    };

    // off → playlist → track → off
    private Task CycleRepeat()
    {
        var next = _state?.Repeat switch { "off" or null => "playlist", "playlist" => "track", _ => "off" };
        return Send($"music/repeat?mode={next}");
    }

    private Task ToggleShuffle() => Send($"music/shuffle?value={(ShuffleOn ? "false" : "true")}");

    private async Task Send(string path)
    {
        if (await Api.CommandAsync(path))
            await PollAsync();
    }

    private async Task Play(string uri, string title)
    {
        if (await Api.CommandAsync($"music/play?id={Uri.EscapeDataString(uri)}", $"Playing {title}"))
            await PollAsync();
    }

    private async Task OnVolumeChanged(int percent)
    {
        _volumePercent = percent;
        var volume = (percent / 100.0).ToString(System.Globalization.CultureInfo.InvariantCulture);
        await Api.CommandAsync($"music/volume?value={volume}");
    }

    private async Task SearchAsync()
    {
        if (string.IsNullOrWhiteSpace(_query)) return;
        _searching = true;
        try
        {
            var (results, error) = await Api.SearchSpotifyTracksAsync(_query);
            if (results is not null) _results = results;
            else if (error is not null) Ui.ReportError(error);
        }
        finally { _searching = false; }
    }

    private async Task OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchAsync();
    }

    public void Dispose() => _timer?.Dispose();
}
