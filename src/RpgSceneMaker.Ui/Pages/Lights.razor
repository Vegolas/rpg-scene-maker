@page "/lights"
@inject ApiClient Api
@inject UiState Ui

<PageTitle>Scene Maker — Lights</PageTitle>

<div class="page-head"><h1>Lights</h1></div>

@if (_registry.Count > 0)
{
    <SectionHeading>Target</SectionHeading>
    <div class="chip-row">
        <Chip On="_target is null" OnClick="() => _target = null">All</Chip>
        @foreach (var light in _registry)
        {
            <Chip On="_target == light.Key" OnClick="() => _target = light.Key">@light.Name</Chip>
        }
    </div>
}

<SectionHeading>Power</SectionHeading>
<div class="btn-row">
    <button class="btn btn--big btn--primary" @onclick="@(() => Send(Path("on"), "Light on"))">On</button>
    @if (_target is null)
    {
        <button class="btn btn--big" @onclick="@(() => Send("lights/toggle"))">Toggle</button>
    }
    <button class="btn btn--big btn--danger" @onclick="@(() => Send(Path("off"), "Light off"))">Off</button>
</div>

<SectionHeading>Mood Colors</SectionHeading>
<SwatchGrid Selected="_pickedHex" OnPick="OnColorPicked" />

<SectionHeading>Brightness</SectionHeading>
<div class="panel">
    <SliderRow LeftIcon="🔅" Min="1" Max="100" Suffix="%" Value="_brightness"
               ValueChanged="OnBrightnessChanged" AriaLabel="Brightness" />
</div>

<SectionHeading>White Light</SectionHeading>
<div class="panel">
    <SliderRow LeftIcon="🕯️" RightIcon="❄️" Min="0" Max="100" Value="_temperature"
               ValueChanged="OnTemperatureChanged" AriaLabel="Color temperature" />
    <div class="btn-row">
        <button class="btn btn--primary" @onclick="ApplyWhite">Set white (@_brightness%, @TempLabel)</button>
    </div>
</div>

@code {
    private List<RegisteredLightInfo> _registry = [];
    private string? _target;   // null = all lights (group endpoints); else a registry key

    private string _pickedHex = "#ff8c2a";
    private int _brightness = 80;
    private int _temperature = 40;

    private string TempLabel => LightFormat.TempWord(_temperature);

    protected override async Task OnInitializedAsync() =>
        _registry = await Api.GetRegisteredLightsAsync();

    // Command path: group endpoint (/lights/...) for "All", per-light (/lights/{key}/...) otherwise.
    private string Path(string command) => _target is null ? $"lights/{command}" : $"lights/{_target}/{command}";

    private Task Send(string path, string? ok = null) => Api.CommandAsync(path, ok);

    private async Task OnColorPicked(string hex)
    {
        _pickedHex = hex;
        var name = Palette.Moods.FirstOrDefault(m => string.Equals(m.Hex, hex, StringComparison.OrdinalIgnoreCase)).Name
                   ?? "custom color";
        await Api.CommandAsync($"{Path("color")}?hex={Uri.EscapeDataString(hex.TrimStart('#'))}&brightness={_brightness}", $"Light: {name}");
    }

    private async Task OnBrightnessChanged(int value)
    {
        _brightness = value;
        await Api.CommandAsync($"{Path("brightness")}?value={value}");
    }

    private async Task OnTemperatureChanged(int value)
    {
        _temperature = value;
        await ApplyWhite();
    }

    private Task ApplyWhite() =>
        Api.CommandAsync($"{Path("white")}?brightness={_brightness}&temperature={_temperature}", $"White light ({TempLabel})");
}
