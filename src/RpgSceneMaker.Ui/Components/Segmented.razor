@* A segmented control: one button per option, the one equal to Value is highlighted.
   Renders the design-system `.seg` primitive; `.seg--block` stretches the options full-width. *@
@typeparam TValue

<div class="seg seg--block" style="@Style">
    @foreach (var opt in Options)
    {
        <button type="button" class="seg__opt @(Equals(opt.Value, Value) ? "seg__opt--active" : "")"
                @onclick="() => ValueChanged.InvokeAsync(opt.Value)">@opt.Label</button>
    }
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<(TValue Value, string Label)> Options { get; set; } = [];
    [Parameter] public TValue? Value { get; set; }
    [Parameter] public EventCallback<TValue> ValueChanged { get; set; }
    [Parameter] public string? Style { get; set; }
}
