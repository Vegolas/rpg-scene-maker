@page "/sounds/editor/{SoundId}"
@inject ApiClient Api
@inject UiState Ui
@inject NavigationManager Nav
@inject ViewTransition Vt

<PageTitle>Scene Maker — Edit sound</PageTitle>

@if (_loading)
{
    <p class="empty-note">Uncorking the sound vial…</p>
}
else
{
    <div class="page-head"><h1>Edit Sound</h1></div>
    <div class="panel">
        <div class="field">
            <label for="snd-name">Name</label>
            <input id="snd-name" type="text" value="@_edit.Name" @oninput="e => _edit.Name = e.Value?.ToString() ?? string.Empty" />
        </div>
        <div class="field" style="margin-bottom:0">
            <label for="snd-cat">Category</label>
            <input id="snd-cat" type="text" value="@_edit.Category" @oninput="e => _edit.Category = e.Value?.ToString() ?? string.Empty"
                   placeholder="e.g. Ambience, Combat" />
        </div>
        <SliderRow LeftIcon="🔉" Min="0" Max="100" Suffix="%" @bind-Value="_edit.VolumePercent" AriaLabel="Volume" />
        <div class="chip-row">
            <Chip On="_edit.Loop" OnClick="() => _edit.Loop = !_edit.Loop">🔁 Loop</Chip>
        </div>
        <ArtField @bind-Image="_edit.Image" />
        <div class="btn-row" style="margin-top:1rem">
            <button class="btn btn--primary" @onclick="SaveEdit" disabled="@_busy">Save</button>
            <button class="btn" @onclick="Preview" disabled="@_busy">▶ Preview</button>
            <button class="btn" @onclick="Cancel" disabled="@_busy">Cancel</button>
        </div>
        <div class="btn-row" style="margin-top:0.7rem">
            <button class="btn btn--danger" @onclick="DeleteTapped" disabled="@_busy">
                @(_confirmDelete ? "Really delete?" : "Delete sound")
            </button>
        </div>
    </div>
}

@code {
    [Parameter] public string SoundId { get; set; } = "";

    private bool _loading = true;
    private SoundDto? _sound;
    private SoundEdit _edit = new();
    private bool _busy;
    private bool _confirmDelete;

    protected override async Task OnInitializedAsync()
    {
        var sounds = await Api.GetSoundsAsync();
        _sound = sounds.FirstOrDefault(s => string.Equals(s.Id, SoundId, StringComparison.OrdinalIgnoreCase));
        if (_sound is null)
        {
            Ui.ReportError($"Couldn't load sound \"{SoundId}\".");
            Nav.NavigateTo("sounds");
            return;
        }

        _edit = new SoundEdit
        {
            Name = _sound.Name,
            Category = _sound.Category,
            VolumePercent = (int)Math.Round(_sound.Volume * 100),
            Loop = _sound.Loop,
            Image = _sound.Image,
        };
        _loading = false;
    }

    private Task Cancel() => Vt.NavigateAsync("sounds");

    private async Task SaveEdit()
    {
        if (_sound is null) return;
        if (string.IsNullOrWhiteSpace(_edit.Name))
        {
            Ui.ReportError("Give the sound a name.");
            return;
        }

        _busy = true;
        try
        {
            var (result, error) = await Api.UpdateSoundAsync(
                _sound.Id, _edit.Name.Trim(), _edit.Category.Trim(), _edit.VolumePercent / 100.0, _edit.Loop, _edit.Image);
            if (result is not null)
            {
                Ui.ReportOk($"Saved \"{result.Name}\"");
                await Vt.NavigateAsync("sounds");
            }
            else
            {
                Ui.ReportError(error ?? "Save failed.");
            }
        }
        finally { _busy = false; }
    }

    // Audition at the (unsaved) edited volume so it can be dialled in before saving.
    private Task Preview()
    {
        if (_sound is null) return Task.CompletedTask;
        var volume = (_edit.VolumePercent / 100.0).ToString(System.Globalization.CultureInfo.InvariantCulture);
        return Api.CommandAsync($"sounds/{Uri.EscapeDataString(_sound.Id)}/play?volume={volume}");
    }

    private async Task DeleteTapped()
    {
        if (!_confirmDelete) { _confirmDelete = true; return; }
        if (_sound is null) return;

        _busy = true;
        try
        {
            var (ok, error) = await Api.DeleteSoundAsync(_sound.Id);
            if (ok)
            {
                Ui.ReportOk("Sound deleted");
                await Vt.NavigateAsync("sounds");
            }
            else
            {
                Ui.ReportError(error ?? "Delete failed.");
            }
        }
        finally { _busy = false; }
    }
}
