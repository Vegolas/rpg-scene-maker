@* Shared assistant chat surface: transcript log + composer, 1s polling of /assistant/state?rev=,
   send/stop/clear and busy handling. Hosted both by the full-page Assistant tab (window scroll) and
   the in-editor AssistantDrawer (Drawer="true" → the log scrolls its own container). The single
   conversation is server-side, so every mount just replays the persisted transcript. *@
@implements IDisposable
@inject ApiClient Api
@inject UiState Ui
@inject IJSRuntime JS
@inject Localizer L

@if (!_loaded)
{
    <p class="empty-note">@L["assistant.loading"]</p>
}
else if (!_configured)
{
    @* The host supplies the "no API key" panel; drawers never render here (they're gated on a key). *@
    @NotConfigured
}
else
{
    <div class="chat @(Drawer ? "chat--drawer" : "")">
        <div class="chat-log" @ref="_logEl">
            @if (_entries.Count == 0)
            {
                <p class="empty-note">@L["assistant.emptyPrompt"]</p>
            }
            @foreach (var e in _entries)
            {
                @switch (e.Kind)
                {
                    case "user":
                        <div class="chat-msg chat-msg--user"><div class="chat-bubble chat-bubble--user">@e.Text</div></div>
                        break;
                    case "assistant":
                        <div class="chat-msg chat-msg--assistant"><div class="chat-bubble chat-bubble--assistant">@e.Text</div></div>
                        break;
                    case "tool":
                        <div class="chat-tool @(e.ToolIsError == true ? "chat-tool--error" : "")">
                            <span class="chat-tool-ico">⚙</span>
                            <span class="chat-tool-name">@e.ToolName</span>
                            <span class="chat-tool-result">@Truncate(string.IsNullOrEmpty(e.Text) ? e.ToolResult : e.Text)</span>
                        </div>
                        break;
                    default: // "error"
                        <div class="chat-tool chat-tool--error">
                            <span class="chat-tool-ico">⚠️</span>
                            <span class="chat-tool-result">@e.Text</span>
                        </div>
                        break;
                }
            }
            @if (_busy)
            {
                <div class="chat-thinking"><span class="chat-thinking-dot"></span>@L["assistant.thinking"]</div>
            }
        </div>

        <div class="chat-composer">
            <textarea class="chat-input" rows="2" placeholder='@L["assistant.placeholder"]'
                      @bind="_input" @bind:event="oninput" @onkeydown="OnKeyDown"
                      disabled="@_busy"></textarea>
            <div class="chat-actions">
                @if (_busy)
                {
                    <button class="btn btn--danger" @onclick="StopAsync">@L["common.stop"]</button>
                }
                else
                {
                    <button class="btn btn--primary" @onclick="SendAsync"
                            disabled="@string.IsNullOrWhiteSpace(_input)">@L["assistant.send"]</button>
                }
                <ConfirmButton Class="btn" ConfirmLabel="@L["common.reallyClear"]" Disabled="_busy" OnConfirmed="ClearAsync">@L["assistant.clear"]</ConfirmButton>
            </div>
        </div>
    </div>
}

@code {
    // Editable text to pre-fill the composer with on first mount (e.g. the editor context draft).
    // Applied only when the composer is empty, so it never clobbers a message in progress.
    [Parameter] public string? InitialDraft { get; set; }

    // Drawer layout: the log scrolls its own container instead of the window, and the composer
    // is not window-sticky. Drives the .chat--drawer style hook.
    [Parameter] public bool Drawer { get; set; }

    // Fired when a run finishes (polled busy transitions true → false). The editor drawer uses this
    // to re-fetch and re-apply the entity the assistant may have changed.
    [Parameter] public EventCallback OnRunCompleted { get; set; }

    // Rendered when no provider key is configured — the host owns this panel's content.
    [Parameter] public RenderFragment? NotConfigured { get; set; }

    private readonly List<AssistantEntryDto> _entries = [];
    private string _input = "";
    private long _rev;
    private bool _busy;
    private bool _configured;
    private bool _loaded;
    private ElementReference _logEl;
    private Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        await PollAsync();
        _loaded = true;
        if (string.IsNullOrWhiteSpace(_input) && !string.IsNullOrEmpty(InitialDraft))
            _input = InitialDraft;
        StateHasChanged();
        _timer = new Timer(_ => _ = InvokeAsync(PollAsync), null, 1000, 1000);
    }

    private async Task PollAsync()
    {
        var state = await Api.GetAssistantStateAsync(_rev);
        if (state is null) return; // transport hiccup — the poll just flipped the connection dot

        var wasBusy = _busy;
        var changed = state.Busy != _busy || state.Configured != _configured;
        _busy = state.Busy;
        _configured = state.Configured;

        var grew = false;
        if (state.Entries is not null)
        {
            _entries.Clear();
            _entries.AddRange(state.Entries);
            _rev = state.Rev;
            changed = true;
            grew = true;
        }

        if (changed) StateHasChanged();
        if (grew) await ScrollToBottomAsync();

        // A run just finished — let the host react (e.g. refresh the edited entity).
        if (wasBusy && !_busy && OnRunCompleted.HasDelegate)
            await OnRunCompleted.InvokeAsync();
    }

    private async Task SendAsync()
    {
        var text = _input.Trim();
        if (_busy || text.Length == 0) return;
        _input = "";
        var (ok, error) = await Api.SendAssistantMessageAsync(text);
        if (!ok)
        {
            Ui.ReportError(error ?? L["assistant.toast.sendFailed"]);
            return;
        }
        await PollAsync(); // reflect the queued message + busy state without waiting for the next tick
    }

    // Enter sends; Shift+Enter inserts a newline. The bound value is cleared on send, so any stray newline
    // the keypress leaves behind is discarded on the next render.
    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
            await SendAsync();
    }

    private async Task StopAsync()
    {
        await Api.StopAssistantAsync();
        await PollAsync();
    }

    private async Task ClearAsync()
    {
        if (await Api.ClearAssistantAsync())
        {
            _rev = 0; // force the next poll to return the (now empty) full snapshot
            await PollAsync();
        }
    }

    private static string Truncate(string? s, int max = 160)
    {
        if (string.IsNullOrEmpty(s)) return "";
        s = s.Replace('\n', ' ').Replace('\r', ' ');
        return s.Length <= max ? s : s[..max] + "…";
    }

    // Full page: scroll the window so the newest message is visible (unchanged behavior).
    // Drawer: scroll the log's own container instead. Best-effort — a failure never breaks the poll.
    private async Task ScrollToBottomAsync()
    {
        try
        {
            if (Drawer)
                await JS.InvokeVoidAsync("rpgChat.scrollToBottom", _logEl);
            else
                await JS.InvokeVoidAsync("scrollTo", 0, 1_000_000);
        }
        catch { /* best effort */ }
    }

    public void Dispose() => _timer?.Dispose();
}
