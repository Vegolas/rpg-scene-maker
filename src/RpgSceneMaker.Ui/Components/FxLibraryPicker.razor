@* Library-reference controls for a light effect, shared by the scene editor's per-light section and the
   event timeline's light-clip inspector. Renders a "📚 From library" chip that opens a picker of saved
   Light FX; picking one makes the effect a live reference (Type "fx" + FxId). When referencing an FX it
   shows its name, an "Edit in library" link, and a "Detach to edit locally" button that copies the
   keyframes into an embedded "custom" effect. A dangling reference shows a ⚠ hint. *@

<div class="chip-row" style="margin-top:0.6rem">
    <Chip On="@(Effect.Type == "fx")" OnClick="TogglePicker">📚 From library</Chip>
</div>

@if (_pickerOpen)
{
    <div class="panel" style="margin-top:0.6rem">
        @if (Library.Count == 0)
        {
            <p class="hint" style="margin:0">No saved effects yet. Create some on the <a href="effects">Effects</a> tab first.</p>
        }
        else
        {
            <div class="klist">
                @foreach (var fx in Library)
                {
                    <KRow Icon="✨" Title="@fx.Name" Hint="@Meta(fx)"
                          Selected="@(Effect.Type == "fx" && string.Equals(Effect.FxId, fx.Id, StringComparison.OrdinalIgnoreCase))"
                          OnClick="() => Pick(fx)" />
                }
            </div>
        }
    </div>
}

@if (Effect.Type == "fx")
{
    var lib = Library.FirstOrDefault(f => string.Equals(f.Id, Effect.FxId, StringComparison.OrdinalIgnoreCase));
    <div class="panel" style="margin-top:0.6rem">
        @if (lib is not null)
        {
            <p style="margin:0"><strong>✨ @lib.Name</strong> <small class="hint">@Meta(lib)</small></p>
            <div class="btn-row" style="margin-top:0.6rem">
                <a class="btn small" href="effects/@lib.Id">Edit in library</a>
                <button class="btn small" @onclick="() => Detach(lib)">Detach to edit locally</button>
            </div>
            <p class="hint" style="margin-top:0.4rem">Live reference — editing it in the library updates every scene and event that uses it.</p>
        }
        else
        {
            <p class="hint" style="margin:0">⚠ References a missing effect (<code>@Effect.FxId</code>). Pick another above, or choose a different effect type.</p>
        }
    </div>
}

@code {
    [Parameter, EditorRequired] public EffectEdit Effect { get; set; } = new();
    [Parameter] public IReadOnlyList<LightFxDto> Library { get; set; } = [];

    private bool _pickerOpen;

    private void TogglePicker() => _pickerOpen = !_pickerOpen;

    private void Pick(LightFxDto fx)
    {
        Effect.Type = "fx";
        Effect.FxId = fx.Id;
        _pickerOpen = false;
    }

    // Convert the live reference into an embedded "custom" copy (edits no longer propagate back to the library).
    private void Detach(LightFxDto fx)
    {
        Effect.Type = "custom";
        Effect.Keyframes = (fx.Keyframes ?? []).Select(KeyframeEdit.FromDto).ToList();
        Effect.Loop = fx.Loop;
        Effect.CycleMs = fx.CycleMs;
        Effect.FxId = null;
        _pickerOpen = false;
    }

    private static string Meta(LightFxDto fx)
    {
        var count = fx.Keyframes?.Count ?? 0;
        var kf = $"{count} keyframe{(count == 1 ? "" : "s")}";
        return fx.Loop ? $"{kf} · 🔁 loop" : kf;
    }
}
