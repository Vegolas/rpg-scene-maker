@page "/sounds/editor/{SoundId}"
@inject ApiClient Api
@inject UiState Ui
@inject NavigationManager Nav
@inject ViewTransition Vt
@inject Localizer L

<PageTitle>Scene Maker — @L["soundEditor.title"]</PageTitle>

@if (_loading)
{
    <p class="empty-note">@L["soundEditor.loading"]</p>
}
else
{
    <div class="page-head"><h1>@L["soundEditor.title"]</h1></div>
    <div class="panel">
        <div class="field">
            <label for="snd-name">@L["soundEditor.nameLabel"]</label>
            <input id="snd-name" type="text" value="@_edit.Name" @oninput="e => _edit.Name = e.Value?.ToString() ?? string.Empty" />
        </div>
        <div class="field" style="margin-bottom:0">
            <label for="snd-cat">@L["soundEditor.categoryLabel"]</label>
            <input id="snd-cat" type="text" value="@_edit.Category" @oninput="e => _edit.Category = e.Value?.ToString() ?? string.Empty"
                   placeholder='@L["soundEditor.categoryPlaceholder"]' />
        </div>
        <SliderRow LeftIcon="volume" Min="0" Max="100" Suffix="%" @bind-Value="_edit.VolumePercent" AriaLabel='@L["soundEditor.volumeAria"]' />
        <div class="chip-row">
            <Chip On="_edit.Loop" OnClick="() => _edit.Loop = !_edit.Loop"><Icon Name="repeat" /> @L["common.loop"]</Chip>
        </div>
        <ArtField @bind-Image="_edit.Image" />
        @if (_sound?.HasAttribution == true)
        {
            <p class="hint" style="margin-top:0.8rem">
                @L["soundEditor.attrHeading"]:
                @if (!string.IsNullOrWhiteSpace(_sound.Author))
                {
                    <span>@L.Format("soundEditor.attrBy", _sound.Author)</span>
                }
                @if (!string.IsNullOrWhiteSpace(_sound.License))
                {
                    <text> — </text>
                    @if (!string.IsNullOrWhiteSpace(_sound.LicenseUrl))
                    {
                        <a href="@_sound.LicenseUrl" target="_blank" rel="noopener noreferrer">@_sound.License</a>
                    }
                    else
                    {
                        <span>@_sound.License</span>
                    }
                }
                @if (!string.IsNullOrWhiteSpace(_sound.SourceUrl))
                {
                    <text> · </text>
                    <a href="@_sound.SourceUrl" target="_blank" rel="noopener noreferrer">@L["soundEditor.attrSource"]</a>
                }
            </p>
        }
        <div class="btn-row" style="margin-top:1rem">
            <button class="btn btn--primary" @onclick="SaveEdit" disabled="@_busy">@L["common.save"]</button>
            <button class="btn" @onclick="Preview" disabled="@_busy"><Icon Name="play" /> @L["common.preview"]</button>
            <button class="btn" @onclick="Cancel" disabled="@_busy">@L["common.cancel"]</button>
        </div>
        <div class="btn-row" style="margin-top:0.7rem">
            <ConfirmButton Disabled="_busy" OnConfirmed="DeleteConfirmed">@L["soundEditor.deleteBtn"]</ConfirmButton>
        </div>
    </div>
}

@code {
    [Parameter] public string SoundId { get; set; } = "";

    private bool _loading = true;
    private SoundDto? _sound;
    private SoundEdit _edit = new();
    private bool _busy;

    protected override async Task OnInitializedAsync()
    {
        var sounds = await Api.GetSoundsAsync();
        _sound = sounds.FirstOrDefault(s => string.Equals(s.Id, SoundId, StringComparison.OrdinalIgnoreCase));
        if (_sound is null)
        {
            Ui.ReportError(L.Format("soundEditor.toast.loadFailed", SoundId));
            Nav.NavigateTo("sounds");
            return;
        }

        _edit = new SoundEdit
        {
            Name = _sound.Name,
            Category = _sound.Category,
            VolumePercent = (int)Math.Round(_sound.Volume * 100),
            Loop = _sound.Loop,
            Image = _sound.Image,
        };
        _loading = false;
    }

    private Task Cancel() => Vt.NavigateAsync("sounds");

    private async Task SaveEdit()
    {
        if (_sound is null) return;
        if (string.IsNullOrWhiteSpace(_edit.Name))
        {
            Ui.ReportError(L["soundEditor.toast.nameFirst"]);
            return;
        }

        _busy = true;
        try
        {
            var (result, error) = await Api.UpdateSoundAsync(
                _sound.Id, _edit.Name.Trim(), _edit.Category.Trim(), _edit.VolumePercent / 100.0, _edit.Loop, _edit.Image);
            if (result is not null)
            {
                Ui.ReportOk(L.Format("soundEditor.toast.saved", result.Name));
                await Vt.NavigateAsync("sounds");
            }
            else
            {
                Ui.ReportError(error ?? L["soundEditor.toast.saveFailed"]);
            }
        }
        finally { _busy = false; }
    }

    // Audition at the (unsaved) edited volume so it can be dialled in before saving.
    private Task Preview()
    {
        if (_sound is null) return Task.CompletedTask;
        var volume = (_edit.VolumePercent / 100.0).ToString(System.Globalization.CultureInfo.InvariantCulture);
        return Api.CommandAsync($"sounds/{Uri.EscapeDataString(_sound.Id)}/play?volume={volume}");
    }

    private async Task DeleteConfirmed()
    {
        if (_sound is null) return;

        _busy = true;
        try
        {
            var (ok, error) = await Api.DeleteSoundAsync(_sound.Id);
            if (ok)
            {
                Ui.ReportOk(L["soundEditor.toast.deleted"]);
                await Vt.NavigateAsync("sounds");
            }
            else
            {
                Ui.ReportError(error ?? L["soundEditor.toast.deleteFailed"]);
            }
        }
        finally { _busy = false; }
    }
}
