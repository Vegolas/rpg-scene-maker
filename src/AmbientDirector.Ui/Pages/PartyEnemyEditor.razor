@page "/party/enemies/{Id}"
@inject ApiClient Api
@inject UiState Ui
@inject ViewTransition Vt
@inject Localizer L

@* Enemy editor (issue #122): the player editor's twin — a bestiary statblock template with a portrait ArtField
   and base counter definitions (no live tracking, no spotlight — those live on an encounter instance). Load the
   whole roster, pick this enemy by id client-side, edit name / portrait / order / counters, then save it back.
   Blazor routes this over the player editor's "/party/{Id}" because the LITERAL "enemies" segment wins over the
   "{Id}" parameter. The Daggerheart set is a UI-only preset (the API stores generic counters). *@

<PageTitle>Ambient Director — @(_edit.Name is { Length: > 0 } n ? n : L["enemyEditor.title"])</PageTitle>

<div class="btn-row" style="margin-bottom:0.2rem">
    <button class="btn btn--small" @onclick='() => Vt.NavigateAsync("encounters?tab=enemies")'><Icon Name="back" /> @L["encounters.title"]</button>
</div>

@if (_loading)
{
    <p class="empty-note">@L["party.loading"]</p>
}
else if (_notFound)
{
    <div class="page-head"><h1>@L["enemyEditor.notFoundTitle"]</h1></div>
    <p class="empty-note">@L.Format("enemyEditor.notFoundBody", Id)<a href="encounters?tab=enemies">@L["encounters.title"]</a>@L["enemyEditor.notFoundBodyEnd"]</p>
}
else
{
    <div class="page-head"><h1>@(_edit.Name is { Length: > 0 } ? _edit.Name : L["enemyEditor.title"])</h1></div>

    <div class="party-editor">
        <div class="panel">
            <div class="field">
                <label for="e-name">@L["partyEditor.nameLabel"]</label>
                <input id="e-name" type="text" value="@_edit.Name"
                       @oninput="e => _edit.Name = e.Value?.ToString() ?? string.Empty" />
            </div>
            <div class="field" style="margin-bottom:0">
                <label for="e-order">@L["partyEditor.sortOrder"]</label>
                <input id="e-order" class="party-order" type="number" step="1" min="0" max="9999" value="@_edit.SortOrder"
                       @onchange="e => _edit.SortOrder = ClampInt(e.Value, _edit.SortOrder, 0, 9999)" />
            </div>
        </div>

        <SectionHeading>@L["partyEditor.portrait"]</SectionHeading>
        <div class="panel">
            <ArtField Image="_edit.Portrait" ImageChanged="v => _edit.Portrait = v" />
        </div>

        <SectionHeading>@L["partyEditor.counters"]</SectionHeading>
        <div class="panel">
            @if (_edit.Counters.Count == 0)
            {
                <p class="hint" style="margin:0">@L["partyEditor.noCounters"]</p>
            }
            else
            {
                <div class="party-ceditor">
                    @foreach (var (c, index) in _edit.Counters.Select((c, i) => (c, i)))
                    {
                        @* Key by the counter instance so a remove doesn't re-bind the inputs of the row below. *@
                        <div @key="c" class="party-crow-edit">
                            <input class="party-input party-input--label" type="text" value="@c.Label"
                                   placeholder='@L["partyEditor.labelLabel"]'
                                   @oninput="e => c.Label = e.Value?.ToString() ?? string.Empty" />
                            <label class="party-mini">
                                <span>@L["partyEditor.valueLabel"]</span>
                                <input type="number" min="0" max="999" value="@c.Value"
                                       @onchange="e => c.Value = ClampInt(e.Value, c.Value, 0, 999)" />
                            </label>
                            <label class="party-mini">
                                <span>@L["partyEditor.maxLabel"]</span>
                                <input type="number" min="1" max="999" value="@(c.Max?.ToString() ?? "")"
                                       @onchange="e => SetMax(c, e.Value)" />
                            </label>
                            <div class="party-style">
                                <span class="art-label">@L["partyEditor.styleLabel"]</span>
                                <Segmented TValue="string" Options="StyleOptions" Value="@c.Style"
                                           ValueChanged="v => SetStyle(c, v)" />
                            </div>
                            <button class="btn btn--icon btn--danger party-crow-edit__del" @onclick="() => _edit.Counters.RemoveAt(index)"
                                    aria-label='@L["boardEditor.removeElement"]'><Icon Name="close" /></button>
                        </div>
                    }
                </div>
            }
            <div class="btn-row" style="margin-top:var(--s-4,1rem)">
                <button class="btn btn--small" @onclick="AddCounter"><Icon Name="add" /> @L["party.addCounter"]</button>
                @* "Add {system} set" — the active game system's enemy preset loadout (issue #129); hidden when
                   no system is chosen or it offers none, leaving only the generic add-counter button. *@
                @if (_system?.EnemyCounters is { Count: > 0 })
                {
                    <button class="btn btn--small" @onclick="AddPresetSet">@L.Format("partyEditor.addSet", L[_system.NameKey])</button>
                }
            </div>
        </div>
    </div>

    <div class="editor-actions">
        <button class="btn btn--primary" @onclick="Save" disabled="@_busy">@L["common.save"]</button>
    </div>
    <div class="btn-row" style="margin-top:0.7rem">
        <button class="btn" @onclick="ExportPack" disabled="@_busy"><Icon Name="share" /> @L["share.export.btn"]</button>
        <ConfirmButton Disabled="_busy" OnConfirmed="DeleteConfirmed">@L["enemyEditor.delete"]</ConfirmButton>
    </div>
}

@code {
    [Parameter] public string Id { get; set; } = "";

    private bool _loading = true;
    private bool _notFound;
    private bool _busy;
    private EnemyEdit _edit = new();
    private GameSystemDto? _system;

    private (string, string)[] StyleOptions =>
        [("pips", L["partyEditor.stylePips"]), ("number", L["partyEditor.styleNumber"])];

    protected override async Task OnInitializedAsync()
    {
        await Api.GetApiKeyAsync(); // cache the key so the ArtField portrait thumbnail url carries it
        var party = await Api.GetPartyAsync();
        _system = (await Api.GetGameSystemsAsync())?.Active; // drives the "Add {system} set" preset button
        var dto = party?.Enemies.FirstOrDefault(e => string.Equals(e.Id, Id, StringComparison.OrdinalIgnoreCase));
        if (dto is null)
        {
            _notFound = true;
            _loading = false;
            return;
        }
        _edit = EnemyEdit.FromDto(dto);
        _loading = false;
    }

    private void AddCounter() => _edit.Counters.Add(new CounterEdit { Label = "", Value = 0, Max = 6, Style = "pips" });

    // Append the active system's enemy counter loadout (issue #129) — a UI-only convenience; the API still
    // stores generic counters. CounterPresets stamps each counter's semantic key + localized label and skips
    // any preset whose key/label already exists, so re-clicking never duplicates.
    private void AddPresetSet() => CounterPresets.Apply(_edit.Counters, _system!.EnemyCounters, k => L[k]);

    private static void SetStyle(CounterEdit c, string style)
    {
        c.Style = style;
        // pips needs a bounded, TV-renderable max (1–24) — clamp/default it when switching to pips.
        if (style == "pips") c.Max = Math.Clamp(c.Max ?? 6, 1, 24);
    }

    private static void SetMax(CounterEdit c, object? raw)
    {
        var text = raw?.ToString();
        if (string.IsNullOrWhiteSpace(text)) c.Max = null;
        else if (int.TryParse(text, out var v)) c.Max = Math.Clamp(v, 1, 999);
        if (c.Style == "pips") c.Max = Math.Min(c.Max ?? 6, 24);
    }

    private static int ClampInt(object? raw, int fallback, int min, int max) =>
        int.TryParse(raw?.ToString(), out var v) ? Math.Clamp(v, min, max) : fallback;

    private async Task Save()
    {
        if (_busy) return;
        if (string.IsNullOrWhiteSpace(_edit.Name))
        {
            Ui.ReportError(L["party.toast.nameFirst"]);
            return;
        }
        _busy = true;
        try
        {
            var (_, error) = await Api.SaveEnemyAsync(_edit.Id, _edit.ToDto());
            if (error is not null) { Ui.ReportError(error); return; }
            Ui.ReportOk(L.Format("enemyEditor.toast.saved", _edit.Name.Trim()));
        }
        finally { _busy = false; }
    }

    // Download a shareable pack for this enemy (bundles the portrait art).
    private Task ExportPack() => Api.ExportPackAsync("enemy", _edit.Id, L["share.export.done"]);

    private async Task DeleteConfirmed()
    {
        _busy = true;
        try
        {
            var (ok, error) = await Api.DeleteEnemyAsync(_edit.Id);
            if (ok) await Vt.NavigateAsync("encounters?tab=enemies");
            else Ui.ReportError(error ?? L["enemyEditor.toast.deleteFailed"]);
        }
        finally { _busy = false; }
    }
}
