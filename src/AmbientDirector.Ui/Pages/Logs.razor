@page "/logs"
@implements IDisposable
@inject ApiClient Api
@inject NavigationManager Nav
@inject Localizer L

<PageTitle>Ambient Director — @L["logs.title"]</PageTitle>

<div class="page-head"><h1>@L["logs.title"]</h1></div>

<SectionHeading>@L["logs.diagnostics"]</SectionHeading>
<div class="panel">
    @if (_diag is not null)
    {
        <dl class="diag">
            <dt>@L["logs.version"]</dt><dd>@_diag.Version</dd>
            <dt>@L["logs.environment"]</dt><dd>@_diag.Environment</dd>
            <dt>@L["logs.uptime"]</dt><dd>@Uptime(_diag.StartedAt)</dd>
            <dt>@L["logs.lightProvider"]</dt><dd>@L[LightFormat.ProviderLabelKey(_diag.LightProvider)]</dd>
            <dt>Spotify</dt><dd>@(_diag.SpotifyConnected ? L["logs.connected"] : L["logs.notConnected"])</dd>
            <dt>@L["logs.soundboard"]</dt>
            <dd>@(_diag.SoundboardSupported ? L.Format("logs.soundboardSupported", _diag.PlayingSoundCount) : L["logs.soundboardUnsupported"])</dd>
            <dt>@L["logs.scenes"]</dt><dd>@_diag.SceneCount</dd>
            <dt>@L["logs.sounds"]</dt><dd>@_diag.SoundCount</dd>
            <dt>@L["logs.events"]</dt><dd>@_diag.EventCount</dd>
            <dt>@L["logs.database"]</dt><dd><code>@_diag.DatabasePath</code></dd>
            <dt>@L["logs.soundsFolder"]</dt><dd><code>@_diag.SoundsPath</code></dd>
        </dl>
    }
    else if (_diagLoaded)
    {
        <p class="empty-note" style="margin:0.4rem 0">@L["logs.diagUnavailable"]</p>
    }
    else
    {
        <p class="empty-note" style="margin:0.4rem 0">@L["logs.diagGathering"]</p>
    }
    <div class="btn-row" style="margin-top:0.8rem">
        <button class="btn btn--small" @onclick="RefreshDiagnosticsAsync">@L["common.refresh"]</button>
    </div>
</div>

<SectionHeading>@L["logs.recent"]</SectionHeading>

<div class="chip-row">
    <Chip On="@(_filter == LogFilter.All)" OnClick="@(() => _filter = LogFilter.All)">@L["logs.filterAll"]</Chip>
    <Chip On="@(_filter == LogFilter.Warnings)" OnClick="@(() => _filter = LogFilter.Warnings)">@L["logs.filterWarnings"]</Chip>
    <Chip On="@(_filter == LogFilter.Errors)" OnClick="@(() => _filter = LogFilter.Errors)">@L["logs.filterErrors"]</Chip>
    <ConfirmButton Class="btn btn--small" ConfirmLabel="@L["common.reallyClear"]" OnConfirmed="ClearAsync">@L["logs.clear"]</ConfirmButton>
</div>

@if (_logs is null)
{
    <p class="empty-note">@L["logs.reading"]</p>
}
else
{
    var rows = Filtered().ToList();
    @if (rows.Count == 0)
    {
        <p class="empty-note">@(_filter == LogFilter.All ? L["logs.emptyAll"] : L["logs.emptyLevel"])</p>
    }
    else
    {
        <div class="log-list">
            @foreach (var e in rows)
            {
                <div class="log-row log-@e.Level.ToLowerInvariant()">
                    <span class="log-time">@e.Timestamp.ToString("HH:mm:ss")</span>
                    <span class="log-level">@e.Level</span>
                    <span class="log-cat">@e.Category</span>
                    <span class="log-msg">@e.Message</span>
                </div>
                @if (!string.IsNullOrEmpty(e.Exception))
                {
                    <pre class="log-exc">@e.Exception</pre>
                }
            }
        </div>
    }
}

@code {
    private enum LogFilter { All, Warnings, Errors }

    private List<LogEntryDto>? _logs;
    private LogFilter _filter = LogFilter.All;
    private Timer? _timer;
    private DiagnosticsDto? _diag;
    private bool _diagLoaded;

    protected override async Task OnInitializedAsync()
    {
        // Developer mode gates this page; when it's off there's no tab for it, so send the user home
        // (e.g. arriving via a stale bookmark). Authoritative check, independent of layout timing.
        if (!await Api.GetDevModeAsync())
        {
            Nav.NavigateTo("");
            return;
        }

        await RefreshDiagnosticsAsync();
        await RefreshAsync();
        _timer = new Timer(_ => _ = InvokeAsync(RefreshAsync), null, 2500, 2500);
    }

    private async Task RefreshAsync()
    {
        _logs = await Api.GetLogsAsync();
        StateHasChanged();
    }

    // Fetched on demand (load + Refresh button) rather than on the 2.5s log poll: the count fields
    // hit the database, so there's no need to re-query them every tick. Uptime still ticks along,
    // because the log poll re-renders the page and Uptime() recomputes from StartedAt.
    private async Task RefreshDiagnosticsAsync()
    {
        _diag = await Api.GetDiagnosticsAsync();
        _diagLoaded = true;
        StateHasChanged();
    }

    private IEnumerable<LogEntryDto> Filtered() => _filter switch
    {
        LogFilter.Warnings => _logs!.Where(l => l.Level is "Warning" or "Error" or "Critical"),
        LogFilter.Errors => _logs!.Where(l => l.Level is "Error" or "Critical"),
        _ => _logs!,
    };

    private async Task ClearAsync()
    {
        if (await Api.ClearLogsAsync(L["logs.toast.cleared"]))
            await RefreshAsync();
    }

    private static string Uptime(DateTimeOffset startedAt)
    {
        var span = DateTimeOffset.UtcNow - startedAt;
        if (span < TimeSpan.Zero) span = TimeSpan.Zero;
        if (span.TotalHours >= 1) return $"{(int)span.TotalHours}h {span.Minutes}m";
        if (span.TotalMinutes >= 1) return $"{span.Minutes}m {span.Seconds}s";
        return $"{span.Seconds}s";
    }

    public void Dispose() => _timer?.Dispose();
}
