@* Editor lives under /editor, outside the /scenes API namespace — GET /scenes/new would
   otherwise match the API's GET /scenes/{id} on a full page load and 404 instead of the app. *@
@page "/editor"
@page "/editor/{SceneId}"
@using System.Text.Json
@inject ApiClient Api
@inject UiState Ui
@inject NavigationManager Nav
@inject ViewTransition Vt
@inject Localizer L

<PageTitle>Scene Maker — @(_isNew ? L["sceneEditor.titleNew"] : L["sceneEditor.titleEdit"])</PageTitle>

@if (_loading)
{
    <p class="empty-note">@L["sceneEditor.loading"]</p>
}
else
{
    <div class="page-head">
        <h1>@(_isNew ? L["sceneEditor.titleNew"] : L["sceneEditor.titleEdit"])</h1>
        @if (Ui.AssistantConfigured && !_isNew)
        {
            <button class="btn" @onclick="AskAssistant"><Icon Name="assistant" /> @L["assistant.ask"]</button>
        }
    </div>

    @if (_drawerOpen)
    {
        <AssistantDrawer InitialDraft="@AssistantDraft" OnRunCompleted="RefreshFromAssistantAsync" OnClose="() => _drawerOpen = false" />
    }

    <PageTabs TValue="SceneTab" Options="TabOptions" Value="_tab" ValueChanged="@(t => _tab = t)" />

    @if (_tab == SceneTab.Scene)
    {
    <div class="panel">
        <div class="emoji-row">
            @foreach (var e in Palette.Emojis)
            {
                <button class="emoji-pick @(e == _emoji ? "picked" : "")" @onclick="() => ToggleEmoji(e)">@e</button>
            }
        </div>
        <div class="field" style="margin-top:1rem;margin-bottom:0">
            <label for="scene-label">@L["sceneEditor.nameLabel"]</label>
            <input id="scene-label" type="text" value="@_label" @oninput="OnLabelInput" placeholder='@L["sceneEditor.namePlaceholder"]' />
        </div>
        <p class="hint" style="margin-top:0.6rem">
            @if (_isNew)
            {
                <span>@L["sceneEditor.streamDeckUrl"]: <code>/scenes/@(CurrentId is { Length: > 0 } cid ? cid : "…")/activate</code></span>
            }
            else
            {
                <span>@L["sceneEditor.idLabel"]: <code>@_edit.Id</code> @L["sceneEditor.idFixed"] — <code>/scenes/@_edit.Id/activate</code></span>
            }
        </p>
        <ArtField @bind-Image="_edit.Image" />
    </div>
    @* Delete lives here as a quietly separated danger zone at the bottom of the Scene tab. *@
    @if (!_isNew)
    {
        <div class="btn-row" style="margin-top:1.5rem">
            <ConfirmButton Disabled="_busy" OnConfirmed="DeleteConfirmed">@L["sceneEditor.deleteBtn"]</ConfirmButton>
        </div>
    }
    }
    else if (_tab == SceneTab.Lights)
    {
    <div class="panel">
        <Segmented TValue="LightScope" Options="ScopeOptions" Value="_scope" ValueChanged="SetScope" />

        @if (_scope == LightScope.All)
        {
            <Segmented TValue="LightMode" Options="ModeOptions" Value="_lightMode" ValueChanged="@(m => _lightMode = m)" Style="margin-top:1rem" />

            @if (_lightMode == LightMode.Color)
            {
                <SwatchGrid Selected="@_color" OnPick="@(hex => _color = hex)" Style="margin-top:1rem" />
                <SliderRow LeftIcon="dim" Min="1" Max="100" Suffix="%" @bind-Value="_brightness" AriaLabel='@L["sceneEditor.brightnessAria"]' />
            }
            else if (_lightMode == LightMode.White)
            {
                <SliderRow LeftIcon="warm" RightIcon="cold" Min="0" Max="100" @bind-Value="_temperature" AriaLabel='@L["sceneEditor.tempAria"]' />
                <SliderRow LeftIcon="dim" Min="1" Max="100" Suffix="%" @bind-Value="_brightness" AriaLabel='@L["sceneEditor.brightnessAria"]' />
            }
            else
            {
                <p class="hint" style="margin-top:0.8rem">@L["sceneEditor.lightsOffHint"]</p>
            }
        }
        else if (_scope == LightScope.PerLight)
        {
            @if (_perLight.Count == 0)
            {
                <p class="hint" style="margin-top:1rem">@L["sceneEditor.registerLightsPre"]<a href="settings?tab=lights">@L["sceneEditor.settingsLink"]</a>@L["sceneEditor.registerLightsPost"]</p>
            }
            else
            {
                <div class="light-rows" style="margin-top:1rem">
                    @foreach (var row in _perLight)
                    {
                        <div class="light-row @(row.Expanded ? "open" : "")">
                            <button class="light-head" @onclick="() => row.Expanded = !row.Expanded">
                                <span class="reg-badge @(row.Provider == "hue" ? "hue" : "tuya")">@L[LightFormat.ProviderLabelKey(row.Provider)]</span>
                                <span class="light-name">@row.Name @(row.Known ? "" : L["sceneEditor.unknownLight"])</span>
                                <span class="light-summary">@Summary(row)</span>
                                <span class="light-caret"><Icon Name="@(row.Expanded ? "caret-down" : "caret-right")" /></span>
                            </button>

                            @if (row.Expanded)
                            {
                                <div class="light-body">
                                    <Segmented TValue="string" Options="RowModeOptions" Value="row.Edit.Mode" ValueChanged="@(m => SetRowMode(row, m))" />

                                    @if (row.Edit.Mode is "color" or "white")
                                    {
                                        <p class="section-h">@L["sceneEditor.effectLabel"]</p>
                                        <div class="chip-row">
                                            @foreach (var (type, label) in Palette.Effects)
                                            {
                                                <Chip On="row.Edit.Effect.Type == type" OnClick="() => SetEffect(row, type)">@if (Palette.EffectIcon(type) is { Length: > 0 } ic) { <Icon Name="@ic" /> }@L[label]</Chip>
                                            }
                                        </div>

                                        @* "From library" belongs with the effect chooser: picking a saved FX (Type "fx")
                                           replaces the built-in effect and hides the per-effect controls below. *@
                                        <FxLibraryPicker Effect="row.Edit.Effect" Library="_fxLibrary" />

                                        @* Base colour/white — shown only for effects that build on it (static + flicker/glow/storm);
                                           drift needs just its brightness; custom/fx set colour + brightness per keyframe. *@
                                        @if (Palette.EffectUsesBaseColor(row.Edit.Effect.Type))
                                        {
                                            @if (row.Edit.Mode == "color")
                                            {
                                                <SwatchGrid Selected="@row.Edit.Color" OnPick="@(hex => row.Edit.Color = hex)" Style="margin-top:1rem" />
                                                <SliderRow LeftIcon="dim" Min="1" Max="100" Suffix="%" @bind-Value="row.Edit.Brightness" AriaLabel='@L["sceneEditor.brightnessAria"]' />
                                            }
                                            else
                                            {
                                                <SliderRow LeftIcon="warm" RightIcon="cold" Min="0" Max="100" @bind-Value="row.Edit.Temperature" AriaLabel='@L["sceneEditor.tempAria"]' />
                                                <SliderRow LeftIcon="dim" Min="1" Max="100" Suffix="%" @bind-Value="row.Edit.Brightness" AriaLabel='@L["sceneEditor.brightnessAria"]' />
                                            }
                                            @if (row.Edit.Effect.Type != "none")
                                            {
                                                <p class="hint" style="margin-top:0.6rem"><Icon Name="effects" /> @L.Format("sceneEditor.effectBaseHint", row.Edit.Mode == "color" ? L["sceneEditor.baseColorWord"] : L["sceneEditor.baseWhiteWord"])</p>
                                            }
                                        }
                                        else if (Palette.EffectUsesBaseBrightness(row.Edit.Effect.Type))
                                        {
                                            <SliderRow LeftIcon="dim" Min="1" Max="100" Suffix="%" @bind-Value="row.Edit.Brightness" AriaLabel='@L["sceneEditor.brightnessAria"]' />
                                        }

                                        @if (row.Edit.Effect.Type == "custom")
                                        {
                                            <KeyframeEditor Effect="row.Edit.Effect" />
                                        }
                                        else if (row.Edit.Effect.Type is not ("none" or "fx"))
                                        {
                                            <SliderRow LeftIcon="speed" Min="1" Max="10" @bind-Value="row.Edit.Effect.Speed" AriaLabel='@L["sceneEditor.speedAria"]' />
                                            <SliderRow LeftIcon="bright" Min="1" Max="10" @bind-Value="row.Edit.Effect.Intensity" AriaLabel='@L["sceneEditor.intensityAria"]' />

                                            @if (row.Edit.Effect.Type == "drift")
                                            {
                                                <p class="hint" style="margin-top:0.6rem">@L["sceneEditor.driftHint"]</p>
                                                @if (row.Edit.Effect.Colors.Count > 0)
                                                {
                                                    <div class="palette-chips">
                                                        @foreach (var c in row.Edit.Effect.Colors)
                                                        {
                                                            <span class="pal-chip">
                                                                <span class="pal-dot" style="background:@c"></span>@c.ToUpperInvariant()
                                                                <button class="pal-x" title='@L["sceneEditor.removeColor"]' aria-label='@L["sceneEditor.removeColor"]' @onclick="() => RemovePaletteColor(row, c)"><Icon Name="close" /></button>
                                                            </span>
                                                        }
                                                    </div>
                                                }
                                                <SwatchGrid Selected="@null" ShowCustom="false" OnPick="@(hex => AddPaletteColor(row, hex))" Style="margin-top:0.6rem" />
                                            }
                                        }
                                    }
                                    else if (row.Edit.Mode == "off")
                                    {
                                        <p class="hint" style="margin-top:0.8rem">@L["sceneEditor.lightOffHint"]</p>
                                    }
                                    else
                                    {
                                        <p class="hint" style="margin-top:0.8rem">@L["sceneEditor.lightSkipHint"]</p>
                                    }

                                    <div class="btn-row" style="margin-top:1rem">
                                        <button class="btn btn--small" @onclick="() => CopyToAll(row)">@L["sceneEditor.copyToAll"]</button>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        }
    </div>
    }
    else if (_tab == SceneTab.Music)
    {
    <div class="panel">
        <Segmented TValue="MusicChoice" Options="MusicOptions" Value="_music" ValueChanged="@(m => _music = m)" />

        @if (_music == MusicChoice.Play)
        {
            @* Which source this scene's music targets: Spotify (URI / playlist picker) or the local library. *@
            <div style="margin-top:1rem">
                <Segmented TValue="string" Options="MusicSourceOptions" Value="_musicSource" ValueChanged="@(s => _musicSource = s)" />
            </div>

            @if (_musicSource == "local")
            {
                @if (_localTracks is { Count: 0 } && _localPlaylists is { Count: 0 })
                {
                    <p class="hint" style="margin-top:0.8rem">@L["sceneEditor.noLocalMusicPre"]<a href="music">@L["sceneEditor.musicLink"]</a>@L["sceneEditor.noLocalMusicPost"]</p>
                }
                else
                {
                    <div class="field" style="margin-top:1rem;margin-bottom:0">
                        <label for="local-pick">@L["sceneEditor.localPickLabel"]</label>
                        <select id="local-pick" value="@(_localPlayId ?? "")"
                                @onchange="e => _localPlayId = NullIfBlank(e.Value?.ToString())">
                            <option value="">@L["sceneEditor.localKeepCurrent"]</option>
                            @if (_localPlayId is { } current && !LocalIdKnown(current))
                            {
                                @* A reference the library no longer lists — keep it visible instead of silently blanking. *@
                                <option value="@current">@current</option>
                            }
                            @if (_localTracks is { Count: > 0 })
                            {
                                <optgroup label='@L["sceneEditor.localTracksGroup"]'>
                                    @foreach (var t in _localTracks)
                                    {
                                        <option value="@t.PlayId">@t.Name</option>
                                    }
                                </optgroup>
                            }
                            @if (_localPlaylists is { Count: > 0 })
                            {
                                <optgroup label='@L["sceneEditor.localPlaylistsGroup"]'>
                                    @foreach (var p in _localPlaylists)
                                    {
                                        <option value="@p.PlayId">@p.Name</option>
                                    }
                                </optgroup>
                            }
                        </select>
                    </div>
                }
            }
            else
            {
                <div class="field" style="margin-top:1rem;margin-bottom:0">
                    <label for="music-uri">@L["sceneEditor.musicUriLabel"]</label>
                    <input id="music-uri" type="text" value="@_playId" @oninput="e => _playId = e.Value?.ToString() ?? string.Empty"
                           placeholder="spotify:playlist:… or https://open.spotify.com/…" />
                </div>

                <PlaylistPicker Playlists="_playlists" SelectedUri="_playId" OnPick="pl => _playId = pl.Uri" ListStyle="margin-top:1rem">
                    <EmptyContent>
                        <p class="hint" style="margin-top:0.8rem">@L["sceneEditor.connectSpotifyPre"]<a href="settings?tab=music">@L["sceneEditor.settingsLink"]</a>@L["sceneEditor.connectSpotifyPost"]</p>
                    </EmptyContent>
                </PlaylistPicker>
            }

            <div class="chip-row" style="margin-top:1rem">
                <Chip On="_setVolume" OnClick="() => _setVolume = !_setVolume">@L["sceneEditor.setVolume"]</Chip>
            </div>
            @if (_setVolume)
            {
                <SliderRow LeftIcon="volume" Min="0" Max="100" Suffix="%" @bind-Value="_volumePercent" AriaLabel='@L["sceneEditor.volumeAria"]' />
            }
        }
        else if (_music == MusicChoice.Pause)
        {
            <p class="hint" style="margin-top:0.8rem">@L["sceneEditor.musicPauseHint"]</p>
        }
    </div>
    }
    else if (_tab == SceneTab.Sounds)
    {
    <div class="panel">
        @if (_sounds is null || _sounds.Count == 0)
        {
            <p class="hint" style="margin:0">
                @L["sceneEditor.noSoundsPre"]<a href="sounds">@L["sceneEditor.soundsLink"]</a>@L["sceneEditor.noSoundsPost"]
            </p>
        }
        else
        {
            <p class="hint" style="margin-top:0">@L["sceneEditor.soundsHint"]</p>
            @foreach (var group in _sounds.GroupBy(s => string.IsNullOrWhiteSpace(s.Category) ? L["sceneEditor.uncategorized"] : s.Category))
            {
                <p class="section-h">@group.Key</p>
                <div class="klist">
                    @foreach (var sound in group)
                    {
                        var picked = _soundEffects.Contains(sound.Id);
                        <KRow IconName="@(picked ? "check-on" : "check-off")" Title="@sound.Name" Hint='@(sound.Loop ? L["sceneEditor.loopHint"] : null)'
                              Selected="picked" OnClick="() => ToggleSound(sound.Id)" />
                    }
                </div>
            }
        }

        @* Sound ids the scene still references but that are no longer in the library (e.g. a deleted or
           legacy sound). Otherwise invisible — surface them so they can be dropped, then Save. *@
        @{
            var knownIds = _sounds?.Select(s => s.Id).ToHashSet() ?? [];
            var unknownSoundIds = _soundEffects.Where(sid => !knownIds.Contains(sid)).ToList();
        }
        @if (unknownSoundIds.Count > 0)
        {
            <p class="section-h">@L["sceneEditor.unknownHeading"]</p>
            <div class="klist">
                @foreach (var sid in unknownSoundIds)
                {
                    <KRow IconName="warn" Title="@sid" Hint='@L["sceneEditor.removedSoundHint"]' OnClick="() => RemoveSound(sid)" />
                }
            </div>
        }
    </div>
    }

    <div class="editor-actions">
        <button class="btn btn--primary" @onclick="() => Save(test: false)" disabled="@_busy">@L["common.save"]</button>
        <button class="btn" @onclick="() => Save(test: true)" disabled="@_busy">@L["common.saveAndTest"]</button>
    </div>
}

@code {
    [Parameter] public string? SceneId { get; set; }

    private enum LightScope { None, All, PerLight }
    private enum LightMode { Color, White, Off }
    private enum MusicChoice { None, Play, Pause }
    private enum SceneTab { Scene, Lights, Music, Sounds }

    // Tab strip options (value + localized label + chrome icon), rebuilt per render like the segmented ones.
    private (SceneTab, string, string?)[] TabOptions =>
        [(SceneTab.Scene, L["sceneEditor.tab.scene"], "scenes"), (SceneTab.Lights, L["sceneEditor.tab.lights"], "lights"),
         (SceneTab.Music, L["sceneEditor.tab.music"], "music"), (SceneTab.Sounds, L["sceneEditor.tab.sounds"], "sounds")];

    // Segmented control options. Labels resolve through the localizer, so these are instance
    // properties rebuilt per render (they can't be static — L is an injected instance member).
    private (LightScope, string)[] ScopeOptions =>
        [(LightScope.None, L["common.leaveAlone"]), (LightScope.All, L["common.allLights"]), (LightScope.PerLight, L["common.perLight"])];
    private (LightMode, string)[] ModeOptions =>
        [(LightMode.Color, L["common.modeColor"]), (LightMode.White, L["common.modeWhite"]), (LightMode.Off, L["common.turnOff"])];
    private (MusicChoice, string)[] MusicOptions =>
        [(MusicChoice.None, L["common.none"]), (MusicChoice.Play, L["common.play"]), (MusicChoice.Pause, L["common.pause"])];
    private (string, string)[] MusicSourceOptions =>
        [("spotify", L["sceneEditor.musicSource.spotify"]), ("local", L["sceneEditor.musicSource.local"])];
    private (string, string)[] RowModeOptions =>
        [("skip", L["common.skip"]), ("color", L["common.modeColor"]), ("white", L["common.modeWhite"]), ("off", L["common.modeOff"])];

    // One editable per-light row: the persisted fields plus registry display metadata.
    private class LightRow
    {
        public string Key = "";
        public string Name = "";
        public string Provider = "tuya";
        public bool Known = true;
        public bool Expanded;
        public SceneLightEdit Edit = new();
    }

    private bool _loading = true;
    private bool _busy;
    private bool _isNew;
    private SceneEdit _edit = new();
    private List<string> _existingIds = [];

    // Active editor tab. In its own field so LoadFrom / an assistant refresh never resets it.
    private SceneTab _tab = SceneTab.Scene;

    // identity
    private string _emoji = "";
    private string _label = "";

    // lights
    private LightScope _scope = LightScope.None;
    private LightMode _lightMode = LightMode.Color;
    private string _color = "#ff8c2a";
    private int _brightness = 80;
    private int _temperature = 40;
    private List<RegisteredLightInfo> _registry = [];
    private List<LightRow> _perLight = [];
    private List<LightFxDto> _fxLibrary = [];

    // music
    private MusicChoice _music = MusicChoice.None;
    private string _musicSource = "spotify";   // "spotify" | "local" — which source the Play choice targets
    private string? _playId;                   // Spotify URI / link (free text)
    private string? _localPlayId;              // local:track:{id} / local:playlist:{id} (picked from the library)
    private bool _setVolume;
    private int _volumePercent = 50;
    private List<SpotifyPlaylistDto>? _playlists;
    private List<MusicTrackDto>? _localTracks;
    private List<MusicPlaylistDto>? _localPlaylists;

    // Ids of soundboard sounds this scene fires; picked from the imported library below.
    private List<string> _soundEffects = [];
    private List<SoundDto>? _sounds;

    // assistant drawer + real-time refresh
    private bool _drawerOpen;
    // Serialized snapshot of the scene as last loaded/saved. When a run finishes and the persisted
    // scene differs, the form is re-applied so the assistant's edits land live (see RefreshFromAssistantAsync).
    private string? _snapshot;
    private string AssistantDraft => L.Format("assistant.ctxDraft.scene", _edit.Id);

    protected override async Task OnInitializedAsync()
    {
        _isNew = string.IsNullOrEmpty(SceneId);

        var scenes = await Api.GetScenesAsync();
        _existingIds = scenes.Select(s => s.Id).ToList();
        _registry = await Api.GetRegisteredLightsAsync();
        _fxLibrary = await Api.GetLightFxAsync();

        if (!_isNew)
        {
            var scene = await Api.GetSceneAsync(SceneId!);
            if (scene is null)
            {
                Ui.ReportError(L.Format("sceneEditor.toast.loadFailed", SceneId));
                Nav.NavigateTo("");
                return;
            }
            LoadFrom(scene);
            _snapshot = JsonSerializer.Serialize(scene);
        }

        // Spotify playlists are optional — the free-text URI field always works when not connected.
        var (playlists, _) = await Api.GetSpotifyPlaylistsAsync();
        _playlists = playlists ?? [];

        // Local music library for the Local source pickers (empty when nothing imported yet).
        _localTracks = await Api.GetMusicLibraryTracksAsync();
        _localPlaylists = await Api.GetMusicLibraryPlaylistsAsync();

        // Sound library to pick scene sound effects from (empty/silent when none imported yet).
        _sounds = await Api.GetSoundsAsync();
        _loading = false;
    }

    // Maps a persisted scene onto the form fields. Idempotent — safe to call again on an assistant
    // refresh — so it resets the conditionally-assigned state first rather than layering onto stale values.
    private void LoadFrom(SceneDto scene)
    {
        _scope = LightScope.None;
        _lightMode = LightMode.Color;
        _perLight = [];
        _music = MusicChoice.None;
        _musicSource = "spotify";
        _playId = null;
        _localPlayId = null;
        _setVolume = false;

        _edit.Id = scene.Id;
        _edit.Image = scene.Image;
        (_emoji, _label) = SceneNaming.SplitName(scene.Name);

        // Per-light entries win over the legacy single block (matching the server).
        if (scene.Lights is { Count: > 0 } sceneLights)
        {
            _scope = LightScope.PerLight;
            BuildPerLightRows(sceneLights);
        }
        else if (scene.Light is { } light)
        {
            _scope = LightScope.All;
            if (light.Color is { } color)
            {
                _lightMode = LightMode.Color;
                _color = color;
                _brightness = light.Brightness ?? 80;
            }
            else if (light.Power == false)
            {
                _lightMode = LightMode.Off;
            }
            else
            {
                _lightMode = LightMode.White;
                _temperature = light.Temperature ?? 40;
                _brightness = light.Brightness ?? 80;
            }
        }

        if (scene.Music is { } music)
        {
            if (music.Pause)
            {
                _music = MusicChoice.Pause;
            }
            else if (music.PlayId is { } playId)
            {
                _music = MusicChoice.Play;
                // Legacy scenes have no Source — infer it from the play-id shape, like the server does.
                _musicSource = music.Source
                    ?? (playId.StartsWith("local:", StringComparison.OrdinalIgnoreCase) ? "local" : "spotify");
                if (_musicSource == "local") _localPlayId = playId;
                else _playId = playId;
                if (music.Volume is { } vol)
                {
                    _setVolume = true;
                    _volumePercent = (int)Math.Round(vol * 100);
                }
            }
        }

        _soundEffects = [.. scene.SoundEffects ?? []];
    }

    // Open the in-editor assistant drawer (no navigation) so the user chats while the form stays visible
    // and the assistant's edits to this scene land live. Gated on !_isNew, so _edit.Id is always set.
    private void AskAssistant() => _drawerOpen = true;

    // Fired when an assistant run finishes. Re-fetch the scene; if it was deleted, leave the editor; if it
    // changed since we last loaded/saved, re-apply it to the form and toast. Accepted v1 tradeoff: if the
    // user had unsaved local edits, this overwrites them — they explicitly asked the assistant to edit it.
    private async Task RefreshFromAssistantAsync()
    {
        if (_isNew || string.IsNullOrEmpty(_edit.Id)) return;

        var scene = await Api.GetSceneAsync(_edit.Id);
        if (scene is null)
        {
            Ui.ReportOk(L["assistant.toast.entityDeleted"]);
            await Vt.NavigateAsync("");
            return;
        }

        var json = JsonSerializer.Serialize(scene);
        if (json == _snapshot) return; // nothing changed — don't clobber in-progress typing

        _snapshot = json;
        LoadFrom(scene);
        Ui.ReportOk(L["assistant.toast.entityUpdated"]);
        StateHasChanged();
    }

    private void ToggleEmoji(string e) => _emoji = _emoji == e ? "" : e;

    private void OnLabelInput(ChangeEventArgs e) => _label = e.Value?.ToString() ?? "";

    private string ComposedName =>
        string.IsNullOrEmpty(_emoji) ? _label.Trim() : $"{_emoji} {_label.Trim()}";

    // On create the id follows the label; on edit it's fixed.
    private string CurrentId => _isNew ? SceneNaming.MakeUnique(SceneNaming.Slugify(_label), _existingIds) : _edit.Id;

    private async Task Save(bool test)
    {
        if (string.IsNullOrWhiteSpace(_label))
        {
            _tab = SceneTab.Scene; // surface the offending field's tab before toasting
            Ui.ReportError(L["sceneEditor.toast.nameFirst"]);
            return;
        }

        var id = CurrentId;
        if (string.IsNullOrEmpty(id))
        {
            _tab = SceneTab.Scene;
            Ui.ReportError(L["sceneEditor.toast.noId"]);
            return;
        }

        // Drift needs at least two palette colors — catch it before the server 400s.
        if (_scope == LightScope.PerLight)
        {
            var badDrift = _perLight.FirstOrDefault(r =>
                r.Edit.Mode is "color" or "white" && r.Edit.Effect.Type == "drift" && r.Edit.Effect.Colors.Count < 2);
            if (badDrift is not null)
            {
                _tab = SceneTab.Lights;
                Ui.ReportError(L.Format("sceneEditor.toast.driftColors", badDrift.Name));
                return;
            }
        }

        _edit.Id = id;
        _edit.Name = ComposedName;
        (_edit.Light, _edit.Lights) = BuildLights();
        _edit.Music = BuildMusic();
        _edit.SoundEffects = _soundEffects;

        _busy = true;
        try
        {
            var (_, error) = await Api.SaveSceneAsync(id, _edit);
            if (error is not null)
            {
                Ui.ReportError(error);
                return;
            }

            if (test)
            {
                var result = await Api.ActivateSceneAsync(id);
                if (result is null) return;
                if (result.FullySucceeded)
                {
                    Ui.ReportOk(L.Format("sceneEditor.toast.savedLive", id));
                }
                else
                {
                    Ui.ReportError(L.Format("sceneEditor.toast.savedPartial", result.ProblemSummary(k => L[k])));
                }
                // On create, keep editing the freshly-made scene rather than re-creating it.
                if (_isNew)
                    await Vt.NavigateAsync($"editor/{id}");
                // Staying on the page: refresh the snapshot so a later assistant refresh compares against
                // what we just saved (not the load-time state) and doesn't spuriously re-apply.
                else if (await Api.GetSceneAsync(id) is { } saved)
                    _snapshot = JsonSerializer.Serialize(saved);
            }
            else
            {
                Ui.ReportOk(L.Format("sceneEditor.toast.saved", id));
                await Vt.NavigateAsync("");
            }
        }
        finally
        {
            _busy = false;
        }
    }

    // Legacy single block for "All lights"; the per-light list otherwise. Per-light with only skips
    // (or an empty registry) collapses to "leave alone": no legacy block and an empty list.
    private (LightEdit? Light, List<SceneLightEdit> Lights) BuildLights() => _scope switch
    {
        LightScope.All => (_lightMode switch
        {
            LightMode.Color => new LightEdit { Power = true, Color = _color, Brightness = _brightness },
            LightMode.White => new LightEdit { Power = true, Temperature = _temperature, Brightness = _brightness },
            _ => new LightEdit { Power = false },
        }, []),
        LightScope.PerLight => (null, _perLight.Select(r => r.Edit).ToList()),
        _ => (null, []),
    };

    private void SetScope(LightScope scope)
    {
        _scope = scope;
        if (scope == LightScope.PerLight && _perLight.Count == 0 && _registry.Count > 0)
            BuildPerLightRows(null);
    }

    // Build one row per registered light (pre-filled from the scene where present), then any scene
    // entries whose light is no longer registered, flagged so the user notices.
    private void BuildPerLightRows(List<SceneLightDto>? sceneLights)
    {
        _perLight = [];
        foreach (var reg in _registry)
        {
            var entry = sceneLights?.FirstOrDefault(l => string.Equals(l.LightKey, reg.Key, StringComparison.OrdinalIgnoreCase));
            _perLight.Add(MakeRow(reg.Key, reg.Name, reg.Provider, entry, known: true));
        }
        if (sceneLights is not null)
            foreach (var l in sceneLights)
                if (!_registry.Any(r => string.Equals(r.Key, l.LightKey, StringComparison.OrdinalIgnoreCase)))
                    _perLight.Add(MakeRow(l.LightKey, l.LightKey, "?", l, known: false));
    }

    private static LightRow MakeRow(string key, string name, string provider, SceneLightDto? entry, bool known)
    {
        var edit = new SceneLightEdit { LightKey = key };
        if (entry is not null)
        {
            if (entry.Color is { } color) { edit.Mode = "color"; edit.Color = color; edit.Brightness = entry.Brightness ?? 80; }
            else if (entry.Power == false) { edit.Mode = "off"; }
            else { edit.Mode = "white"; edit.Temperature = entry.Temperature ?? 40; edit.Brightness = entry.Brightness ?? 80; }

            edit.Effect = EffectEdit.FromDto(entry.Effect);
        }
        return new LightRow { Key = key, Name = name, Provider = provider, Known = known, Edit = edit };
    }

    private void SetRowMode(LightRow row, string mode) => row.Edit.Mode = mode;

    private void SetEffect(LightRow row, string type) => row.Edit.Effect.Type = type;

    private void AddPaletteColor(LightRow row, string hex)
    {
        var colors = row.Edit.Effect.Colors;
        if (colors.Count >= 4 || colors.Any(c => c.Equals(hex, StringComparison.OrdinalIgnoreCase))) return;
        colors.Add(hex);
    }

    private void RemovePaletteColor(LightRow row, string hex) => row.Edit.Effect.Colors.Remove(hex);

    // Clone this row's settings + effect onto every other row (each keeps its own light key).
    private void CopyToAll(LightRow src)
    {
        foreach (var row in _perLight)
        {
            if (ReferenceEquals(row, src)) continue;
            row.Edit.Mode = src.Edit.Mode;
            row.Edit.Color = src.Edit.Color;
            row.Edit.Brightness = src.Edit.Brightness;
            row.Edit.Temperature = src.Edit.Temperature;
            row.Edit.Effect = src.Edit.Effect.Clone();
        }
        Ui.ReportOk(L["sceneEditor.toast.copiedAll"]);
    }

    // Collapsed one-line summary, e.g. "Flicker · #FF8C2A 80%" or "White · warm 60%" or "Skip".
    // Instance (not static): the labels are resolved through the localizer.
    private string Summary(LightRow row)
    {
        var e = row.Edit;
        var fx = e.Effect.Type == "none" ? "" : $"{L[LightFormat.EffectLabelKey(e.Effect.Type)]} · ";
        return e.Mode switch
        {
            "color" => $"{fx}{e.Color.ToUpperInvariant()} {e.Brightness}%",
            "white" => $"{fx}{L["common.modeWhite"]} · {L[LightFormat.TempWordKey(e.Temperature)]} {e.Brightness}%",
            "off" => L["common.modeOff"],
            _ => L["common.skip"],
        };
    }

    // Pause deliberately carries no Source — it pauses whatever is playing, whichever source that is.
    private MusicEdit? BuildMusic() => _music switch
    {
        MusicChoice.Pause => new MusicEdit { Pause = true },
        MusicChoice.Play => new MusicEdit
        {
            Source = _musicSource,
            PlayId = NullIfBlank(_musicSource == "local" ? _localPlayId : _playId),
            Volume = _setVolume ? _volumePercent / 100.0 : null,
        },
        _ => null,
    };

    // Whether a local play id is still in the loaded library (unknown ids stay visible in the picker).
    private bool LocalIdKnown(string playId) =>
        (_localTracks?.Any(t => string.Equals(t.PlayId, playId, StringComparison.OrdinalIgnoreCase)) ?? false)
        || (_localPlaylists?.Any(p => string.Equals(p.PlayId, playId, StringComparison.OrdinalIgnoreCase)) ?? false);

    private void ToggleSound(string id)
    {
        if (!_soundEffects.Remove(id))
            _soundEffects.Add(id);
    }

    // Drop a dangling reference (a sound id no longer in the library) from the scene. Persists on Save.
    private void RemoveSound(string id) => _soundEffects.Remove(id);

    private async Task DeleteConfirmed()
    {
        _busy = true;
        try
        {
            var (ok, error) = await Api.DeleteSceneAsync(_edit.Id);
            if (ok)
            {
                Ui.ReportOk(L.Format("sceneEditor.toast.deleted", _edit.Id));
                await Vt.NavigateAsync("");
            }
            else
            {
                Ui.ReportError(error ?? L["sceneEditor.toast.deleteFailed"]);
            }
        }
        finally
        {
            _busy = false;
        }
    }

    private static string? NullIfBlank(string? s) => string.IsNullOrWhiteSpace(s) ? null : s.Trim();
}
