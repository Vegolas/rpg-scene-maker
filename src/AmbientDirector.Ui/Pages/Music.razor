@page "/music"
@implements IDisposable
@inject ApiClient Api
@inject UiState Ui
@inject Localizer L

<PageTitle>Ambient Director — @L["music.title"]</PageTitle>

<div class="page-head"><h1>@L["music.title"]</h1></div>

@* ---------- Now Playing: the source-aware transport (drives the active source) ---------- *@
@if (MusicAvailable)
{
    <SectionHeading>@L["music.nowPlaying"]</SectionHeading>

    <div class="panel">
        <p class="now-title">@(_state?.TrackName ?? L["music.nothingPlaying"])</p>
        <p class="now-sub">
            @if (_state is { TrackName: not null })
            {
                @(_state.ArtistName ?? "—")
                @if (!string.IsNullOrEmpty(_state.ContextName))
                {
                    <span class="hint"> · @_state.ContextName</span>
                }
                @if (!string.IsNullOrEmpty(_state.DeviceName))
                {
                    <span class="hint"> · @_state.DeviceName</span>
                }
                @if (_state.Source is { } src)
                {
                    <span class="hint"> · @L[SourceLabelKey(src)]</span>
                }
            }
            else if (SpotifyAvailable)
            {
                <span>@L["music.openSpotifyHint"]</span>
            }
            else
            {
                <span>@L["music.local.pickTrackHint"]</span>
            }
        </p>

        @if (_state is { DurationSeconds: > 0 })
        {
            <div class="progress"><div style="width:@(ProgressPercent().ToString("0.#", System.Globalization.CultureInfo.InvariantCulture))%"></div></div>
        }

        <div class="transport">
            <button class="btn" @onclick="@(() => Send("music/previous"))" aria-label='@L["common.previous"]'><Icon Name="prev" /></button>
            @if (_state?.IsPlaying == true)
            {
                <button class="btn btn--primary play" @onclick="@(() => Send("music/pause"))" aria-label='@L["common.pause"]'><Icon Name="pause" /></button>
            }
            else
            {
                <button class="btn btn--primary play" @onclick="@(() => Send("music/resume"))" aria-label='@L["common.play"]'><Icon Name="play" /></button>
            }
            <button class="btn" @onclick="@(() => Send("music/next"))" aria-label='@L["common.next"]'><Icon Name="next" /></button>
        </div>

        <SliderRow LeftIcon="volume" Min="0" Max="100" Suffix="%" Value="_volumePercent"
                   ValueChanged="OnVolumeChanged" AriaLabel='@L["music.volumeAria"]' />

        <div class="chip-row">
            <Chip On="ShuffleOn" OnClick="ToggleShuffle"><Icon Name="shuffle" /> @L["music.shuffle"]</Chip>
            <Chip On="RepeatOn" OnClick="CycleRepeat"><Icon Name="@RepeatIcon()" /> @L[RepeatText()]</Chip>
        </div>
    </div>
}

@* ---------- Spotify (browser: search + playlists; setup lives on the Settings page) ---------- *@
<SectionHeading>@L["music.spotifyTitle"]</SectionHeading>
@if (!SpotifyAvailable)
{
    <p class="empty-note">@L["music.notConnected.pre"]<a href="settings">@L["music.notConnected.link"]</a>@L["music.notConnected.post"]</p>
}
else
{
    <div class="panel">
        <div class="field">
            <label for="spotify-search">@L["music.searchLabel"]</label>
            <div class="field-row">
                <input id="spotify-search" type="text" @bind="_query" @bind:event="oninput"
                       @onkeydown="OnSearchKeyDown" placeholder='@L["music.searchPlaceholder"]' />
                <button class="btn" @onclick="SearchAsync" disabled="@_searching">@L["music.searchBtn"]</button>
            </div>
        </div>
        @if (_results is { Count: > 0 })
        {
            <div class="klist">
                @foreach (var t in _results)
                {
                    var label = string.IsNullOrEmpty(t.Artist) ? t.Name : $"{t.Name} — {t.Artist}";
                    <KRow IconName="track" Title="@t.Name" Hint="@t.Artist" OnClick="() => Play(t.Uri, label)" />
                }
            </div>
        }
    </div>

    <SectionHeading>@L["music.playlists"]</SectionHeading>
    <PlaylistPicker Playlists="FilteredPlaylists" Filterable="false" OnPick="pl => Play(pl.Uri, pl.Name)">
        <EmptyContent>
            @if (Searching)
            {
                <p class="empty-note">@L.Format("music.noPlaylistMatch", Ui.SearchQuery)</p>
            }
            else
            {
                <p class="empty-note">@L["music.noPlaylists"]</p>
            }
        </EmptyContent>
    </PlaylistPicker>
}

@* ---------- Local library (bring-your-own files, played on the server's audio device) ---------- *@
<SectionHeading>@L["music.local.title"]</SectionHeading>

<div class="panel">
    @* Shared with the onboarding wizard's music step (Components/MusicImportField). *@
    <MusicImportField OnImported="OnTrackImported" />
</div>

@if (_tracks is null)
{
    <p class="empty-note">@L["music.local.loading"]</p>
}
else if (_tracks.Count == 0)
{
    <p class="empty-note">@L["music.local.empty"]</p>
}
else
{
    <div class="lib-list">
        @foreach (var t in _tracks)
        {
            var isPlaying = _state?.Source == "local" && _state?.IsPlaying == true && _state?.TrackName == t.Name;
            <div class="lib-row @(isPlaying ? "previewing" : "")">
                <button class="lib-play" @onclick="() => Play(t.PlayId, t.Name)" aria-label='@L["common.play"]'>
                    <Icon Name="play" />
                </button>
                <div class="lib-row__body">
                    <div class="lib-row__title">@t.Name</div>
                    <div class="lib-row__meta">
                        @if (!string.IsNullOrWhiteSpace(t.Artist))
                        {
                            <span>@t.Artist</span>
                            <span aria-hidden="true">·</span>
                        }
                        @if (t.DurationMs is > 0)
                        {
                            <span>@FormatDuration(t.DurationMs.Value)</span>
                        }
                    </div>
                </div>
                <div class="lib-row__actions">
                    <button class="btn" @onclick="() => ToggleEdit(t)"
                            aria-label='@L["music.local.editTrackAria"]'><Icon Name="edit" /></button>
                    <ConfirmButton Class="btn btn--danger" OnConfirmed="() => DeleteTrack(t)"><Icon Name="close" /></ConfirmButton>
                </div>
            </div>
            @if (_editTrackId == t.Id)
            {
                <div class="panel" style="margin:0.4rem 0 0.8rem">
                    <div class="field">
                        <label for="trk-name">@L["music.local.trackName"]</label>
                        <input id="trk-name" type="text" @bind="_editName" />
                    </div>
                    <div class="field">
                        <label for="trk-artist">@L["music.local.artist"]</label>
                        <input id="trk-artist" type="text" @bind="_editArtist" />
                    </div>
                    @if (_playlistsLocal is { Count: > 0 })
                    {
                        <div class="field">
                            <label for="trk-addto">@L["music.local.addToPlaylist"]</label>
                            <select id="trk-addto" value="" @onchange="e => AddToPlaylist(t, e.Value?.ToString())">
                                <option value="" disabled selected>@L["music.local.pickPlaylist"]</option>
                                @foreach (var pl in _playlistsLocal)
                                {
                                    <option value="@pl.Id">@pl.Name</option>
                                }
                            </select>
                        </div>
                    }
                    <div class="btn-row">
                        <button class="btn btn--primary" @onclick="() => SaveTrack(t)">@L["common.save"]</button>
                        <button class="btn" @onclick="() => _editTrackId = null">@L["common.cancel"]</button>
                    </div>
                </div>
            }
        }
    </div>
}

<SectionHeading>@L["music.local.playlists"]</SectionHeading>

<div class="panel">
    <div class="field" style="margin-bottom:0">
        <label for="pl-new">@L["music.local.newPlaylist"]</label>
        <div class="field-row">
            <input id="pl-new" type="text" @bind="_newPlaylistName" placeholder='@L["music.local.newPlaylistPlaceholder"]' />
            <button class="btn" @onclick="CreatePlaylist" disabled="@string.IsNullOrWhiteSpace(_newPlaylistName)">
                <Icon Name="add" /> @L["common.add"]
            </button>
        </div>
    </div>
</div>

@if (_playlistsLocal is { Count: 0 })
{
    <p class="empty-note">@L["music.local.noPlaylists"]</p>
}
else if (_playlistsLocal is not null)
{
    <div class="lib-list">
        @foreach (var pl in _playlistsLocal)
        {
            <div class="lib-row">
                <button class="lib-play" @onclick="() => Play(pl.PlayId, pl.Name)" aria-label='@L["common.play"]'>
                    <Icon Name="play" />
                </button>
                <div class="lib-row__body">
                    <div class="lib-row__title">@pl.Name</div>
                    <div class="lib-row__meta"><span>@L.Plural("music.local.trackCount", pl.TrackIds.Count)</span></div>
                </div>
                <div class="lib-row__actions">
                    <button class="btn" @onclick="() => TogglePlaylist(pl)"
                            aria-label='@L["music.local.editPlaylistAria"]'><Icon Name="edit" /></button>
                    <ConfirmButton Class="btn btn--danger" OnConfirmed="() => DeletePlaylist(pl)"><Icon Name="close" /></ConfirmButton>
                </div>
            </div>
            @if (_openPlaylistId == pl.Id)
            {
                <div class="panel" style="margin:0.4rem 0 0.8rem">
                    <div class="field">
                        <label for="pl-name">@L["music.local.playlistName"]</label>
                        <div class="field-row">
                            <input id="pl-name" type="text" @bind="_playlistName" />
                            <button class="btn btn--primary" @onclick="() => RenamePlaylist(pl)">@L["common.save"]</button>
                        </div>
                    </div>

                    @if (pl.TrackIds.Count == 0)
                    {
                        <p class="hint">@L["music.local.emptyPlaylistHint"]</p>
                    }
                    else
                    {
                        <div class="lib-list">
                            @for (var i = 0; i < pl.TrackIds.Count; i++)
                            {
                                var index = i;
                                var trackId = pl.TrackIds[index];
                                <div class="lib-row">
                                    <div class="lib-row__body">
                                        <div class="lib-row__title">@(index + 1). @TrackName(trackId)</div>
                                    </div>
                                    <div class="lib-row__actions">
                                        <button class="btn" disabled="@(index == 0)" @onclick="() => MoveTrack(pl, index, -1)"
                                                aria-label='@L["music.local.moveUpAria"]'><Icon Name="move-up" /></button>
                                        <button class="btn" disabled="@(index == pl.TrackIds.Count - 1)" @onclick="() => MoveTrack(pl, index, +1)"
                                                aria-label='@L["music.local.moveDownAria"]'><Icon Name="move-down" /></button>
                                        <button class="btn" @onclick="() => RemoveTrack(pl, index)"
                                                aria-label='@L["common.remove"]'><Icon Name="close" /></button>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        }
    </div>
}

@code {
    private MusicStateDto? _state;
    private List<SpotifyPlaylistDto>? _playlists;
    private bool _spotifyLoaded;   // Spotify playlists fetched (once, when the source shows up)
    private List<SpotifyTrackDto>? _results;
    private string _query = "";
    private bool _searching;
    private int _volumePercent = 50;
    private Timer? _timer;

    // Local library.
    private List<MusicTrackDto>? _tracks;
    private List<MusicPlaylistDto>? _playlistsLocal;
    private string? _editTrackId;
    private string _editName = "";
    private string _editArtist = "";
    private string _newPlaylistName = "";
    private string? _openPlaylistId;
    private string _playlistName = "";

    private bool MusicAvailable => _state?.Available is { Count: > 0 };
    private bool SpotifyAvailable => _state?.Available?.Contains("spotify") == true;
    private bool ShuffleOn => _state?.IsShuffling == true;
    private bool RepeatOn => _state is { Repeat: "playlist" or "track" };

    private static string SourceLabelKey(string source) =>
        source == "local" ? "music.source.local" : "music.source.spotify";

    // Playlists narrowed by the header search (null while still loading, so the picker keeps its
    // loading state). The catalog "Search tracks" box below is a separate, server-side search.
    private List<SpotifyPlaylistDto>? FilteredPlaylists
    {
        get
        {
            if (_playlists is null) return null;
            var q = Ui.SearchQuery;
            if (string.IsNullOrWhiteSpace(q)) return _playlists;
            return _playlists.Where(p => p.Name.Contains(q, StringComparison.OrdinalIgnoreCase)).ToList();
        }
    }

    private bool Searching => !string.IsNullOrWhiteSpace(Ui.SearchQuery);

    private void OnSearchChanged() => InvokeAsync(StateHasChanged);

    protected override async Task OnInitializedAsync()
    {
        Ui.SearchChanged += OnSearchChanged;
        await RefreshLibraryAsync();
        await PollAsync();
        _timer = new Timer(_ => _ = InvokeAsync(PollAsync), null, 3000, 3000);
    }

    private async Task PollAsync()
    {
        _state = await Api.GetMusicStateAsync();
        if (_state?.VolumePercent is { } vp) _volumePercent = vp;

        // Fetch the Spotify browser data once, as soon as the source is available (also covers
        // connecting in another tab mid-session).
        if (SpotifyAvailable && !_spotifyLoaded)
        {
            _spotifyLoaded = true;
            var (playlists, error) = await Api.GetSpotifyPlaylistsAsync();
            _playlists = playlists ?? [];
            if (playlists is null && error is not null) Ui.ReportError(error);
        }
        StateHasChanged();
    }

    private async Task RefreshLibraryAsync()
    {
        _tracks = await Api.GetMusicLibraryTracksAsync();
        _playlistsLocal = await Api.GetMusicLibraryPlaylistsAsync();
    }

    private double ProgressPercent() =>
        _state is { ProgressSeconds: { } p, DurationSeconds: { } d } && d > 0
            ? Math.Clamp(p / d * 100, 0, 100)
            : 0;

    private string RepeatIcon() => _state?.Repeat == "track" ? "repeat-one" : "repeat";

    private string RepeatText() => _state?.Repeat switch
    {
        "track" => "music.repeat.track",
        "playlist" => "music.repeat.list",
        _ => "music.repeat.none",
    };

    // off → playlist → track → off
    private Task CycleRepeat()
    {
        var next = _state?.Repeat switch { "off" or null => "playlist", "playlist" => "track", _ => "off" };
        return Send($"music/repeat?mode={next}");
    }

    private Task ToggleShuffle() => Send($"music/shuffle?value={(ShuffleOn ? "false" : "true")}");

    private async Task Send(string path)
    {
        if (await Api.CommandAsync(path))
            await PollAsync();
    }

    private async Task Play(string uri, string title)
    {
        if (await Api.CommandAsync($"music/play?id={Uri.EscapeDataString(uri)}", L.Format("music.toast.playing", title)))
            await PollAsync();
    }

    private async Task OnVolumeChanged(int percent)
    {
        _volumePercent = percent;
        var volume = (percent / 100.0).ToString(System.Globalization.CultureInfo.InvariantCulture);
        await Api.CommandAsync($"music/volume?value={volume}");
    }

    private async Task SearchAsync()
    {
        if (string.IsNullOrWhiteSpace(_query)) return;
        _searching = true;
        try
        {
            var (results, error) = await Api.SearchSpotifyTracksAsync(_query);
            if (results is not null) _results = results;
            else if (error is not null) Ui.ReportError(error);
        }
        finally { _searching = false; }
    }

    private async Task OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchAsync();
    }

    // ---------- local library actions ----------

    private async Task OnTrackImported(MusicTrackDto _)
    {
        await RefreshLibraryAsync();
        await PollAsync(); // "available" may have just gained local — surface the transport now
    }

    private void ToggleEdit(MusicTrackDto t)
    {
        if (_editTrackId == t.Id) { _editTrackId = null; return; }
        _editTrackId = t.Id;
        _editName = t.Name;
        _editArtist = t.Artist;
    }

    private async Task SaveTrack(MusicTrackDto t)
    {
        var (result, error) = await Api.UpdateMusicTrackAsync(t.Id, _editName.Trim(), _editArtist.Trim());
        if (result is null) { Ui.ReportError(error ?? L["music.local.toast.saveFailed"]); return; }
        _editTrackId = null;
        Ui.ReportOk(L.Format("music.local.toast.saved", result.Name));
        await RefreshLibraryAsync();
    }

    private async Task DeleteTrack(MusicTrackDto t)
    {
        var (ok, error) = await Api.DeleteMusicTrackAsync(t.Id);
        if (!ok) { Ui.ReportError(error ?? L["music.local.toast.deleteFailed"]); return; }
        if (_editTrackId == t.Id) _editTrackId = null;
        Ui.ReportOk(L.Format("music.local.toast.deleted", t.Name));
        await RefreshLibraryAsync();
        await PollAsync(); // the library may have just gone empty — hide the transport truthfully
    }

    private async Task AddToPlaylist(MusicTrackDto t, string? playlistId)
    {
        if (string.IsNullOrEmpty(playlistId) || _playlistsLocal?.FirstOrDefault(p => p.Id == playlistId) is not { } pl)
            return;
        var ids = new List<string>(pl.TrackIds) { t.Id };
        var (result, error) = await Api.SaveMusicPlaylistAsync(pl.Id, pl.Name, ids);
        if (result is null) { Ui.ReportError(error ?? L["music.local.toast.saveFailed"]); return; }
        Ui.ReportOk(L.Format("music.local.toast.addedTo", t.Name, pl.Name));
        await RefreshLibraryAsync();
    }

    // ---------- local playlist actions ----------

    private async Task CreatePlaylist()
    {
        var name = _newPlaylistName.Trim();
        if (name.Length == 0) return;
        var id = Slugify(name);
        if (id.Length == 0) id = "playlist";
        // Suffix -2, -3, … if the slug is taken (mirrors how track import ids are made unique server-side).
        if (_playlistsLocal is not null)
        {
            var baseId = id;
            for (var n = 2; _playlistsLocal.Any(p => string.Equals(p.Id, id, StringComparison.OrdinalIgnoreCase)); n++)
                id = $"{baseId}-{n}";
        }
        var (result, error) = await Api.SaveMusicPlaylistAsync(id, name, []);
        if (result is null) { Ui.ReportError(error ?? L["music.local.toast.saveFailed"]); return; }
        _newPlaylistName = "";
        Ui.ReportOk(L.Format("music.local.toast.playlistCreated", result.Name));
        await RefreshLibraryAsync();
    }

    private void TogglePlaylist(MusicPlaylistDto pl)
    {
        if (_openPlaylistId == pl.Id) { _openPlaylistId = null; return; }
        _openPlaylistId = pl.Id;
        _playlistName = pl.Name;
    }

    private async Task RenamePlaylist(MusicPlaylistDto pl)
    {
        var (result, error) = await Api.SaveMusicPlaylistAsync(pl.Id, _playlistName.Trim(), pl.TrackIds);
        if (result is null) { Ui.ReportError(error ?? L["music.local.toast.saveFailed"]); return; }
        Ui.ReportOk(L.Format("music.local.toast.saved", result.Name));
        await RefreshLibraryAsync();
    }

    private async Task DeletePlaylist(MusicPlaylistDto pl)
    {
        var (ok, error) = await Api.DeleteMusicPlaylistAsync(pl.Id);
        if (!ok) { Ui.ReportError(error ?? L["music.local.toast.deleteFailed"]); return; }
        if (_openPlaylistId == pl.Id) _openPlaylistId = null;
        Ui.ReportOk(L.Format("music.local.toast.deleted", pl.Name));
        await RefreshLibraryAsync();
    }

    private async Task MoveTrack(MusicPlaylistDto pl, int index, int delta)
    {
        var target = index + delta;
        if (target < 0 || target >= pl.TrackIds.Count) return;
        var ids = new List<string>(pl.TrackIds);
        (ids[index], ids[target]) = (ids[target], ids[index]);
        await SaveOrder(pl, ids);
    }

    private async Task RemoveTrack(MusicPlaylistDto pl, int index)
    {
        var ids = new List<string>(pl.TrackIds);
        ids.RemoveAt(index);
        await SaveOrder(pl, ids);
    }

    private async Task SaveOrder(MusicPlaylistDto pl, List<string> ids)
    {
        var (result, error) = await Api.SaveMusicPlaylistAsync(pl.Id, pl.Name, ids);
        if (result is null) { Ui.ReportError(error ?? L["music.local.toast.saveFailed"]); return; }
        await RefreshLibraryAsync();
    }

    private string TrackName(string id) =>
        _tracks?.FirstOrDefault(t => string.Equals(t.Id, id, StringComparison.OrdinalIgnoreCase))?.Name ?? id;

    private static string FormatDuration(int ms)
    {
        var ts = TimeSpan.FromMilliseconds(ms);
        return ts.TotalHours >= 1 ? ts.ToString(@"h\:mm\:ss") : ts.ToString(@"m\:ss");
    }

    private static string Slugify(string s)
    {
        var sb = new System.Text.StringBuilder();
        foreach (var ch in s.Trim().ToLowerInvariant())
        {
            if (char.IsAsciiLetterOrDigit(ch)) sb.Append(ch);
            else if (sb.Length > 0 && sb[^1] != '-') sb.Append('-');
        }
        return sb.ToString().Trim('-');
    }

    public void Dispose()
    {
        Ui.SearchChanged -= OnSearchChanged;
        _timer?.Dispose();
    }
}
