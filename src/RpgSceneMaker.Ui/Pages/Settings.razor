@page "/settings"
@inject ApiClient Api
@inject UiState Ui
@inject NavigationManager Nav

<PageTitle>Scene Maker — Settings</PageTitle>

@if (_config is null)
{
    <p class="empty-note">@(_loadError ?? "Opening the workshop…")</p>
}
else
{
    <RuneHeading>Light System</RuneHeading>
    <div class="chip-row">
        <Chip On="@(!IsHue)" OnClick="@(() => SetProvider("tuya"))">Tuya bulb</Chip>
        <Chip On="@(IsHue)" OnClick="@(() => SetProvider("hue"))">Philips Hue</Chip>
    </div>
    <p class="hint">Only the selected system's settings are shown. Scenes and the Lights tab control it.</p>

    @if (IsHue)
    {
    <RuneHeading>Philips Hue</RuneHeading>
    <div class="panel">
        <div class="field">
            <label for="bridge-ip">Bridge IP</label>
            <div class="field-row">
                <input id="bridge-ip" type="text" @bind="_config.Hue.BridgeIp" placeholder="e.g. 192.168.1.30" />
                <button class="btn" @onclick="Discover" disabled="@_busy">Find</button>
            </div>
        </div>

        @if (HueIsPaired)
        {
            <p class="status ok">✓ Paired with the bridge</p>
            <div class="btn-row">
                <button class="btn" @onclick="LoadHueLights" disabled="@_busy">Refresh lights</button>
                <button class="btn" @onclick="TestLight" disabled="@_busy">Test (toggle)</button>
                <button class="btn danger" @onclick="ForgetHue" disabled="@_busy">Forget pairing</button>
            </div>

            @if (_hueLights is not null)
            {
                <p class="hint" style="margin-top:1rem">Lights the panel and scenes control (none checked = all lights):</p>
                <div class="klist">
                    @foreach (var light in _hueLights)
                    {
                        <label class="krow check @(_config.Hue.LightIds.Contains(light.Id) ? "playing" : "")">
                            <input type="checkbox"
                                   checked="@_config.Hue.LightIds.Contains(light.Id)"
                                   @onchange="e => ToggleLight(light.Id, e)" />
                            <span class="krow-ico">@(light.Reachable ? "💡" : "⚠️")</span>
                            <span class="krow-title">@light.Name <small class="hint">@light.Type@(light.Reachable ? "" : " — unreachable")</small></span>
                        </label>
                    }
                </div>
            }
        }
        else
        {
            <p class="status">Not paired yet.</p>
            <ol class="hint steps">
                <li>Fill in the bridge IP (or tap <em>Find</em>).</li>
                <li><strong>Press the round link button</strong> on top of the Hue Bridge.</li>
                <li>Tap <em>Pair</em> below within 30 seconds.</li>
            </ol>
            <div class="btn-row">
                <button class="btn primary big" @onclick="Pair" disabled="@(_busy || string.IsNullOrWhiteSpace(_config.Hue.BridgeIp))">Pair with bridge</button>
            </div>
        }

        @if (_hueStatus is not null)
        {
            <p class="status @(_hueStatusIsError ? "err" : "ok")">@_hueStatus</p>
        }

        <div class="btn-row" style="margin-top:1rem">
            <button class="btn primary" @onclick="SaveConfig" disabled="@_busy">Save Hue settings</button>
        </div>
    </div>
    }
    else
    {
    <RuneHeading>Tuya Bulb</RuneHeading>
    <div class="panel">
        <div class="field">
            <label for="tuya-ip">Bulb IP</label>
            <div class="field-row">
                <input id="tuya-ip" type="text" @bind="_config.Tuya.Ip" placeholder="e.g. 192.168.1.41" />
                <button class="btn" @onclick="ScanTuya" disabled="@_busy">Scan</button>
            </div>
        </div>
        <div class="field">
            <label for="tuya-id">Device id</label>
            <input id="tuya-id" type="text" @bind="_config.Tuya.DeviceId" />
        </div>
        <div class="field">
            <label for="tuya-key">Local key</label>
            <input id="tuya-key" type="password" @bind="_config.Tuya.LocalKey" />
        </div>
        <div class="field-row">
            <div class="field" style="flex:1">
                <label for="tuya-proto">Protocol</label>
                <select id="tuya-proto" @bind="_config.Tuya.ProtocolVersion">
                    <option value="3.3">3.3 (default)</option>
                    <option value="3.1">3.1 (very old)</option>
                </select>
            </div>
            <div class="field" style="flex:1">
                <label for="tuya-dp">DP layout</label>
                <select id="tuya-dp" @bind="_config.Tuya.DpProfile">
                    <option value="v2">v2 — DPs 20-24</option>
                    <option value="v1">v1 — DPs 1-5 (old)</option>
                </select>
            </div>
        </div>
        @if (_tuyaStatus is not null)
        {
            <p class="status">@_tuyaStatus</p>
        }
        <div class="btn-row">
            <button class="btn primary" @onclick="SaveConfig" disabled="@_busy">Save Tuya settings</button>
        </div>
        <p class="hint">The local key still comes from the Tuya IoT portal — see the README walkthrough.</p>
    </div>
    }

    <RuneHeading>Light Registry</RuneHeading>
    <div class="panel">
        <p class="hint">Individually addressable lights that scenes and the Lights tab can target one by one.</p>

        @if (_config.Lights.Count == 0)
        {
            <p class="empty-note" style="margin:0.8rem 0">No lights registered yet — add your Hue lights or the Tuya bulb below.</p>
        }
        else
        {
            <div class="reg-list">
                @foreach (var light in _config.Lights)
                {
                    <div class="reg-row">
                        <span class="reg-badge @(light.Provider == "hue" ? "hue" : "tuya")">@LightFormat.ProviderLabel(light.Provider)</span>
                        <input class="reg-name" type="text" @bind="light.Name" placeholder="Light name" />
                        <code class="reg-key" title="Stable key used by scenes and endpoints">@light.Key</code>
                        <button class="reg-remove" aria-label="Remove light" @onclick="() => RemoveLight(light)">✕</button>
                    </div>
                }
            </div>
        }

        <div class="btn-row" style="margin-top:1rem">
            <button class="btn" @onclick="ToggleHueAdd" disabled="@(!HueIsPaired)">Add Hue lights</button>
            <button class="btn" @onclick="AddTuya" disabled="@HasTuya">Add Tuya bulb</button>
        </div>
        @if (!HueIsPaired)
        {
            <p class="hint">Pair a Hue bridge above to add Hue lights.</p>
        }
        @if (HasTuya)
        {
            <p class="hint">The Tuya bulb is already registered (only one is supported).</p>
        }

        @if (_showHueAdd && HueIsPaired)
        {
            @if (_hueLights is null)
            {
                <p class="empty-note" style="margin-top:1rem">Fetching bridge lights…</p>
            }
            else
            {
                <div class="reg-list" style="margin-top:1rem">
                    @foreach (var hl in _hueLights)
                    {
                        var added = _config.Lights.Any(l => l.Provider == "hue" && l.HueId == hl.Id);
                        <div class="reg-row">
                            <span class="krow-ico">@(hl.Reachable ? "💡" : "⚠️")</span>
                            <span class="reg-name-static">@hl.Name</span>
                            <button class="btn small" disabled="@added" @onclick="() => AddHue(hl)">@(added ? "Added" : "Add")</button>
                        </div>
                    }
                </div>
            }
        }

        <div class="btn-row" style="margin-top:1rem">
            <button class="btn primary" @onclick="SaveConfig" disabled="@_busy">Save lights</button>
        </div>
    </div>

    <RuneHeading>Default Lighting</RuneHeading>
    <div class="panel">
        <p class="hint">The state the top-bar 💡 reset button restores — e.g. bright white “house lights up” for a break.</p>

        <Segmented TValue="string" Options="DefaultModes" Value="@(DefaultMode ?? "")" ValueChanged="SetDefaultMode" />

        @if (DefaultMode == "color")
        {
            <div style="margin-top:1rem">
                <SwatchGrid Selected="_config.DefaultLight?.Color" OnPick="OnDefaultColorPicked" />
            </div>
            <SliderRow LeftIcon="🔆" Min="1" Max="100" Suffix="%" Value="@(_config.DefaultLight?.Brightness ?? 80)"
                       ValueChanged="OnDefaultBrightnessChanged" AriaLabel="Default brightness" />
        }
        else if (DefaultMode == "white")
        {
            <SliderRow LeftIcon="🕯️" RightIcon="❄️" Min="0" Max="100" Value="@(_config.DefaultLight?.Temperature ?? 50)"
                       ValueChanged="OnDefaultTemperatureChanged" AriaLabel="Default color temperature" />
            <SliderRow LeftIcon="🔆" Min="1" Max="100" Suffix="%" Value="@(_config.DefaultLight?.Brightness ?? 80)"
                       ValueChanged="OnDefaultBrightnessChanged" AriaLabel="Default brightness" />
        }
        else if (DefaultMode == "off")
        {
            <p class="hint">The reset button will switch all lights off.</p>
        }
        else
        {
            <p class="empty-note" style="margin:0.8rem 0">No default set yet — pick Colour, White or Off above.</p>
        }

        <div class="btn-row" style="margin-top:1rem">
            <button class="btn primary" @onclick="SaveConfig" disabled="@_busy">Save default</button>
            <button class="btn" @onclick="TestDefault" disabled="@(_busy || _config.DefaultLight is null)">Test</button>
        </div>
    </div>

    <RuneHeading>Spotify</RuneHeading>
    <div class="panel">
        <div class="field">
            <label for="spotify-client-id">Client ID</label>
            <input id="spotify-client-id" type="text" @bind="_spotify.ClientId" placeholder="from developer.spotify.com" />
        </div>
        <div class="btn-row">
            <button class="btn primary" @onclick="SaveSpotify" disabled="@_busy">Save Client ID</button>
        </div>

        @if (!string.IsNullOrWhiteSpace(_spotify.RedirectUri))
        {
            <div class="field" style="margin-top:1rem">
                <label for="spotify-redirect">Redirect URI</label>
                <input id="spotify-redirect" type="text" readonly value="@_spotify.RedirectUri" />
            </div>
        }
        <p class="hint">Add this exact Redirect URI to your app at developer.spotify.com — character for character, no trailing slash. Connect from a browser on this machine (<code>http://localhost:5252</code> or <code>http://127.0.0.1:5252</code> both work). Spotify Premium is required for playback.</p>

        @if (_spotify.Connected)
        {
            <p class="status ok">✓ Connected to Spotify</p>
            <div class="field" style="margin-top:1rem">
                <label for="spotify-device">Playback device (empty = whatever is active)</label>
                <div class="field-row">
                    <select id="spotify-device" @onchange="OnSpotifyDeviceChanged">
                        <option value="" selected="@string.IsNullOrEmpty(_spotify.PreferredDeviceId)">Active device (automatic)</option>
                        @if (_spotifyDevices is not null)
                        {
                            @foreach (var d in _spotifyDevices)
                            {
                                <option value="@d.Id" selected="@(d.Id == _spotify.PreferredDeviceId)">@d.Name (@d.Type)@(d.IsActive ? " — active" : "")</option>
                            }
                        }
                        @if (!string.IsNullOrEmpty(_spotify.PreferredDeviceId) &&
                             (_spotifyDevices is null || !_spotifyDevices.Any(d => d.Id == _spotify.PreferredDeviceId)))
                        {
                            <option value="@_spotify.PreferredDeviceId" selected>@_spotify.PreferredDeviceName (offline)</option>
                        }
                    </select>
                    <button class="btn" @onclick="RefreshSpotifyDevices" disabled="@_busy">Refresh</button>
                </div>
            </div>
            <div class="btn-row">
                <button class="btn danger" @onclick="DisconnectSpotify" disabled="@_busy">Disconnect Spotify</button>
            </div>
        }
        else
        {
            <p class="status">Not connected yet.</p>
            <div class="btn-row">
                <button class="btn primary big" @onclick="ConnectSpotify"
                        disabled="@(_busy || string.IsNullOrWhiteSpace(_spotify.ClientId))">Connect Spotify</button>
            </div>
        }
    </div>
    <RuneHeading>This Device</RuneHeading>
    <div class="panel">
        <div class="field">
            <label for="apikey">API key (only if the server has one configured)</label>
            <input id="apikey" type="password" @bind="_apiKeyInput" placeholder="leave empty when not used" />
        </div>
        <div class="btn-row">
            <button class="btn primary" @onclick="SaveApiKey">Save key on this device</button>
        </div>
    </div>
}

@code {
    private LightingConfigDto? _config;
    private string? _loadError;
    private List<HueLightDto>? _hueLights;
    private string? _hueStatus;
    private bool _hueStatusIsError;
    private string? _tuyaStatus;
    private string? _apiKeyInput;
    private bool _busy;
    private bool _showHueAdd;
    private SpotifyConfigDto _spotify = new();
    private List<SpotifyDeviceDto>? _spotifyDevices;

    private bool IsHue => _config?.Provider.Equals("hue", StringComparison.OrdinalIgnoreCase) == true;
    private bool HueIsPaired => !string.IsNullOrWhiteSpace(_config?.Hue.AppKey);
    private bool HasTuya => _config?.Lights.Any(l => l.Provider == "tuya") == true;

    protected override async Task OnInitializedAsync()
    {
        _apiKeyInput = await Api.GetApiKeyAsync();
        var (config, error) = await Api.GetConfigAsync();
        if (config is null)
        {
            _loadError = $"Could not load settings. {error}";
            return;
        }
        _config = config;
        if (HueIsPaired) await LoadHueLights();

        var (spotify, _) = await Api.GetSpotifyConfigAsync();
        if (spotify is not null) _spotify = spotify;
        if (_spotify.Connected) await RefreshSpotifyDevices();

        // Show the result of a just-completed connect attempt (from the OAuth callback redirect).
        switch (QueryValue("spotify"))
        {
            case "connected":
                Ui.ReportOk("Spotify connected");
                break;
            case { } s when s.StartsWith("error", StringComparison.Ordinal):
                Ui.ReportError($"Spotify connection failed: {s[(s.IndexOf(':') + 1)..]}");
                break;
        }
    }

    private async Task SaveSpotify()
    {
        if (await Api.SaveSpotifyConfigAsync(_spotify))
        {
            Ui.ReportOk("Spotify Client ID saved");
            var (spotify, _) = await Api.GetSpotifyConfigAsync();
            if (spotify is not null) _spotify = spotify;
        }
    }

    private async Task ConnectSpotify()
    {
        // Full-page navigation: the login endpoint redirects the browser to Spotify's consent screen.
        var url = await Api.GetSpotifyLoginUrlAsync();
        Nav.NavigateTo(url, forceLoad: true);
    }

    private async Task RefreshSpotifyDevices()
    {
        var (devices, error) = await Api.GetSpotifyDevicesAsync();
        if (devices is not null) _spotifyDevices = devices;
        else if (error is not null) Ui.ReportError(error);
    }

    private async Task OnSpotifyDeviceChanged(ChangeEventArgs e)
    {
        var id = e.Value?.ToString() ?? "";
        _spotify.PreferredDeviceId = id;
        _spotify.PreferredDeviceName = _spotifyDevices?.FirstOrDefault(d => d.Id == id)?.Name ?? "";
        if (await Api.SaveSpotifyConfigAsync(_spotify))
            Ui.ReportOk(id == "" ? "Using the active Spotify device" : $"Playback device set to {_spotify.PreferredDeviceName}");
    }

    private async Task DisconnectSpotify()
    {
        if (await Api.DisconnectSpotifyAsync())
        {
            _spotify.Connected = false;
            _spotify.PreferredDeviceId = "";
            _spotify.PreferredDeviceName = "";
            _spotifyDevices = null;
        }
    }

    private string? QueryValue(string key)
    {
        var query = new Uri(Nav.Uri).Query;
        if (string.IsNullOrEmpty(query)) return null;
        foreach (var pair in query.TrimStart('?').Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var idx = pair.IndexOf('=');
            var k = Uri.UnescapeDataString(idx >= 0 ? pair[..idx] : pair);
            if (k == key)
                return idx >= 0 ? Uri.UnescapeDataString(pair[(idx + 1)..]) : "";
        }
        return null;
    }

    private async Task SetProvider(string provider)
    {
        if (_config is null) return;
        _config.Provider = provider;
        if (await Api.SaveConfigAsync(_config))
            Ui.ReportOk($"Scenes now control {(provider == "hue" ? "Philips Hue" : "the Tuya bulb")}");
        if (IsHue && HueIsPaired && _hueLights is null)
            await LoadHueLights();
    }

    private async Task SaveConfig()
    {
        if (_config is null) return;
        if (await Api.SaveConfigAsync(_config))
            Ui.ReportOk("Settings saved");
    }

    private async Task Discover()
    {
        _busy = true;
        _hueStatus = "Searching for bridges…";
        _hueStatusIsError = false;
        StateHasChanged();
        try
        {
            var (bridges, error) = await Api.DiscoverBridgesAsync();
            if (bridges is { Count: > 0 })
            {
                _config!.Hue.BridgeIp = bridges[0].Ip;
                _hueStatus = bridges.Count == 1
                    ? $"Found bridge at {bridges[0].Ip}"
                    : $"Found {bridges.Count} bridges, using {bridges[0].Ip}: {string.Join(", ", bridges.Select(b => b.Ip))}";
            }
            else
            {
                _hueStatus = error ?? "No bridge found — check that it is powered and on the same network, or type the IP manually.";
                _hueStatusIsError = true;
            }
        }
        finally { _busy = false; }
    }

    private async Task Pair()
    {
        if (_config is null) return;
        _busy = true;
        _hueStatus = "Pairing…";
        _hueStatusIsError = false;
        StateHasChanged();
        try
        {
            var (registration, error) = await Api.RegisterHueAsync(_config.Hue.BridgeIp);
            if (registration is null)
            {
                _hueStatus = error ?? "Pairing failed.";
                _hueStatusIsError = true;
                return;
            }

            _config.Hue.AppKey = registration.AppKey;
            if (await Api.SaveConfigAsync(_config))
            {
                _hueStatus = "Paired and saved — pick your lights below.";
                await LoadHueLights();
            }
        }
        finally { _busy = false; }
    }

    private async Task LoadHueLights()
    {
        if (_config is null || !HueIsPaired) return;
        var (lights, error) = await Api.GetHueLightsAsync(_config.Hue.BridgeIp, _config.Hue.AppKey);
        if (lights is null)
        {
            _hueStatus = error;
            _hueStatusIsError = true;
            return;
        }
        _hueLights = lights;
    }

    private void ToggleLight(string id, ChangeEventArgs e)
    {
        if (_config is null) return;
        if (e.Value is true or "true") _config.Hue.LightIds.Add(id);
        else _config.Hue.LightIds.Remove(id);
    }

    private async Task ForgetHue()
    {
        if (_config is null) return;
        _config.Hue.AppKey = "";
        _config.Hue.LightIds.Clear();
        _hueLights = null;
        if (await Api.SaveConfigAsync(_config))
            Ui.ReportOk("Hue pairing removed");
    }

    private Task TestLight() => Api.CommandAsync("lights/toggle", "Toggled — did it blink?");

    private async Task ScanTuya()
    {
        _busy = true;
        _tuyaStatus = "Listening for Tuya broadcasts (8s)…";
        StateHasChanged();
        try
        {
            var (devices, error) = await Api.ScanTuyaAsync();
            if (devices is { Count: > 0 })
            {
                _config!.Tuya.Ip = devices[0].Ip;
                _config!.Tuya.DeviceId = devices[0].DeviceId;
                _tuyaStatus = $"Found {devices.Count} device(s); using {devices[0].Ip} ({devices[0].DeviceId}).";
            }
            else
            {
                _tuyaStatus = error ?? "Nothing found. The bulb must be powered and on the same network.";
            }
        }
        finally { _busy = false; }
    }

    private async Task SaveApiKey()
    {
        await Api.SetApiKeyAsync(_apiKeyInput);
        Ui.ReportOk("API key saved on this device");
    }

    // ---------- light registry ----------

    private async Task ToggleHueAdd()
    {
        _showHueAdd = !_showHueAdd;
        if (_showHueAdd && _hueLights is null)
            await LoadHueLights();
    }

    private void AddHue(HueLightDto hl)
    {
        if (_config is null) return;
        if (_config.Lights.Any(l => l.Provider == "hue" && l.HueId == hl.Id)) return;
        _config.Lights.Add(new RegisteredLightEdit
        {
            Provider = "hue",
            HueId = hl.Id,
            Name = hl.Name,
            Key = UniqueKey(SceneNaming.Slugify(hl.Name)),
        });
    }

    private void AddTuya()
    {
        if (_config is null || HasTuya) return;
        _config.Lights.Add(new RegisteredLightEdit
        {
            Provider = "tuya",
            HueId = null,
            Name = "Tuya bulb",
            Key = UniqueKey("tuya-bulb"),
        });
    }

    private void RemoveLight(RegisteredLightEdit light) => _config?.Lights.Remove(light);

    private string UniqueKey(string baseKey) =>
        SceneNaming.MakeUnique(baseKey, _config!.Lights.Select(l => l.Key).ToList(), "light");

    // ---------- default lighting (the header's reset button) ----------

    private static readonly IReadOnlyList<(string, string)> DefaultModes =
        [("color", "Colour"), ("white", "White"), ("off", "Off")];

    // Derive the editor mode from the stored default (null = nothing configured yet).
    private string? DefaultMode => _config?.DefaultLight switch
    {
        null => null,
        { Power: false } => "off",
        { Color: not null } => "color",
        _ => "white",
    };

    private void SetDefaultMode(string mode)
    {
        if (_config is null) return;
        var d = _config.DefaultLight;
        _config.DefaultLight = mode switch
        {
            "color" => new DefaultLightEdit { Power = true, Color = d?.Color ?? "#ff8c2a", Brightness = d?.Brightness ?? 80 },
            "white" => new DefaultLightEdit { Power = true, Brightness = d?.Brightness ?? 80, Temperature = d?.Temperature ?? 50 },
            "off" => new DefaultLightEdit { Power = false },
            _ => d,
        };
    }

    private void OnDefaultColorPicked(string hex)
    {
        if (_config?.DefaultLight is not { } d) return;
        d.Color = hex;
        d.Power = true;
    }

    private void OnDefaultBrightnessChanged(int value)
    {
        if (_config?.DefaultLight is { } d) d.Brightness = value;
    }

    private void OnDefaultTemperatureChanged(int value)
    {
        if (_config?.DefaultLight is { } d) d.Temperature = value;
    }

    private async Task TestDefault()
    {
        if (_config is null) return;
        // Persist first so the server applies exactly what's on screen, then fire the reset.
        if (await Api.SaveConfigAsync(_config))
            await Api.ResetLightsToDefaultAsync();
    }
}
