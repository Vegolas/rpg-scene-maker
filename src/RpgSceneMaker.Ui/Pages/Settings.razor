@page "/settings"
@inject ApiClient Api
@inject UiState Ui
@inject NavigationManager Nav
@inject Localizer L

<PageTitle>Scene Maker — @L["settings.title"]</PageTitle>

@if (_config is null)
{
    <p class="empty-note">@(_loadError ?? L["settings.loading"])</p>
}
else
{
    <div class="page-head"><h1>@L["settings.title"]</h1></div>

    <SectionHeading>@L["settings.language.title"]</SectionHeading>
    <div class="panel">
        <p class="hint" style="margin-top:0">@L["settings.language.hint"]</p>
        <div class="field">
            <label for="lang-select">@L["settings.language.title"]</label>
            <select id="lang-select" @onchange="OnLanguageChanged">
                @foreach (var lang in L.Available)
                {
                    <option value="@lang.Code" selected="@(lang.Code == L.CurrentCode)">@lang.Name</option>
                }
            </select>
        </div>
    </div>

    <SectionHeading>@L["settings.lightSystem.title"]</SectionHeading>
    <div class="chip-row">
        <Chip On="@(!IsHue)" OnClick="@(() => SetProvider("tuya"))">@L["settings.lightSystem.tuya"]</Chip>
        <Chip On="@(IsHue)" OnClick="@(() => SetProvider("hue"))">@L["settings.lightSystem.hue"]</Chip>
    </div>
    <p class="hint">@L["settings.lightSystem.hint"]</p>

    @if (IsHue)
    {
    <SectionHeading>@L["settings.hue.title"]</SectionHeading>
    <div class="panel">
        <div class="field">
            <label for="bridge-ip">@L["settings.hue.bridgeIp"]</label>
            <div class="field-row">
                <input id="bridge-ip" type="text" @bind="_config.Hue.BridgeIp" placeholder='@L["settings.hue.ipPlaceholder"]' />
                <button class="btn" @onclick="Discover" disabled="@_busy">@L["settings.hue.findBtn"]</button>
            </div>
        </div>

        @if (HueIsPaired)
        {
            <p class="status ok"><Icon Name="ok" /> @L["settings.hue.paired"]</p>
            <div class="btn-row">
                <button class="btn" @onclick="LoadHueLights" disabled="@_busy">@L["settings.hue.refreshLights"]</button>
                <button class="btn" @onclick="TestLight" disabled="@_busy">@L["settings.hue.testToggle"]</button>
                <button class="btn btn--danger" @onclick="ForgetHue" disabled="@_busy">@L["settings.hue.forgetPairing"]</button>
            </div>

            @if (_hueLights is not null)
            {
                <p class="hint" style="margin-top:1rem">@L["settings.hue.lightsControlHint"]</p>
                <div class="klist">
                    @foreach (var light in _hueLights)
                    {
                        <label class="krow check @(_config.Hue.LightIds.Contains(light.Id) ? "playing" : "")">
                            <input type="checkbox"
                                   checked="@_config.Hue.LightIds.Contains(light.Id)"
                                   @onchange="e => ToggleLight(light.Id, e)" />
                            <span class="krow-ico"><Icon Name="@(light.Reachable ? "lights" : "warn")" /></span>
                            <span class="krow-title">@light.Name <small class="hint">@light.Type@(light.Reachable ? "" : L["settings.hue.unreachableSuffix"])</small></span>
                        </label>
                    }
                </div>
            }
        }
        else
        {
            <p class="status">@L["settings.hue.notPaired"]</p>
            <ol class="hint steps">
                <li>@L["settings.hue.step1pre"]<em>@L["settings.hue.findBtn"]</em>@L["settings.hue.step1post"]</li>
                <li><strong>@L["settings.hue.step2strong"]</strong>@L["settings.hue.step2post"]</li>
                <li>@L["settings.hue.step3pre"]<em>@L["settings.hue.pairWord"]</em>@L["settings.hue.step3post"]</li>
            </ol>
            <div class="btn-row">
                <button class="btn btn--primary btn--big" @onclick="Pair" disabled="@(_busy || string.IsNullOrWhiteSpace(_config.Hue.BridgeIp))">@L["settings.hue.pairBtn"]</button>
            </div>
        }

        @if (_hueStatus is not null)
        {
            <p class="status @(_hueStatusIsError ? "err" : "ok")">@_hueStatus</p>
        }

        <div class="btn-row" style="margin-top:1rem">
            <button class="btn btn--primary" @onclick="SaveConfig" disabled="@_busy">@L["settings.hue.saveBtn"]</button>
        </div>
    </div>
    }
    else
    {
    <SectionHeading>@L["settings.tuya.title"]</SectionHeading>
    <div class="panel">
        <div class="field">
            <label for="tuya-ip">@L["settings.tuya.bulbIp"]</label>
            <div class="field-row">
                <input id="tuya-ip" type="text" @bind="_config.Tuya.Ip" placeholder='@L["settings.tuya.ipPlaceholder"]' />
                <button class="btn" @onclick="ScanTuya" disabled="@_busy">@L["settings.tuya.scanBtn"]</button>
            </div>
        </div>
        <div class="field">
            <label for="tuya-id">@L["settings.tuya.deviceId"]</label>
            <input id="tuya-id" type="text" @bind="_config.Tuya.DeviceId" />
        </div>
        <div class="field">
            <label for="tuya-key">@L["settings.tuya.localKey"]</label>
            <input id="tuya-key" type="password" @bind="_config.Tuya.LocalKey" />
        </div>
        <div class="field-row">
            <div class="field" style="flex:1">
                <label for="tuya-proto">@L["settings.tuya.protocol"]</label>
                <select id="tuya-proto" @bind="_config.Tuya.ProtocolVersion">
                    <option value="3.3">@L["settings.tuya.proto33"]</option>
                    <option value="3.1">@L["settings.tuya.proto31"]</option>
                </select>
            </div>
            <div class="field" style="flex:1">
                <label for="tuya-dp">@L["settings.tuya.dpLayout"]</label>
                <select id="tuya-dp" @bind="_config.Tuya.DpProfile">
                    <option value="v2">@L["settings.tuya.dpV2"]</option>
                    <option value="v1">@L["settings.tuya.dpV1"]</option>
                </select>
            </div>
        </div>
        @if (_tuyaStatus is not null)
        {
            <p class="status">@_tuyaStatus</p>
        }
        <div class="btn-row">
            <button class="btn btn--primary" @onclick="SaveConfig" disabled="@_busy">@L["settings.tuya.saveBtn"]</button>
        </div>
        <p class="hint">@L["settings.tuya.keyHint"]</p>
    </div>
    }

    <SectionHeading>@L["settings.registry.title"]</SectionHeading>
    <div class="panel">
        <p class="hint">@L["settings.registry.hint"]</p>

        @if (_config.Lights.Count == 0)
        {
            <p class="empty-note" style="margin:0.8rem 0">@L["settings.registry.empty"]</p>
        }
        else
        {
            <div class="reg-list">
                @foreach (var light in _config.Lights)
                {
                    <div class="reg-row">
                        <span class="reg-badge @(light.Provider == "hue" ? "hue" : "tuya")">@L[LightFormat.ProviderLabelKey(light.Provider)]</span>
                        <input class="reg-name" type="text" @bind="light.Name" placeholder='@L["settings.registry.namePlaceholder"]' />
                        <code class="reg-key" title='@L["settings.registry.keyTitle"]'>@light.Key</code>
                        <button class="reg-remove" aria-label='@L["settings.registry.removeAria"]' @onclick="() => RemoveLight(light)"><Icon Name="close" /></button>
                    </div>
                }
            </div>
        }

        <div class="btn-row" style="margin-top:1rem">
            <button class="btn" @onclick="ToggleHueAdd" disabled="@(!HueIsPaired)">@L["settings.registry.addHue"]</button>
            <button class="btn" @onclick="AddTuya" disabled="@HasTuya">@L["settings.registry.addTuya"]</button>
        </div>
        @if (!HueIsPaired)
        {
            <p class="hint">@L["settings.registry.pairFirst"]</p>
        }
        @if (HasTuya)
        {
            <p class="hint">@L["settings.registry.tuyaExists"]</p>
        }

        @if (_showHueAdd && HueIsPaired)
        {
            @if (_hueLights is null)
            {
                <p class="empty-note" style="margin-top:1rem">@L["settings.registry.fetching"]</p>
            }
            else
            {
                <div class="reg-list" style="margin-top:1rem">
                    @foreach (var hl in _hueLights)
                    {
                        var added = _config.Lights.Any(l => l.Provider == "hue" && l.HueId == hl.Id);
                        <div class="reg-row">
                            <span class="krow-ico"><Icon Name="@(hl.Reachable ? "lights" : "warn")" /></span>
                            <span class="reg-name-static">@hl.Name</span>
                            <button class="btn btn--small" disabled="@added" @onclick="() => AddHue(hl)">@(added ? L["common.added"] : L["common.add"])</button>
                        </div>
                    }
                </div>
            }
        }

        <div class="btn-row" style="margin-top:1rem">
            <button class="btn btn--primary" @onclick="SaveConfig" disabled="@_busy">@L["settings.registry.saveBtn"]</button>
        </div>
    </div>

    <SectionHeading>@L["settings.default.title"]</SectionHeading>
    <div class="panel">
        <p class="hint">@L["settings.default.hint"]</p>

        <Segmented TValue="string" Options="DefaultModes" Value="@(DefaultMode ?? "")" ValueChanged="SetDefaultMode" />

        @if (DefaultMode == "color")
        {
            <div style="margin-top:1rem">
                <SwatchGrid Selected="_config.DefaultLight?.Color" OnPick="OnDefaultColorPicked" />
            </div>
            <SliderRow LeftIcon="dim" Min="1" Max="100" Suffix="%" Value="@(_config.DefaultLight?.Brightness ?? 80)"
                       ValueChanged="OnDefaultBrightnessChanged" AriaLabel='@L["settings.default.brightnessAria"]' />
        }
        else if (DefaultMode == "white")
        {
            <SliderRow LeftIcon="warm" RightIcon="cold" Min="0" Max="100" Value="@(_config.DefaultLight?.Temperature ?? 50)"
                       ValueChanged="OnDefaultTemperatureChanged" AriaLabel='@L["settings.default.tempAria"]' />
            <SliderRow LeftIcon="dim" Min="1" Max="100" Suffix="%" Value="@(_config.DefaultLight?.Brightness ?? 80)"
                       ValueChanged="OnDefaultBrightnessChanged" AriaLabel='@L["settings.default.brightnessAria"]' />
        }
        else if (DefaultMode == "off")
        {
            <p class="hint">@L["settings.default.offHint"]</p>
        }
        else
        {
            <p class="empty-note" style="margin:0.8rem 0">@L["settings.default.empty"]</p>
        }

        <div class="btn-row" style="margin-top:1rem">
            <button class="btn btn--primary" @onclick="SaveConfig" disabled="@_busy">@L["settings.default.saveBtn"]</button>
            <button class="btn" @onclick="TestDefault" disabled="@(_busy || _config.DefaultLight is null)">@L["common.test"]</button>
        </div>
    </div>

    <SectionHeading>@L["settings.spotify.title"]</SectionHeading>
    <div class="panel">
        <div class="field">
            <label for="spotify-client-id">@L["settings.spotify.clientId"]</label>
            <input id="spotify-client-id" type="text" @bind="_spotify.ClientId" placeholder='@L["settings.spotify.clientIdPlaceholder"]' />
        </div>
        <div class="btn-row">
            <button class="btn btn--primary" @onclick="SaveSpotify" disabled="@_busy">@L["settings.spotify.saveClientId"]</button>
        </div>

        @if (!string.IsNullOrWhiteSpace(_spotify.RedirectUri))
        {
            <div class="field" style="margin-top:1rem">
                <label for="spotify-redirect">@L["settings.spotify.redirectUri"]</label>
                <input id="spotify-redirect" type="text" readonly value="@_spotify.RedirectUri" />
            </div>
        }
        <p class="hint">@L["settings.spotify.redirectHintA"]<code>http://localhost:5252</code>@L["settings.spotify.redirectHintB"]<code>http://127.0.0.1:5252</code>@L["settings.spotify.redirectHintC"]</p>

        @if (_spotify.Connected)
        {
            <p class="status ok"><Icon Name="ok" /> @L["settings.spotify.connected"]</p>
            <div class="field" style="margin-top:1rem">
                <label for="spotify-device">@L["settings.spotify.deviceLabel"]</label>
                <div class="field-row">
                    <select id="spotify-device" @onchange="OnSpotifyDeviceChanged">
                        <option value="" selected="@string.IsNullOrEmpty(_spotify.PreferredDeviceId)">@L["settings.spotify.deviceAuto"]</option>
                        @if (_spotifyDevices is not null)
                        {
                            @foreach (var d in _spotifyDevices)
                            {
                                <option value="@d.Id" selected="@(d.Id == _spotify.PreferredDeviceId)">@d.Name (@d.Type)@(d.IsActive ? L["settings.spotify.activeSuffix"] : "")</option>
                            }
                        }
                        @if (!string.IsNullOrEmpty(_spotify.PreferredDeviceId) &&
                             (_spotifyDevices is null || !_spotifyDevices.Any(d => d.Id == _spotify.PreferredDeviceId)))
                        {
                            <option value="@_spotify.PreferredDeviceId" selected>@_spotify.PreferredDeviceName @L["settings.spotify.offline"]</option>
                        }
                    </select>
                    <button class="btn" @onclick="RefreshSpotifyDevices" disabled="@_busy">@L["common.refresh"]</button>
                </div>
            </div>
            <div class="btn-row">
                <button class="btn btn--danger" @onclick="DisconnectSpotify" disabled="@_busy">@L["settings.spotify.disconnectBtn"]</button>
            </div>
        }
        else
        {
            <p class="status">@L["settings.spotify.notConnected"]</p>
            <div class="btn-row">
                <button class="btn btn--primary btn--big" @onclick="ConnectSpotify"
                        disabled="@(_busy || string.IsNullOrWhiteSpace(_spotify.ClientId))">@L["settings.spotify.connectBtn"]</button>
            </div>
        }
    </div>
    <SectionHeading>@L["settings.assistant.title"]</SectionHeading>
    <div class="panel">
        <div class="field">
            <label for="assistant-provider">@L["settings.assistant.provider"]</label>
            <select id="assistant-provider" @bind="_assistant.Provider">
                <option value="anthropic">Anthropic (Claude)</option>
                <option value="openai">OpenAI (GPT)</option>
                <option value="gemini">Google Gemini</option>
            </select>
            <p class="hint">@L["settings.assistant.providerHint"]</p>
        </div>
        <div class="field">
            <label for="assistant-key">@L["settings.assistant.apiKey"]</label>
            <input id="assistant-key" type="password" @bind="_assistant.ApiKey" placeholder="@ProviderKeyPlaceholder" />
            <p class="hint">@L["settings.assistant.keyHint"]</p>
        </div>
        <div class="field">
            <label for="assistant-model">@L["settings.assistant.model"]</label>
            <input id="assistant-model" type="text" @bind="_assistant.Model" placeholder="@ProviderModelPlaceholder" />
            <p class="hint">@L[ProviderModelHint]</p>
        </div>
        <div class="btn-row">
            <button class="btn btn--primary" @onclick="SaveAssistant" disabled="@_busy">@L["settings.assistant.saveBtn"]</button>
        </div>

        @if (_assistant.Configured)
        {
            <p class="status ok">✓ @L["settings.assistant.configured"]</p>
            <div class="btn-row">
                <button class="btn btn--danger" @onclick="DisconnectAssistant" disabled="@_busy">@L["common.disconnect"]</button>
            </div>
        }
        else
        {
            <p class="status">@L["settings.assistant.noKey"]</p>
        }

        <div class="field" style="margin-top:1rem">
            <label for="mcp-endpoint">@L["settings.assistant.mcpEndpoint"]</label>
            <input id="mcp-endpoint" type="text" readonly value="@McpEndpoint" />
            <p class="hint">@L["settings.assistant.mcpHintA"]<code>X-Api-Key</code>@L["settings.assistant.mcpHintB"]</p>
        </div>
    </div>

    <SectionHeading>@L["settings.menu.title"]</SectionHeading>
    <div class="panel">
        <p class="hint" style="margin-top:0">@L["settings.menu.hint"]</p>
        <div class="btn-row" style="margin-top:0.6rem">
            <button class="btn" @onclick="ResetMenuOrder" disabled="@(Ui.TabOrder.Count == 0)">@L["settings.menu.resetBtn"]</button>
        </div>
    </div>

    <SectionHeading>@L["settings.device.title"]</SectionHeading>
    <div class="panel">
        <div class="field">
            <label for="apikey">@L["settings.device.apiKeyLabel"]</label>
            <input id="apikey" type="password" @bind="_apiKeyInput" placeholder='@L["settings.device.apiKeyPlaceholder"]' />
        </div>
        <div class="btn-row">
            <button class="btn btn--primary" @onclick="SaveApiKey">@L["settings.device.saveBtn"]</button>
        </div>
    </div>

    <SectionHeading>@L["settings.developer.title"]</SectionHeading>
    <div class="panel">
        <div class="chip-row" style="margin-top:0">
            <Chip On="@Ui.DevMode" OnClick="ToggleDevMode">@L["settings.developer.mode"]</Chip>
        </div>
        <p class="hint">@L["settings.developer.hint"]</p>
    </div>
}

@code {
    private LightingConfigDto? _config;
    private string? _loadError;
    private List<HueLightDto>? _hueLights;
    private string? _hueStatus;
    private bool _hueStatusIsError;
    private string? _tuyaStatus;
    private string? _apiKeyInput;
    private bool _busy;
    private bool _showHueAdd;
    private SpotifyConfigDto _spotify = new();
    private List<SpotifyDeviceDto>? _spotifyDevices;
    private AssistantConfigDto _assistant = new();

    // The MCP server is hosted at /mcp on the panel's own origin.
    private string McpEndpoint => $"{Nav.BaseUri}mcp";

    // Provider-specific hints for the AI Assistant key/model fields.
    private string ProviderKeyPlaceholder => _assistant.Provider switch
    {
        "openai" => "sk-…",
        "gemini" => "AIza…",
        _ => "sk-ant-…",
    };

    private string ProviderModelPlaceholder => _assistant.Provider switch
    {
        "openai" => "gpt-4o",
        "gemini" => "gemini-2.0-flash",
        _ => "claude-opus-4-8",
    };

    private string ProviderModelHint => _assistant.Provider switch
    {
        "openai" => "settings.assistant.modelHint.openai",
        "gemini" => "settings.assistant.modelHint.gemini",
        _ => "settings.assistant.modelHint.anthropic",
    };

    private async Task OnLanguageChanged(ChangeEventArgs e)
    {
        var code = e.Value?.ToString();
        if (string.IsNullOrEmpty(code)) return;
        await L.SetLanguageAsync(code);
        var name = L.Available.FirstOrDefault(x => x.Code == code)?.Name ?? code;
        Ui.ReportOk(L.Format("settings.toast.languageChanged", name));
    }

    private bool IsHue => _config?.Provider.Equals("hue", StringComparison.OrdinalIgnoreCase) == true;
    private bool HueIsPaired => !string.IsNullOrWhiteSpace(_config?.Hue.AppKey);
    private bool HasTuya => _config?.Lights.Any(l => l.Provider == "tuya") == true;

    protected override async Task OnInitializedAsync()
    {
        _apiKeyInput = await Api.GetApiKeyAsync();
        var (config, error) = await Api.GetConfigAsync();
        if (config is null)
        {
            _loadError = L.Format("settings.loadError", error);
            return;
        }
        _config = config;
        if (HueIsPaired) await LoadHueLights();

        var (spotify, _) = await Api.GetSpotifyConfigAsync();
        if (spotify is not null) _spotify = spotify;
        if (_spotify.Connected) await RefreshSpotifyDevices();

        var (assistant, _) = await Api.GetAssistantConfigAsync();
        if (assistant is not null) _assistant = assistant;

        // Show the result of a just-completed connect attempt (from the OAuth callback redirect).
        switch (QueryValue("spotify"))
        {
            case "connected":
                Ui.ReportOk(L["settings.toast.spotifyConnected"]);
                break;
            case { } s when s.StartsWith("error", StringComparison.Ordinal):
                Ui.ReportError(L.Format("settings.toast.spotifyFailed", s[(s.IndexOf(':') + 1)..]));
                break;
        }
    }

    private async Task SaveSpotify()
    {
        if (await Api.SaveSpotifyConfigAsync(_spotify))
        {
            Ui.ReportOk(L["settings.toast.clientIdSaved"]);
            var (spotify, _) = await Api.GetSpotifyConfigAsync();
            if (spotify is not null) _spotify = spotify;
        }
    }

    private async Task SaveAssistant()
    {
        _busy = true;
        try
        {
            if (await Api.SaveAssistantConfigAsync(_assistant))
            {
                _assistant.ApiKey = ""; // the key is never echoed; blank the field after saving
                var (assistant, _) = await Api.GetAssistantConfigAsync();
                if (assistant is not null) _assistant = assistant;
                Ui.ReportOk(L["settings.toast.assistantSaved"]);
                Ui.SetAssistantConfigured(_assistant.Configured); // toggle the Assistant nav tab live
            }
        }
        finally { _busy = false; }
    }

    private async Task DisconnectAssistant()
    {
        if (await Api.DisconnectAssistantAsync(L["settings.toast.assistantDisconnected"]))
        {
            var (assistant, _) = await Api.GetAssistantConfigAsync();
            if (assistant is not null) _assistant = assistant;
            Ui.SetAssistantConfigured(_assistant.Configured); // toggle the Assistant nav tab live
        }
    }

    private async Task ConnectSpotify()
    {
        // Full-page navigation: the login endpoint redirects the browser to Spotify's consent screen.
        var url = await Api.GetSpotifyLoginUrlAsync();
        Nav.NavigateTo(url, forceLoad: true);
    }

    private async Task RefreshSpotifyDevices()
    {
        var (devices, error) = await Api.GetSpotifyDevicesAsync();
        if (devices is not null) _spotifyDevices = devices;
        else if (error is not null) Ui.ReportError(error);
    }

    private async Task OnSpotifyDeviceChanged(ChangeEventArgs e)
    {
        var id = e.Value?.ToString() ?? "";
        _spotify.PreferredDeviceId = id;
        _spotify.PreferredDeviceName = _spotifyDevices?.FirstOrDefault(d => d.Id == id)?.Name ?? "";
        if (await Api.SaveSpotifyConfigAsync(_spotify))
            Ui.ReportOk(id == "" ? L["settings.toast.deviceAuto"] : L.Format("settings.toast.deviceSet", _spotify.PreferredDeviceName));
    }

    private async Task DisconnectSpotify()
    {
        if (await Api.DisconnectSpotifyAsync(L["settings.toast.spotifyDisconnected"]))
        {
            _spotify.Connected = false;
            _spotify.PreferredDeviceId = "";
            _spotify.PreferredDeviceName = "";
            _spotifyDevices = null;
        }
    }

    private string? QueryValue(string key)
    {
        var query = new Uri(Nav.Uri).Query;
        if (string.IsNullOrEmpty(query)) return null;
        foreach (var pair in query.TrimStart('?').Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var idx = pair.IndexOf('=');
            var k = Uri.UnescapeDataString(idx >= 0 ? pair[..idx] : pair);
            if (k == key)
                return idx >= 0 ? Uri.UnescapeDataString(pair[(idx + 1)..]) : "";
        }
        return null;
    }

    private async Task SetProvider(string provider)
    {
        if (_config is null) return;
        _config.Provider = provider;
        if (await Api.SaveConfigAsync(_config))
            Ui.ReportOk(L.Format("settings.toast.providerSet", provider == "hue" ? L["settings.provider.hue"] : L["settings.provider.tuya"]));
        if (IsHue && HueIsPaired && _hueLights is null)
            await LoadHueLights();
    }

    private async Task SaveConfig()
    {
        if (_config is null) return;
        if (await Api.SaveConfigAsync(_config))
            Ui.ReportOk(L["settings.toast.saved"]);
    }

    private async Task Discover()
    {
        _busy = true;
        _hueStatus = L["settings.hue.searching"];
        _hueStatusIsError = false;
        StateHasChanged();
        try
        {
            var (bridges, error) = await Api.DiscoverBridgesAsync();
            if (bridges is { Count: > 0 })
            {
                _config!.Hue.BridgeIp = bridges[0].Ip;
                _hueStatus = bridges.Count == 1
                    ? L.Format("settings.hue.foundOne", bridges[0].Ip)
                    : L.Plural("settings.hue.foundMany", bridges.Count, bridges[0].Ip, string.Join(", ", bridges.Select(b => b.Ip)));
            }
            else
            {
                _hueStatus = error ?? L["settings.hue.noBridge"];
                _hueStatusIsError = true;
            }
        }
        finally { _busy = false; }
    }

    private async Task Pair()
    {
        if (_config is null) return;
        _busy = true;
        _hueStatus = L["settings.hue.pairing"];
        _hueStatusIsError = false;
        StateHasChanged();
        try
        {
            var (registration, error) = await Api.RegisterHueAsync(_config.Hue.BridgeIp);
            if (registration is null)
            {
                _hueStatus = error ?? L["settings.hue.pairFailed"];
                _hueStatusIsError = true;
                return;
            }

            _config.Hue.AppKey = registration.AppKey;
            if (await Api.SaveConfigAsync(_config))
            {
                _hueStatus = L["settings.hue.pairedSaved"];
                await LoadHueLights();
            }
        }
        finally { _busy = false; }
    }

    private async Task LoadHueLights()
    {
        if (_config is null || !HueIsPaired) return;
        var (lights, error) = await Api.GetHueLightsAsync(_config.Hue.BridgeIp, _config.Hue.AppKey);
        if (lights is null)
        {
            _hueStatus = error;
            _hueStatusIsError = true;
            return;
        }
        _hueLights = lights;
    }

    private void ToggleLight(string id, ChangeEventArgs e)
    {
        if (_config is null) return;
        if (e.Value is true or "true") _config.Hue.LightIds.Add(id);
        else _config.Hue.LightIds.Remove(id);
    }

    private async Task ForgetHue()
    {
        if (_config is null) return;
        _config.Hue.AppKey = "";
        _config.Hue.LightIds.Clear();
        _hueLights = null;
        if (await Api.SaveConfigAsync(_config))
            Ui.ReportOk(L["settings.toast.huePairingRemoved"]);
    }

    private Task TestLight() => Api.CommandAsync("lights/toggle", L["settings.toast.toggled"]);

    private async Task ScanTuya()
    {
        _busy = true;
        _tuyaStatus = L["settings.tuya.listening"];
        StateHasChanged();
        try
        {
            var (devices, error) = await Api.ScanTuyaAsync();
            if (devices is { Count: > 0 })
            {
                _config!.Tuya.Ip = devices[0].Ip;
                _config!.Tuya.DeviceId = devices[0].DeviceId;
                _tuyaStatus = L.Plural("settings.tuya.found", devices.Count, devices[0].Ip, devices[0].DeviceId);
            }
            else
            {
                _tuyaStatus = error ?? L["settings.tuya.nothingFound"];
            }
        }
        finally { _busy = false; }
    }

    private async Task SaveApiKey()
    {
        await Api.SetApiKeyAsync(_apiKeyInput);
        Ui.ReportOk(L["settings.toast.apiKeySaved"]);
    }

    private async Task ResetMenuOrder()
    {
        await Api.ClearTabOrderAsync();
        Ui.ReportOk(L["settings.toast.menuReset"]);
    }

    private async Task ToggleDevMode()
    {
        var on = !Ui.DevMode;
        await Api.SetDevModeAsync(on);
        Ui.ReportOk(on ? L["settings.toast.devModeOn"] : L["settings.toast.devModeOff"]);
    }

    // ---------- light registry ----------

    private async Task ToggleHueAdd()
    {
        _showHueAdd = !_showHueAdd;
        if (_showHueAdd && _hueLights is null)
            await LoadHueLights();
    }

    private void AddHue(HueLightDto hl)
    {
        if (_config is null) return;
        if (_config.Lights.Any(l => l.Provider == "hue" && l.HueId == hl.Id)) return;
        _config.Lights.Add(new RegisteredLightEdit
        {
            Provider = "hue",
            HueId = hl.Id,
            Name = hl.Name,
            Key = UniqueKey(SceneNaming.Slugify(hl.Name)),
        });
    }

    private void AddTuya()
    {
        if (_config is null || HasTuya) return;
        _config.Lights.Add(new RegisteredLightEdit
        {
            Provider = "tuya",
            HueId = null,
            Name = "Tuya bulb",
            Key = UniqueKey("tuya-bulb"),
        });
    }

    private void RemoveLight(RegisteredLightEdit light) => _config?.Lights.Remove(light);

    private string UniqueKey(string baseKey) =>
        SceneNaming.MakeUnique(baseKey, _config!.Lights.Select(l => l.Key).ToList(), "light");

    // ---------- default lighting (the header's reset button) ----------

    private IReadOnlyList<(string, string)> DefaultModes =>
        [("color", L["common.modeColor"]), ("white", L["common.modeWhite"]), ("off", L["common.modeOff"])];

    // Derive the editor mode from the stored default (null = nothing configured yet).
    private string? DefaultMode => _config?.DefaultLight switch
    {
        null => null,
        { Power: false } => "off",
        { Color: not null } => "color",
        _ => "white",
    };

    private void SetDefaultMode(string mode)
    {
        if (_config is null) return;
        var d = _config.DefaultLight;
        _config.DefaultLight = mode switch
        {
            "color" => new DefaultLightEdit { Power = true, Color = d?.Color ?? "#ff8c2a", Brightness = d?.Brightness ?? 80 },
            "white" => new DefaultLightEdit { Power = true, Brightness = d?.Brightness ?? 80, Temperature = d?.Temperature ?? 50 },
            "off" => new DefaultLightEdit { Power = false },
            _ => d,
        };
    }

    private void OnDefaultColorPicked(string hex)
    {
        if (_config?.DefaultLight is not { } d) return;
        d.Color = hex;
        d.Power = true;
    }

    private void OnDefaultBrightnessChanged(int value)
    {
        if (_config?.DefaultLight is { } d) d.Brightness = value;
    }

    private void OnDefaultTemperatureChanged(int value)
    {
        if (_config?.DefaultLight is { } d) d.Temperature = value;
    }

    private async Task TestDefault()
    {
        if (_config is null) return;
        // Persist first so the server applies exactly what's on screen, then fire the reset.
        if (await Api.SaveConfigAsync(_config))
            await Api.ResetLightsToDefaultAsync(L["toast.lightsReset"]);
    }
}
