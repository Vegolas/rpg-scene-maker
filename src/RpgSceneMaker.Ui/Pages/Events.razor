@page "/events"
@implements IDisposable
@inject ApiClient Api
@inject UiState Ui

<PageTitle>Scene Maker — Events</PageTitle>

<RuneHeading>Events</RuneHeading>

@if (_edit is not null)
{
    <div class="panel">
        <div class="emoji-row">
            @foreach (var e in Palette.Emojis)
            {
                <button class="emoji-pick @(e == _emoji ? "picked" : "")" @onclick="() => ToggleEmoji(e)">@e</button>
            }
        </div>
        <div class="field" style="margin-top:1rem;margin-bottom:0">
            <label for="evt-label">Name</label>
            <input id="evt-label" type="text" value="@_label" @oninput="e => _label = e.Value?.ToString() ?? string.Empty"
                   placeholder="e.g. Thunder" />
        </div>
        <p class="hint" style="margin-top:0.6rem">
            @if (_isNew)
            {
                <span>Stream Deck URL: <code>/events/@(CurrentId is { Length: > 0 } cid ? cid : "…")/trigger</code></span>
            }
            else
            {
                <span>Id: <code>@_edit.Id</code> (fixed) — <code>/events/@_edit.Id/trigger</code></span>
            }
        </p>
        <ArtField @bind-Image="_edit.Image" />
    </div>

    <RuneHeading>Timeline</RuneHeading>
    <div class="panel">
        <p class="hint" style="margin-top:0">
            Lay sound and light clips along the time axis. Drag a clip to move it, drag its right edge to resize,
            tap it to edit below. Lights flash then restore the live scene; sounds overlay whatever's playing.
        </p>
        <TimelineEditor Model="_edit.Timeline" Sounds="_sounds" Lights="_lights" />
    </div>

    <RuneHeading>Save</RuneHeading>
    <div class="btn-row">
        <button class="btn primary" @onclick="() => Save(test: false)" disabled="@_busy">Save</button>
        <button class="btn" @onclick="() => Save(test: true)" disabled="@_busy">Save &amp; Test</button>
        @if (!_isNew && _runningId == _edit.Id)
        {
            <button class="btn danger" @onclick="Stop" disabled="@_busy">⏹ Stop</button>
        }
        <button class="btn" @onclick="CancelEdit" disabled="@_busy">Cancel</button>
    </div>
    @if (!_isNew)
    {
        <div class="btn-row" style="margin-top:0.7rem">
            <button class="btn danger" @onclick="DeleteTapped" disabled="@_busy">
                @(_confirmDelete ? "Really delete?" : "Delete event")
            </button>
        </div>
    }
}

@if (_events is null)
{
    <p class="empty-note">Gathering the omens…</p>
}
else
{
    @if (_edit is null && _events.Count == 0)
    {
        <p class="empty-note">No events yet — conjure a thunderclap or a horn blast below.</p>
    }
    <div class="scene-grid">
        @foreach (var (evt, index) in _events.Select((e, i) => (e, i)))
        {
            var (emoji, label) = SceneNaming.SplitName(evt.Name, "⚡", evt.Id);
            var artUrl = Api.ImageUrl(evt.Image);
            var hasArt = artUrl is not null;
            var running = _runningId == evt.Id;
            <button class="scene-card @(_busyId == evt.Id ? "busy" : "") @(running ? "playing" : "") @(hasArt ? "art" : "")"
                    style="animation-delay:@(index * 55)ms; --sc:@(SwatchColor(evt));@(hasArt ? $" --art:url('{artUrl}');" : "")"
                    @onclick="() => Trigger(evt.Id)">
                @if (hasArt)
                {
                    <span class="scene-art"></span>
                }
                <span class="scene-swatch"></span>
                <span class="card-edit" role="button" tabindex="0" aria-label="Edit event"
                      @onclick="() => Edit(evt)" @onclick:stopPropagation="true">✎</span>
                @if (running)
                {
                    <span class="card-stop" role="button" tabindex="0" aria-label="Stop event"
                          @onclick="Stop" @onclick:stopPropagation="true">⏹</span>
                }
                <span class="scene-emoji">@emoji</span>
                <span class="scene-name">@label</span>
            </button>
        }
        <button class="scene-card ghost" @onclick="NewEvent">
            <span class="scene-emoji">＋</span>
            <span class="scene-name">New event</span>
        </button>
    </div>
    @if (_events.Count > 0)
    {
        <p class="hint" style="margin-top:1rem">Tap to fire. ✎ to edit the timeline. ⏹ appears while an event is playing.</p>
    }
}

@code {
    private List<EventDto>? _events;
    private List<SoundDto> _sounds = [];
    private List<RegisteredLightInfo> _lights = [];
    private string? _busyId;
    private string? _runningId;
    private Timer? _timer;

    // Editor state (inline, one at a time). _edit non-null = editor open.
    private EventEdit? _edit;
    private bool _isNew;
    private bool _busy;
    private bool _confirmDelete;
    private string _emoji = "";
    private string _label = "";

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
        await PollAsync();
        _timer = new Timer(_ => _ = InvokeAsync(PollAsync), null, 1500, 1500);
    }

    private async Task RefreshAsync()
    {
        await Api.GetApiKeyAsync(); // cache the key so tile-art urls carry it
        var eventsTask = Api.GetEventsAsync();
        var soundsTask = Api.GetSoundsAsync();
        var lightsTask = Api.GetRegisteredLightsAsync();
        await Task.WhenAll(eventsTask, soundsTask, lightsTask);
        _events = await eventsTask;
        _sounds = await soundsTask;
        _lights = await lightsTask;
        StateHasChanged();
    }

    private async Task PollAsync()
    {
        var running = await Api.GetRunningEventIdAsync();
        if (running != _runningId)
        {
            _runningId = running;
            StateHasChanged();
        }
    }

    // Card tint: the first light clip's colour (or the legacy flash colour), like a scene's swatch.
    private static string SwatchColor(EventDto evt)
    {
        var color = evt.Timeline?.Lights?.FirstOrDefault(l => l.Color is not null)?.Color;
        return color ?? evt.Flash?.Color ?? "transparent";
    }

    private async Task Trigger(string id)
    {
        _busyId = id;
        StateHasChanged();
        try
        {
            var result = await Api.TriggerEventAsync(id);
            if (result is null) return;
            if (result.FullySucceeded)
                Ui.ReportOk($"Event \"{id}\" fired");
            else
                Ui.ReportError($"Partially fired. {result.ProblemSummary()}");
            await PollAsync();
        }
        finally
        {
            _busyId = null;
            StateHasChanged();
        }
    }

    private async Task Stop()
    {
        if (await Api.StopEventAsync())
        {
            _runningId = null;
            StateHasChanged();
        }
    }

    private void NewEvent()
    {
        _isNew = true;
        _emoji = "";
        _label = "";
        _edit = new EventEdit();
        _confirmDelete = false;
    }

    private void Edit(EventDto evt)
    {
        _isNew = false;
        (_emoji, _label) = SceneNaming.SplitName(evt.Name);
        _edit = EventEdit.FromDto(evt, _sounds);
        _confirmDelete = false;
    }

    private void CancelEdit()
    {
        _edit = null;
        _confirmDelete = false;
    }

    private void ToggleEmoji(string e) => _emoji = _emoji == e ? "" : e;

    private string ComposedName =>
        string.IsNullOrEmpty(_emoji) ? _label.Trim() : $"{_emoji} {_label.Trim()}";

    // On create the id follows the label; on edit it's fixed.
    private string CurrentId => _isNew
        ? SceneNaming.MakeUnique(SceneNaming.Slugify(_label), _events?.Select(e => e.Id).ToList() ?? [])
        : _edit!.Id;

    private async Task Save(bool test)
    {
        if (_edit is null) return;
        if (string.IsNullOrWhiteSpace(_label))
        {
            Ui.ReportError("Give the event a name first.");
            return;
        }
        if (_edit.Timeline.IsEmpty)
        {
            Ui.ReportError("An event needs at least one sound or light clip.");
            return;
        }
        if (_edit.Timeline.EndMs > TimelineEdit.MaxEndMs)
        {
            Ui.ReportError("The timeline must end within 10 minutes.");
            return;
        }
        // Drift needs at least two palette colours — catch it before the server 400s.
        var badDrift = _edit.Timeline.Lights.FirstOrDefault(l =>
            l.Mode is "color" or "white" && l.Effect.Type == "drift" && l.Effect.Colors.Count < 2);
        if (badDrift is not null)
        {
            Ui.ReportError("A Drift effect needs at least 2 colors.");
            return;
        }

        var id = CurrentId;
        if (string.IsNullOrEmpty(id))
        {
            Ui.ReportError("Couldn't derive an id from that name — use some letters or digits.");
            return;
        }

        _edit.Id = id;
        _edit.Name = ComposedName;

        _busy = true;
        try
        {
            var (_, error) = await Api.SaveEventAsync(id, _edit);
            if (error is not null)
            {
                Ui.ReportError(error);
                return;
            }
            await RefreshAsync();

            if (test)
            {
                // Keep editing the saved event (no longer "new") so a follow-up save updates it.
                _isNew = false;
                _edit.Id = id;
                var result = await Api.TriggerEventAsync(id);
                if (result is null) return;
                if (result.FullySucceeded)
                    Ui.ReportOk($"Saved — event \"{id}\" fired");
                else
                    Ui.ReportError($"Saved, but partially fired. {result.ProblemSummary()}");
                await PollAsync();
            }
            else
            {
                Ui.ReportOk($"Saved event \"{id}\"");
                CancelEdit();
            }
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task DeleteTapped()
    {
        if (!_confirmDelete) { _confirmDelete = true; return; }
        if (_edit is null) return;

        _busy = true;
        try
        {
            var (ok, error) = await Api.DeleteEventAsync(_edit.Id);
            if (ok)
            {
                Ui.ReportOk($"Deleted event \"{_edit.Id}\"");
                await RefreshAsync();
                CancelEdit();
            }
            else
            {
                Ui.ReportError(error ?? "Delete failed.");
            }
        }
        finally { _busy = false; }
    }

    public void Dispose() => _timer?.Dispose();
}
