@page "/music"
@implements IDisposable
@inject ApiClient Api
@inject UiState Ui

<PageTitle>Scene Maker — Music</PageTitle>

<h2 class="rune">Now Playing</h2>

<div class="panel">
    <p class="now-title">@(_state?.TrackTitle ?? "Nothing playing")</p>
    <p class="now-sub">@(_state?.PlaylistTitle ?? "Pick a playlist below")</p>

    @if (_state is { Duration: > 0 })
    {
        <div class="progress"><div style="width:@(Math.Clamp(_state.Progress / _state.Duration * 100, 0, 100).ToString("0.#", System.Globalization.CultureInfo.InvariantCulture))%"></div></div>
    }

    <div class="transport">
        <button class="btn" @onclick="@(() => Send("music/previous"))" aria-label="Previous">⏮</button>
        @if (_state?.Playing == true)
        {
            <button class="btn primary play" @onclick="@(() => Send("music/pause"))" aria-label="Pause">⏸</button>
        }
        else
        {
            <button class="btn primary play" @onclick="@(() => Send("music/resume"))" aria-label="Play">▶</button>
        }
        <button class="btn" @onclick="@(() => Send("music/next"))" aria-label="Next">⏭</button>
    </div>

    <div class="slider-row">
        <span class="slider-ico">🔉</span>
        <input type="range" min="0" max="100" value="@_volumePercent"
               @onchange="OnVolumeChanged" aria-label="Volume" />
        <span class="slider-val">@_volumePercent%</span>
    </div>

    <div class="chip-row">
        <button class="chip @(_state?.Muted == true ? "on" : "")"
                @onclick="@(() => Send($"music/mute?value={(_state?.Muted == true ? "false" : "true")}"))">Mute</button>
        <button class="chip @(_state?.Shuffle == true ? "on" : "")"
                @onclick="@(() => Send($"music/shuffle?value={(_state?.Shuffle == true ? "false" : "true")}"))">Shuffle</button>
        <button class="chip @(_state?.Repeat == "playlist" ? "on" : "")"
                @onclick="@(() => Send("music/repeat?mode=playlist"))">Repeat list</button>
        <button class="chip @(_state?.Repeat == "track" ? "on" : "")"
                @onclick="@(() => Send("music/repeat?mode=track"))">Repeat track</button>
        <button class="chip @(_state?.Repeat == "off" ? "on" : "")"
                @onclick="@(() => Send("music/repeat?mode=off"))">No repeat</button>
    </div>
</div>

<h2 class="rune">Playlists</h2>

@if (_playlists is null)
{
    <p class="empty-note">Reading the songbook…</p>
}
else if (_playlists.Count == 0)
{
    <p class="empty-note">No playlists found — is Kenku FM running with Remote enabled?</p>
}
else
{
    <div class="klist">
        @foreach (var group in _playlists)
        {
            <p class="kgroup-title">@group.Title</p>
            <button class="krow" @onclick="() => Play(group.Id, group.Title)">
                <span class="krow-ico">📁</span>
                <span class="krow-title">Play all — @group.Title</span>
            </button>
            @foreach (var track in group.Items)
            {
                <button class="krow" @onclick="() => Play(track.Id, track.Title)">
                    <span class="krow-ico">♪</span>
                    <span class="krow-title">@track.Title</span>
                </button>
            }
        }
    </div>
}

@if (_spotifyConnected)
{
    <h2 class="rune">Spotify</h2>
    <div class="panel">
        <div class="field">
            <label for="spotify-search">Search tracks</label>
            <div class="field-row">
                <input id="spotify-search" type="text" @bind="_spotifyQuery" @bind:event="oninput"
                       @onkeydown="OnSearchKeyDown" placeholder="song or artist…" />
                <button class="btn" @onclick="SearchSpotify" disabled="@_searching">Search</button>
            </div>
        </div>
        @if (_spotifyResults is { Count: > 0 })
        {
            <div class="klist">
                @foreach (var t in _spotifyResults)
                {
                    var label = string.IsNullOrEmpty(t.Artist) ? t.Name : $"{t.Name} — {t.Artist}";
                    <button class="krow" @onclick="() => PlaySpotify(t.Uri, label)">
                        <span class="krow-ico">♪</span>
                        <span class="krow-title">@t.Name <small class="hint">@t.Artist</small></span>
                    </button>
                }
            </div>
        }
    </div>

    <h2 class="rune">Spotify Playlists</h2>
    @if (_spotifyPlaylists is null)
    {
        <p class="empty-note">Reading your Spotify playlists…</p>
    }
    else if (_spotifyPlaylists.Count == 0)
    {
        <p class="empty-note">No Spotify playlists found.</p>
    }
    else
    {
        <div class="klist">
            @foreach (var pl in _spotifyPlaylists)
            {
                <button class="krow" @onclick="() => PlaySpotify(pl.Uri, pl.Name)">
                    <span class="krow-ico">🎧</span>
                    <span class="krow-title">@pl.Name <small class="hint">@pl.TrackCount tracks</small></span>
                </button>
            }
        </div>
    }
}

@code {
    private MusicState? _state;
    private List<KenkuGroup>? _playlists;
    private int _volumePercent = 50;
    private Timer? _timer;

    private bool _spotifyConnected;
    private List<SpotifyPlaylistDto>? _spotifyPlaylists;
    private List<SpotifyTrackDto>? _spotifyResults;
    private string _spotifyQuery = "";
    private bool _searching;

    protected override async Task OnInitializedAsync()
    {
        await PollAsync();
        _playlists = await Api.GetPlaylistsAsync();
        _timer = new Timer(_ => _ = InvokeAsync(PollAsync), null, 3000, 3000);

        var (spotify, _) = await Api.GetSpotifyConfigAsync();
        if (spotify?.Connected == true)
        {
            _spotifyConnected = true;
            var (playlists, error) = await Api.GetSpotifyPlaylistsAsync();
            _spotifyPlaylists = playlists ?? [];
            if (playlists is null && error is not null) Ui.ReportError(error);
        }
    }

    private async Task PollAsync()
    {
        _state = await Api.GetMusicStateAsync();
        if (_state is not null)
            _volumePercent = (int)Math.Round(_state.Volume * 100);
        StateHasChanged();
    }

    private async Task Send(string path)
    {
        if (await Api.CommandAsync(path))
            await PollAsync();
    }

    private async Task Play(string id, string title)
    {
        if (await Api.CommandAsync($"music/play?id={Uri.EscapeDataString(id)}", $"Playing {title}"))
            await PollAsync();
    }

    private async Task OnVolumeChanged(ChangeEventArgs e)
    {
        if (!int.TryParse(e.Value?.ToString(), out var percent)) return;
        _volumePercent = percent;
        var volume = (percent / 100.0).ToString(System.Globalization.CultureInfo.InvariantCulture);
        await Api.CommandAsync($"music/volume?value={volume}");
    }

    private async Task PlaySpotify(string uri, string title)
    {
        if (await Api.CommandAsync($"music/play?id={Uri.EscapeDataString(uri)}", $"Playing {title}"))
            await PollAsync();
    }

    private async Task SearchSpotify()
    {
        if (string.IsNullOrWhiteSpace(_spotifyQuery)) return;
        _searching = true;
        try
        {
            var (results, error) = await Api.SearchSpotifyTracksAsync(_spotifyQuery);
            if (results is not null) _spotifyResults = results;
            else if (error is not null) Ui.ReportError(error);
        }
        finally { _searching = false; }
    }

    private async Task OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchSpotify();
    }

    public void Dispose() => _timer?.Dispose();
}
