@inherits LayoutComponentBase
@implements IDisposable
@inject UiState Ui
@inject NavigationManager Nav

<div class="shell">
    <header class="topbar">
        <h1>Scene Maker</h1>
        <div class="conn-dot @(Ui.Connected ? "" : "off")" title="@(Ui.Connected ? "API connected" : "API unreachable")"></div>
        <button class="icon-btn" @onclick="@(() => Nav.NavigateTo("settings"))" aria-label="Settings">⚙</button>
    </header>

    <main class="page">
        @Body
    </main>

    <nav class="tabbar">
        <NavLink href="" Match="NavLinkMatch.All"><span class="tab-ico">🎲</span>Scenes</NavLink>
        <NavLink href="music"><span class="tab-ico">🎵</span>Music</NavLink>
        <NavLink href="lights"><span class="tab-ico">💡</span>Lights</NavLink>
    </nav>

    @if (Ui.Toast is not null)
    {
        <div class="toast @(Ui.ToastIsError ? "error" : "")">@Ui.Toast</div>
    }
</div>

@code {
    protected override void OnInitialized() => Ui.Changed += OnUiChanged;

    private void OnUiChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Ui.Changed -= OnUiChanged;
}
