@inject Localizer L

@* Load the UI strings before anything renders, so no page flashes raw "nav.scenes"-style keys. The boot
   placeholder mirrors index.html's, so the hand-off from the pre-Blazor splash is seamless. Its text is
   intentionally left literal — the strings aren't loaded yet at this point. *@
@if (_ready)
{
    <Router AppAssembly="@typeof(App).Assembly" NotFoundPage="typeof(Pages.NotFound)">
        <Found Context="routeData">
            <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)"/>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
    </Router>
}
else
{
    <div class="boot">
        <div class="boot-die"><svg viewBox="0 0 256 256" fill="currentColor" aria-hidden="true"><path d="M192,32H64A32,32,0,0,0,32,64V192a32,32,0,0,0,32,32H192a32,32,0,0,0,32-32V64A32,32,0,0,0,192,32ZM92,176a12,12,0,1,1,12-12A12,12,0,0,1,92,176Zm0-72a12,12,0,1,1,12-12A12,12,0,0,1,92,104Zm36,36a12,12,0,1,1,12-12A12,12,0,0,1,128,140Zm36,36a12,12,0,1,1,12-12A12,12,0,0,1,164,176Zm0-72a12,12,0,1,1,12-12A12,12,0,0,1,164,104Z"/></svg></div>
        <div class="boot-text">Preparing the table…</div>
    </div>
}

@code {
    private bool _ready;

    protected override async Task OnInitializedAsync()
    {
        await L.InitializeAsync();
        _ready = true;
    }
}
