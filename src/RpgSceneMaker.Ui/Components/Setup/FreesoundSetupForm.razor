@inject ApiClient Api
@inject UiState Ui
@inject Localizer L

@* The Freesound token panel (BYOK API token, save/disconnect), extracted from the Settings page so the
   first-run onboarding wizard reuses the exact same flow. Owns its own config state (loaded on init);
   the token is write-only (never echoed back). *@

<SectionHeading>@L["settings.freesound.title"]</SectionHeading>
<div class="panel">
    <p class="hint" style="margin-top:0">@L["settings.freesound.hint"]</p>
    <div class="field">
        <label for="freesound-key">@L["settings.freesound.apiKey"]</label>
        <input id="freesound-key" type="password" @bind="_freesound.ApiKey" placeholder='@L["settings.freesound.keyPlaceholder"]' />
        <p class="hint">@L["settings.freesound.keyHint"]</p>
    </div>
    <div class="btn-row">
        <button class="btn btn--primary" @onclick="SaveFreesound" disabled="@_busy">@L["settings.freesound.saveBtn"]</button>
    </div>

    @if (_freesound.Configured)
    {
        <p class="status ok"><Icon Name="ok" /> @L["settings.freesound.configured"]</p>
        <div class="btn-row">
            <button class="btn btn--danger" @onclick="DisconnectFreesound" disabled="@_busy">@L["common.disconnect"]</button>
        </div>
    }
    else
    {
        <p class="status">@L["settings.freesound.noKey"]</p>
    }
</div>

@code {
    private FreesoundConfigDto _freesound = new();
    private bool _busy;

    protected override async Task OnInitializedAsync()
    {
        var (freesound, _) = await Api.GetFreesoundConfigAsync();
        if (freesound is not null) _freesound = freesound;
    }

    private async Task SaveFreesound()
    {
        _busy = true;
        try
        {
            if (await Api.SaveFreesoundConfigAsync(_freesound))
            {
                _freesound.ApiKey = ""; // the token is never echoed; blank the field after saving
                var (freesound, _) = await Api.GetFreesoundConfigAsync();
                if (freesound is not null) _freesound = freesound;
                Ui.ReportOk(L["settings.toast.freesoundSaved"]);
            }
        }
        finally { _busy = false; }
    }

    private async Task DisconnectFreesound()
    {
        if (await Api.DisconnectFreesoundAsync(L["settings.toast.freesoundDisconnected"]))
        {
            var (freesound, _) = await Api.GetFreesoundConfigAsync();
            if (freesound is not null) _freesound = freesound;
        }
    }
}
