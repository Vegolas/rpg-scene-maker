@page "/lights"
@implements IDisposable
@inject ApiClient Api
@inject UiState Ui
@inject Localizer L

<PageTitle>Ambient Director — @L["lights.title"]</PageTitle>

<div class="page-head"><h1>@L["lights.title"]</h1></div>

@if (!_loaded)
{
    <p class="empty-note">@L["lights.loading"]</p>
}
else if (!Ui.Connected)
{
    <p class="empty-note">@L["lights.offline"]</p>
}
else
{
    @if (_registry.Count > 0)
    {
        <SectionHeading>@L["lights.target"]</SectionHeading>
        <div class="chip-row">
            <Chip On="_target is null" OnClick="() => _target = null">@L["common.allLights"]</Chip>
            @foreach (var light in _registry)
            {
                <Chip On="_target == light.Key" OnClick="() => _target = light.Key">@light.Name</Chip>
            }
        </div>
    }

    <SectionHeading>@L["lights.status"]</SectionHeading>
    <div class="panel light-status">
        @if (_status is null)
        {
            <p class="hint">@L["lights.status.unavailable"]</p>
        }
        else
        {
            <div class="light-status__row">
                <span class="light-status__power @(_status.On == true ? "on" : "")">
                    <span class="dot"></span>@L[_status.On == true ? "common.on" : "common.off"]
                </span>
                @if (_status.Color is { } hex)
                {
                    <span class="light-status__swatch" style="background:#@hex"></span>
                    <span class="hint">@($"#{hex.ToUpperInvariant()}")</span>
                }
                else if (_status.Temperature is { } temp)
                {
                    <span class="hint">@L["lights.whiteLight"] · @L[LightFormat.TempWordKey(temp)]</span>
                }
                @if (_status.Brightness is { } b)
                {
                    <span class="hint">@($"{b}%")</span>
                }
            </div>
        }
    </div>

    <SectionHeading>@L["lights.power"]</SectionHeading>
    <div class="btn-row">
        <button class="btn btn--big btn--primary" @onclick="@(() => Send(Path("on"), L["lights.toast.on"]))">@L["common.on"]</button>
        @if (_target is null)
        {
            <button class="btn btn--big" @onclick="@(() => Send("lights/toggle"))">@L["lights.toggle"]</button>
        }
        <button class="btn btn--big btn--danger" @onclick="@(() => Send(Path("off"), L["lights.toast.off"]))">@L["common.off"]</button>
    </div>

    <SectionHeading>@L["lights.moodColors"]</SectionHeading>
    <SwatchGrid Selected="@_pickedHex" OnPick="OnColorPicked" />

    <SectionHeading>@L["lights.brightness"]</SectionHeading>
    <div class="panel">
        <SliderRow LeftIcon="dim" Min="1" Max="100" Suffix="%" Value="_brightness"
                   ValueChanged="OnBrightnessChanged" AriaLabel='@L["lights.brightness"]' />
    </div>

    <SectionHeading>@L["lights.whiteLight"]</SectionHeading>
    <div class="panel">
        <SliderRow LeftIcon="warm" RightIcon="cold" Min="0" Max="100" Value="_temperature"
                   ValueChanged="OnTemperatureChanged" AriaLabel='@L["lights.colorTempAria"]' />
        <div class="btn-row">
            <button class="btn btn--primary" @onclick="ApplyWhite">@L.Format("lights.setWhiteBtn", _brightness, L[TempLabel])</button>
        </div>
    </div>
}

@code {
    private List<RegisteredLightInfo> _registry = [];
    private LightStatusDto? _status;
    private bool _loaded;   // first registry fetch has returned (drives the loading state)
    private bool _seeded;   // controls have been seeded from live state once
    private Timer? _timer;

    private string? _target;   // null = all lights (group endpoints); else a registry key

    private string _pickedHex = "#ff8c2a";
    private int _brightness = 80;
    private int _temperature = 40;

    private string TempLabel => LightFormat.TempWordKey(_temperature);

    protected override async Task OnInitializedAsync()
    {
        _registry = await Api.GetRegisteredLightsAsync();
        _loaded = true;
        await PollAsync();
        // Reflect the real bulb (and recover from a load-time hiccup) on the panel's usual polling cadence.
        _timer = new Timer(_ => _ = InvokeAsync(PollAsync), null, 3000, 3000);
    }

    private async Task PollAsync()
    {
        // Self-heal the target chips if the registry came back empty (e.g. offline at first load).
        if (_registry.Count == 0)
        {
            _registry = await Api.GetRegisteredLightsAsync();
            if (_target is not null && _registry.All(l => l.Key != _target)) _target = null;
        }

        _status = await Api.GetLightsStatusAsync();
        // Seed the interactive controls from the live state once, so they start from reality rather than
        // fixed defaults; later polls only refresh the read-only status strip, never yank a control mid-use.
        if (!_seeded && _status is not null)
        {
            _seeded = true;
            if (_status.Brightness is { } b) _brightness = b;
            if (_status.Color is { } hex) _pickedHex = $"#{hex}";
            else if (_status.Temperature is { } t) _temperature = t;
        }
        StateHasChanged();
    }

    // Command path: group endpoint (/lights/...) for "All", per-light (/lights/{key}/...) otherwise.
    private string Path(string command) => _target is null ? $"lights/{command}" : $"lights/{_target}/{command}";

    private async Task Send(string path, string? ok = null)
    {
        if (await Api.CommandAsync(path, ok))
            await PollAsync();
    }

    private async Task OnColorPicked(string hex)
    {
        _pickedHex = hex;
        var nameKey = Palette.Moods.FirstOrDefault(m => string.Equals(m.Hex, hex, StringComparison.OrdinalIgnoreCase)).NameKey;
        var name = nameKey is not null ? L[nameKey] : L["swatchGrid.customColor"];
        if (await Api.CommandAsync($"{Path("color")}?hex={Uri.EscapeDataString(hex.TrimStart('#'))}&brightness={_brightness}", L.Format("lights.toast.mood", name)))
            await PollAsync();
    }

    private async Task OnBrightnessChanged(int value)
    {
        _brightness = value;
        if (await Api.CommandAsync($"{Path("brightness")}?value={value}"))
            await PollAsync();
    }

    private async Task OnTemperatureChanged(int value)
    {
        _temperature = value;
        await ApplyWhite();
    }

    private async Task ApplyWhite()
    {
        if (await Api.CommandAsync($"{Path("white")}?brightness={_brightness}&temperature={_temperature}", L.Format("lights.toast.white", L[TempLabel])))
            await PollAsync();
    }

    public void Dispose() => _timer?.Dispose();
}
