@page "/tv-remote"
@implements IDisposable
@inject ApiClient Api
@inject UiState Ui
@inject NavigationManager Nav
@inject Localizer L

@* The GM's remote for the player-facing /tv display: shows what's on the TV now (with a prominent Clear),
   uploads-and-pushes a new image (full resolution — no tile-art crop), pushes any saved board, and re-pushes
   recent content (image or board). Polls the same /tv/state as the TV so two GM tabs stay in sync. *@

<PageTitle>Ambient Director — @L["tv.title"]</PageTitle>

<div class="page-head">
    <h1>@L["tv.title"]</h1>
</div>

<div class="panel">
    <SectionHeading>@L["tv.nowShowing"]</SectionHeading>
    <div class="tv-now">
        <div class="tv-now__preview">
            @if (_state?.Content is { Kind: "board", Board: { } board })
            {
                <BoardCanvas Model="board" />
            }
            else if (_state?.Content is { Url: { } url })
            {
                <img src="@url" alt='@L["tv.nowShowingAlt"]' />
            }
            else
            {
                <span class="tv-now__empty">@L["tv.nothing"]</span>
            }
        </div>
        <div class="tv-now__meta">
            @if (_state?.Content?.Label is { Length: > 0 } label)
            {
                <span class="tv-now__label">@label</span>
            }
            <button class="btn btn--danger" @onclick="ClearTv"
                    disabled="@(_state?.Content is null || _busy)">@L["tv.clear"]</button>
        </div>
    </div>
    <p class="hint" style="margin-top:0.8rem">@L.Format("tv.openHint", TvUrl)</p>
</div>

<div class="panel" style="margin-top:1rem">
    <SectionHeading>@L["tv.pushNew"]</SectionHeading>
    <div class="field">
        <label for="tv-label">@L["tv.labelLabel"]</label>
        <input id="tv-label" type="text" value="@_label" maxlength="60"
               @oninput="e => _label = e.Value?.ToString() ?? string.Empty"
               placeholder='@L["tv.labelPlaceholder"]' />
    </div>
    <div class="btn-row" style="margin-top:0.6rem">
        <label class="btn btn--primary tv-upload">
            <InputFile OnChange="OnFileChosen" accept="image/png,image/jpeg,image/webp" disabled="@_busy" />
            @(_busy ? L["tv.uploading"] : L["tv.chooseAndPush"])
        </label>
        <button class="btn" @onclick="OpenPdf" disabled="@_busy">
            <Icon Name="pdf" /> @L["tv.pushPdf"]
        </button>
    </div>
</div>

@if (_pdfOpen)
{
    <PdfPagePicker OnPicked="OnPdfPicked" OnClose="ClosePdf" />
}

<div class="panel" style="margin-top:1rem">
    <SectionHeading>@L["tv.boards"]</SectionHeading>
    @if (_boards.Count == 0)
    {
        <p class="empty-note">@L["tv.boardsEmpty"] <a href="boards">@L["nav.boards"]</a></p>
    }
    else
    {
        @* role="button" divs, not <button>s: a BoardCanvas mini preview renders block divs that can't validly
           nest inside a <button>. *@
        <div class="tv-boards">
            @foreach (var b in _boards)
            {
                <div class="tv-boardtile @(_busy ? "is-busy" : "")" role="button" tabindex="0"
                     title='@L["tv.pushBoard"]' @onclick="() => PushBoard(b.Id, null)"
                     @onkeydown="e => OnBoardKey(e, b.Id)">
                    <div class="tv-boardtile__preview"><BoardCanvas Model="Render(b)" /></div>
                    <span>@b.Name</span>
                </div>
            }
        </div>
    }
</div>

<div class="panel" style="margin-top:1rem">
    <SectionHeading>@L["tv.recent"]</SectionHeading>
    @if (_recent.Count == 0)
    {
        <p class="empty-note">@L["tv.recentEmpty"]</p>
    }
    else
    {
        <div class="tv-recent">
            @foreach (var item in _recent)
            {
                <button class="tv-tile" title='@L["tv.repush"]' disabled="@_busy"
                        @onclick="() => PushRecent(item)">
                    @if (item.Kind == "board")
                    {
                        <span class="tv-tile__board"><Icon Name="boards" /></span>
                        <span>@RecentBoardName(item)</span>
                    }
                    else
                    {
                        <img src="@Api.ImageUrl(item.Ref)" alt="" loading="lazy" />
                        @if (!string.IsNullOrEmpty(item.Label))
                        {
                            <span>@item.Label</span>
                        }
                    }
                </button>
            }
        </div>
    }
</div>

@code {
    private TvStateDto? _state;
    private List<TvRecentItemDto> _recent = [];
    private List<BoardDto> _boards = [];
    // The live party roster (mapped once on load) so a board rail tile draws the real roster for any kind="party"
    // element. The now-showing preview instead uses the server-inlined render model from /tv/state (no change).
    private TvPartyDto? _partyRender;
    private long _rev;
    private string _label = "";
    private bool _busy;
    private bool _pdfOpen;
    private Timer? _timer;

    // What to open on the table screen — absolute, so the GM can read it straight off the panel.
    private string TvUrl => $"{Nav.BaseUri}tv";

    protected override async Task OnInitializedAsync()
    {
        await Api.GetApiKeyAsync(); // cache the key so the recent/board tile /images urls carry it
        _boards = await Api.GetBoardsAsync();
        var party = await Api.GetPartyAsync();
        // The active game system (issue #128) resolves each rail tile's counter glyph/colour to match the TV;
        // fetched here (not from UiState) so it is correct even on a deep-link load racing the layout's fetch.
        var systems = await Api.GetGameSystemsAsync();
        _partyRender = party is null ? null : PartyRender.ToRenderModel(party, Api.ImageUrl, systems?.Active);
        await PollAsync();
        _timer = new Timer(_ => _ = InvokeAsync(PollAsync), null, 2000, 2000);
    }

    private async Task PollAsync()
    {
        var state = await Api.GetTvStateAsync(_rev);
        if (state is null || state.Rev == _rev) return; // offline blip or unchanged
        _rev = state.Rev;
        _state = state;
        _recent = await Api.GetTvRecentAsync();
        StateHasChanged();
    }

    // A board's mini preview for the rail — key-bearing /images urls + the live party, the same shape the TV draws.
    private TvBoardDto Render(BoardDto board) => BoardRender.ToRenderModel(board, Api.ImageUrl, _partyRender);

    // A recent board tile shows the live board name (a rename since the push is reflected), falling back to the
    // label stored at push time when the board no longer exists.
    private string RecentBoardName(TvRecentItemDto item) =>
        _boards.FirstOrDefault(b => string.Equals(b.Id, item.Ref, StringComparison.OrdinalIgnoreCase))?.Name
            ?? item.Label ?? item.Ref;

    private async Task OnFileChosen(InputFileChangeEventArgs e)
    {
        if (_busy || e.FileCount == 0) return;
        var file = e.File;
        if (file.Size > 10L * 1024 * 1024)
        {
            Ui.ReportError(L.Format("tv.fileTooLarge", 10));
            return;
        }
        _busy = true;
        try
        {
            var (id, error) = await Api.UploadImageFileAsync(file);
            if (id is null)
            {
                Ui.ReportError(error ?? L["tv.toast.uploadFailed"]);
                return;
            }
            if (await Api.ShowOnTvAsync(id, _label, L["tv.toast.shown"]))
            {
                _label = "";
                await ForcePollAsync();
            }
        }
        finally
        {
            _busy = false;
        }
    }

    private void OpenPdf() => _pdfOpen = true;

    private void ClosePdf() => _pdfOpen = false;

    // A picked PDF page was rendered + stored server-side; push that stored image just like a fresh upload.
    private async Task OnPdfPicked(string? id)
    {
        _pdfOpen = false;
        if (id is null || _busy) return;
        _busy = true;
        try
        {
            if (await Api.ShowOnTvAsync(id, _label, L["tv.toast.shown"]))
            {
                _label = "";
                await ForcePollAsync();
            }
        }
        finally
        {
            _busy = false;
        }
    }

    // Re-push a recent item — an image via /images, a board by id.
    private async Task PushRecent(TvRecentItemDto item)
    {
        if (_busy) return;
        _busy = true;
        try
        {
            var ok = item.Kind == "board"
                ? await Api.ShowBoardOnTvAsync(item.Ref, item.Label, L["tv.toast.shown"])
                : await Api.ShowOnTvAsync(item.Ref, item.Label, L["tv.toast.shown"]);
            if (ok) await ForcePollAsync();
        }
        finally { _busy = false; }
    }

    // Keyboard activation for the role="button" rail tiles (Enter / Space), matching a native button.
    private async Task OnBoardKey(KeyboardEventArgs e, string id)
    {
        if (e.Key is "Enter" or " ") await PushBoard(id, null);
    }

    private async Task PushBoard(string id, string? label)
    {
        if (_busy) return;
        _busy = true;
        try
        {
            if (await Api.ShowBoardOnTvAsync(id, label, L["tv.toast.shown"]))
                await ForcePollAsync();
        }
        finally { _busy = false; }
    }

    private async Task ClearTv()
    {
        if (_busy) return;
        _busy = true;
        try
        {
            if (await Api.ClearTvAsync(L["tv.toast.cleared"]))
                await ForcePollAsync();
        }
        finally
        {
            _busy = false;
        }
    }

    // Refresh right after our own command instead of waiting out the 2 s poll tick.
    private Task ForcePollAsync()
    {
        _rev = 0;
        return PollAsync();
    }

    public void Dispose() => _timer?.Dispose();
}
