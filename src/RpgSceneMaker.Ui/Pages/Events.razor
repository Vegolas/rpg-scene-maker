@page "/events"
@implements IDisposable
@inject ApiClient Api
@inject UiState Ui
@inject ViewTransition Vt

<PageTitle>Scene Maker — Events</PageTitle>

<RuneHeading>Events</RuneHeading>

@if (_events is null)
{
    <p class="empty-note">Gathering the omens…</p>
}
else
{
    @if (_events.Count == 0)
    {
        <p class="empty-note">No events yet — conjure a thunderclap or a horn blast below.</p>
    }
    <div class="scene-grid">
        @foreach (var (evt, index) in _events.Select((e, i) => (e, i)))
        {
            var (emoji, label) = SceneNaming.SplitName(evt.Name, "⚡", evt.Id);
            var artUrl = Api.ImageUrl(evt.Image);
            var hasArt = artUrl is not null;
            var running = _runningId == evt.Id;
            <button class="scene-card @(_busyId == evt.Id ? "busy" : "") @(running ? "playing" : "") @(hasArt ? "art" : "")"
                    style="animation-delay:@(index * 55)ms; --sc:@(SwatchColor(evt));@(hasArt ? $" --art:url('{artUrl}');" : "")"
                    @onclick="() => Trigger(evt.Id)">
                @if (hasArt)
                {
                    <span class="scene-art"></span>
                }
                <span class="scene-swatch"></span>
                <span class="card-edit" role="button" tabindex="0" aria-label="Edit event"
                      @onclick="() => Edit(evt.Id)" @onclick:stopPropagation="true">✎</span>
                @if (running)
                {
                    <span class="card-stop" role="button" tabindex="0" aria-label="Stop event"
                          @onclick="Stop" @onclick:stopPropagation="true">⏹</span>
                }
                <span class="scene-emoji">@emoji</span>
                <span class="scene-name">@label</span>
            </button>
        }
        <button class="scene-card ghost" @onclick="NewEvent">
            <span class="scene-emoji">＋</span>
            <span class="scene-name">New event</span>
        </button>
    </div>
    @if (_events.Count > 0)
    {
        <p class="hint" style="margin-top:1rem">Tap to fire. ✎ to edit the timeline. ⏹ appears while an event is playing.</p>
    }
}

@code {
    private List<EventDto>? _events;
    private string? _busyId;
    private string? _runningId;
    private Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        await Api.GetApiKeyAsync(); // cache the key so tile-art urls carry it
        await RefreshAsync();
        _timer = new Timer(_ => _ = InvokeAsync(PollAsync), null, 1500, 1500);
    }

    private async Task RefreshAsync()
    {
        _events = await Api.GetEventsAsync();
        await PollAsync();
    }

    private async Task PollAsync()
    {
        var running = await Api.GetRunningEventIdAsync();
        if (running != _runningId)
        {
            _runningId = running;
            StateHasChanged();
        }
    }

    // Card tint: the first light clip's colour (or the legacy flash colour), like a scene's swatch.
    private static string SwatchColor(EventDto evt)
    {
        var color = evt.Timeline?.Lights?.FirstOrDefault(l => l.Color is not null)?.Color;
        return color ?? evt.Flash?.Color ?? "transparent";
    }

    private async Task Trigger(string id)
    {
        _busyId = id;
        StateHasChanged();
        try
        {
            var result = await Api.TriggerEventAsync(id);
            if (result is null) return;
            if (result.FullySucceeded)
                Ui.ReportOk($"Event \"{id}\" fired");
            else
                Ui.ReportError($"Partially fired. {result.ProblemSummary()}");
            await PollAsync();
        }
        finally
        {
            _busyId = null;
            StateHasChanged();
        }
    }

    private async Task Stop()
    {
        if (await Api.StopEventAsync())
        {
            _runningId = null;
            StateHasChanged();
        }
    }

    private Task NewEvent() => Vt.NavigateAsync("events/editor");

    private Task Edit(string id) => Vt.NavigateAsync($"events/editor/{id}");

    public void Dispose() => _timer?.Dispose();
}
