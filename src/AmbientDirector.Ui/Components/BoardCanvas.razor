@* The single board renderer. Draws a board's render model (TvBoardDto) onto a fixed 16:9 stage; used by the
   TV page, the editor's live preview, the boards-list cards and the remote's now-showing/rail previews. The
   element list order IS the paint/z-order (index 0 = bottom) — there is no z-index. Text sizes in cqh (1% of
   the container's height) so it scales identically on a full TV, the editor preview and a tiny list card; that
   is why the root sets container-type:size. Purely presentational — no interactivity lives here. *@

<div class="board-canvas" style="background:@(Model.BackgroundColor ?? "#000")">
    @if (Model.BackgroundUrl is { } bg && !_failed.Contains(bg))
    {
        <img class="board-canvas__bg" src="@bg" alt="" @onerror="() => _failed.Add(bg)" />
    }
    @foreach (var el in Model.Elements)
    {
        // One counter's value for a PARTY PLAYER row: a row of pips (dots, filled up to Value) for a
        // "pips"/small-bounded counter, else tabular-nums text (Value, or Value/Max when a max is set). The
        // table-counter strip is gone (issue #144 moved Fear to the dedicated fear element), so this now serves
        // only the per-player rows. Sized in container units so it scales with the stage. Each counter arrives
        // with its Glyph + Color already resolved from the active game system (issue #128) — BoardCanvas draws
        // them, it no longer matches labels — so a Polish "Stres" themes exactly like an English "Stress".
        // Enemies use enemyValue below.
        RenderFragment<TvPartyCounterDto> counterValue = c =>
        @<span class="bparty__val">
            @if (IsPips(c))
            {
                var pipMax = Math.Min(c.Max ?? 0, PipCap);
                var filled = Math.Clamp(c.Value, 0, pipMax);
                var svg = GlyphSvg(c.Glyph);
                @* A counter with a curated glyph (svg != null) renders that themed pip — a broken heart, dark
                   heart, broken shield, diamond, …; filled from --pip / self-styled and dim-empty in CSS. Every
                   other counter (no glyph — custom tracks, and Fear) keeps the plain dot in its --pip colour. *@
                <span class="bparty__pips" style="--pip:@PipVar(c)">
                    @for (var i = 0; i < pipMax; i++)
                    {
                        <span class="@PipClass(c.Glyph, svg is not null, i < filled)">
                            @if (svg is not null)
                            {
                                <svg viewBox="0 0 256 256" aria-hidden="true">@((MarkupString)svg)</svg>
                            }
                        </span>
                    }
                </span>
            }
            else
            {
                <span class="bparty__num">@(c.Max is { } m ? $"{c.Value}/{m}" : c.Value.ToString())</span>
            }
        </span>;

        // An ENEMY counter, drawn so the players never learn its MAX — they must not see how much more HP/Stress
        // is left to mark before it drops (issue #129 follow-up). So, unlike counterValue: pips draw ONLY the
        // marked (filled) count, never the empty remainder that would reveal the total (an undamaged enemy shows
        // no marks — like un-ticked HP boxes at the table); number style shows the bare Value, never "/max". The
        // GM's own Encounters tracker still shows the full track — this hiding is player-facing (BoardCanvas) only.
        RenderFragment<TvPartyCounterDto> enemyValue = c =>
        @<span class="bparty__val">
            @if (IsPips(c))
            {
                var marked = Math.Clamp(c.Value, 0, PipCap);
                var svg = GlyphSvg(c.Glyph);
                <span class="bparty__pips" style="--pip:@PipVar(c)">
                    @for (var i = 0; i < marked; i++)
                    {
                        <span class="@PipClass(c.Glyph, svg is not null, true)">
                            @if (svg is not null)
                            {
                                <svg viewBox="0 0 256 256" aria-hidden="true">@((MarkupString)svg)</svg>
                            }
                        </span>
                    }
                </span>
            }
            else
            {
                <span class="bparty__num">@c.Value</span>
            }
        </span>;
        <div class="board-el" style="left:@Pct(el.X)%;top:@Pct(el.Y)%;width:@Pct(el.W)%;height:@Pct(el.H)%">
            @if (el.Kind == "image")
            {
                @if (el.Url is { } url && !_failed.Contains(url))
                {
                    @* A vanished file must not show a broken-image glyph on the table TV — hide it on error. *@
                    <img class="board-el__img" src="@url" alt="" @onerror="() => _failed.Add(url)" />
                }
            }
            else if (el.Kind == "text")
            {
                <div class="board-el__text" style="@TextStyle(el)">@el.Text</div>
            }
            else if (el.Kind == "party")
            {
                @if (el.Party is { } p)
                {
                    <div class="board-el__party">
                        @* Players only now (issue #144): the table-counter strip moved to the dedicated fear
                           element, so the party element renders just the hero cards. Design hero cards (#120 "TV
                           Board" versus mode): portrait on the LEFT, then a column with the name and one row per
                           counter. A vertical stack of equal-height cards fills the element box — matching the
                           mock's left party column. *@
                        <div class="bparty__list">
                            @foreach (var pl in p.Players)
                            {
                                <div class="bparty__player">
                                    <div class="bparty__portrait">
                                        @if (pl.PortraitUrl is { } purl && !_failed.Contains(purl))
                                        {
                                            <img src="@purl" alt="" @onerror="() => _failed.Add(purl)" />
                                        }
                                        else
                                        {
                                            <span class="bparty__initial">@Initial(pl.Name)</span>
                                        }
                                    </div>
                                    <div class="bparty__info">
                                        <div class="bparty__pname">@pl.Name</div>
                                        @if (pl.Counters.Count > 0)
                                        {
                                            <div class="bparty__crows">
                                                @foreach (var c in pl.Counters)
                                                {
                                                    <div class="bparty__crow">
                                                        <span class="bparty__label">@c.Label</span>
                                                        @counterValue(c)
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    @* Panel contexts that didn't supply live data render a quiet placeholder, never a broken box. *@
                    <div class="board-el__party board-el__party--empty"><Icon Name="party" /></div>
                }
            }
            else if (el.Kind == "enemies")
            {
                @if (el.Party is { Enemies.Count: > 0 } p)
                {
                    @* A vertical stack of enemy cards filling the element box — name (+ SPOTLIGHT chip for a boss)
                       and the same counter rows the party element uses (shared counterValue + .bparty__label /
                       pip classes; enemy pips are tinted red in _party.scss via ".benemies .bparty__pip"). *@
                    <div class="benemies">
                        @foreach (var en in p.Enemies)
                        {
                            <div class="benemies__card@(en.Spotlight ? " benemies__card--spotlight" : "")">
                                <div class="benemies__namerow">
                                    @if (en.PortraitUrl is { } eurl && !_failed.Contains(eurl))
                                    {
                                        @* Enemies get portraits too (#122); a vanished file hides rather than
                                           flashing a broken glyph, like the hero portrait. *@
                                        <span class="benemies__portrait"><img src="@eurl" alt="" @onerror="() => _failed.Add(eurl)" /></span>
                                    }
                                    <span class="benemies__name">@en.Name</span>
                                    @if (en.Spotlight && !string.IsNullOrEmpty(en.SpotlightLabel))
                                    {
                                        @* Deliberate LITERAL, not localized: the chip text is the active game
                                           system's SpotlightLabel (Daggerheart's "SPOTLIGHT"), resolved server-
                                           side into the render model (#128). BoardCanvas renders on the KEY-FREE TV
                                           where /i18n sits behind the API gate, so it must not depend on Localizer;
                                           null label (no system) drops the chip entirely. *@
                                        <span class="benemies__chip">@en.SpotlightLabel</span>
                                    }
                                </div>
                                @if (en.Counters.Count > 0)
                                {
                                    <div class="benemies__crows">
                                        @foreach (var c in en.Counters)
                                        {
                                            <div class="benemies__crow">
                                                <span class="bparty__label">@c.Label</span>
                                                @enemyValue(c)
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
                else
                {
                    @* Panel offline or an empty enemy roster → a quiet placeholder, never a broken box. *@
                    <div class="board-el__party board-el__party--empty"><Icon Name="enemies" /></div>
                }
            }
            else if (el.Kind == "fear")
            {
                // The table's Fear as a skull track (issue #144). Matched by the fear-keyed table counter — its
                // localized label ("Fear"/"Strach") can never be matched, only its semantic Key.
                var fear = el.Party?.Counters.FirstOrDefault(c => string.Equals(c.Key, "fear", StringComparison.OrdinalIgnoreCase));
                @if (fear is null)
                {
                    @* Panel offline, or no fear-keyed table counter → a quiet placeholder, never a broken box. *@
                    <div class="board-el__party board-el__party--empty"><Icon Name="fear" /></div>
                }
                else
                {
                    // Up to 12 slots, lit up to Value. Slot i ALWAYS shows skull_{i+1}, so the demon art at slot
                    // 12 only ignites at max Fear; the track keeps every slot visible (dim silhouette) so the
                    // layout never reflows as Fear rises. The art is a static wwwroot asset (outside the API-key
                    // gate), so the key-free TV loads it directly — no /tv/content route needed.
                    var slots = Math.Clamp(fear.Max ?? 12, 1, 12);
                    var filled = Math.Clamp(fear.Value, 0, slots);
                    <div class="bfear" style="--slots:@slots">
                        @for (var i = 0; i < slots; i++)
                        {
                            var on = i < filled;
                            // Only genuinely-new skulls pop: those at/above FearAnimateFrom (the previous Fear on
                            // an increase, or 0 on first show). The inline animation-delay staggers the cascade.
                            var pop = on && FearAnimateFrom is { } from && i >= from;
                            var cls = "bfear__skull" + (on ? " is-on" : "") + (pop ? " bfear__skull--pop" : "");
                            <div class="@cls" style="@(pop ? FearPopStyle(i) : null)">
                                <img src="@($"img/fear/skull_{i + 1}.jpg")" alt="" />
                            </div>
                        }
                    </div>
                }
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public TvBoardDto Model { get; set; } = default!;

    // When set, lit fear slots at index >= it play the staggered "pop" (issue #144): the TV passes the PREVIOUS
    // Fear value on an increase (so only genuinely-new skulls animate), or 0 when a fear board first appears
    // (full cascade). Null (panel previews, or no change) renders the track statically. The pop's 0.75 s base
    // delay lets the TV's crossfade of the new layer finish before the skulls ignite.
    [Parameter] public int? FearAnimateFrom { get; set; }

    // Image urls that failed to load — skipped on re-render so a broken file never flashes a glyph. Keyed by
    // the full url (which carries ?rev=/?apiKey=), so a re-pushed or edited board's new url retries the fetch.
    private readonly HashSet<string> _failed = new(StringComparer.Ordinal);

    // "pips" can't render more dots than a TV can read; the API caps a pips max at 24, so we mirror that here.
    private const int PipCap = 24;

    private static string Pct(double v) => v.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture);

    private static string TextStyle(TvBoardElementDto el)
    {
        var size = el.Size is { } s and > 0 ? s : 5;              // percent of stage height (renderer default 5)
        var align = string.IsNullOrEmpty(el.Align) ? "left" : el.Align;
        var color = string.IsNullOrEmpty(el.Color) ? "#eef2f8" : el.Color; // near-white (matches --text token)
        return $"--sz:{Pct(size)};text-align:{align};color:{color}";
    }

    // A counter draws as pips when it says so, or (style unset) when it has a small, TV-renderable max; else a
    // number. Mirrors the API's renderer rule (PartyValidation) and Party.razor's panel-side copy.
    private static bool IsPips(TvPartyCounterDto c) =>
        string.Equals(c.Style, "pips", StringComparison.Ordinal) || (c.Style is null && c.Max is >= 1 and <= PipCap);

    // The pip's CSS classes: the base, an optional glyph modifier keyed by the curated glyph NAME the render
    // model carries (bparty__pip--heart-broken etc. in _party.scss — issue #128, no longer a matched label), and
    // is-on when filled. A counter with no (or an unrecognised) glyph renders as a plain dot — no modifier,
    // coloured by --pip. Shared by the party and enemies elements, so an enemy's HP/Stress reads like a hero's.
    private static string PipClass(string? glyph, bool hasGlyph, bool on) =>
        "bparty__pip" + (hasGlyph ? $" bparty__pip--{glyph}" : "") + (on ? " is-on" : "");

    // The pip fill colour, handed to CSS as the --pip custom property: the counter's resolved content Colour, or
    // a neutral default for a plain custom dot. Colour-carrying glyphs (heart-broken/shield-broken/diamond) fill
    // from --pip; heart-dark is self-styled in CSS and ignores it (its Colour is null anyway). Content colours,
    // exempt from the one blue chrome accent like scene colours.
    private static string PipVar(TvPartyCounterDto c) => c.Color ?? "#cfd6e2";

    // Inner SVG (viewBox 0 0 256 256) for each curated glyph name (GameSystemGlyphs). The "broken" heart/shield
    // glyphs cut a jagged crack with a fill-rule:evenodd hole so the card shows through (no hardcoded background).
    // Hand-authored simple shapes — they read at pip size (~20px) and can't ship a malformed Phosphor path.
    private const string HeartGlyph =
        "<path d=\"M128,222 C128,222 26,158 26,90 C26,58 50,34 82,34 C104,34 120,48 128,64 C136,48 152,34 174,34 C206,34 230,58 230,90 C230,158 128,222 128,222 Z\"/>";
    private const string BrokenHeartGlyph =
        "<path fill-rule=\"evenodd\" d=\"M128,222 C128,222 26,158 26,90 C26,58 50,34 82,34 C104,34 120,48 128,64 C136,48 152,34 174,34 C206,34 230,58 230,90 C230,158 128,222 128,222 Z M132,62 L112,116 L138,128 L114,182 L128,218 L142,182 L118,128 L144,116 L124,62 Z\"/>";
    private const string BrokenShieldGlyph =
        "<path fill-rule=\"evenodd\" d=\"M128,26 C128,26 70,48 48,54 C48,120 80,190 128,226 C176,190 208,120 208,54 C186,48 128,26 128,26 Z M132,44 L112,110 L138,122 L114,178 L128,212 L142,178 L118,122 L144,110 L124,44 Z\"/>";
    private const string DiamondGlyph =
        "<rect x=\"70\" y=\"70\" width=\"116\" height=\"116\" rx=\"14\" transform=\"rotate(45 128 128)\"/>";

    // The themed pip SVG for a curated glyph name, or null when the counter has no (or an unrecognised) glyph —
    // then it renders as a plain dot. Names match GameSystemGlyphs.Known / the .bparty__pip--<name> CSS.
    private static string? GlyphSvg(string? glyph) => glyph switch
    {
        "heart-broken" => BrokenHeartGlyph,
        "heart-dark" => HeartGlyph,
        "shield-broken" => BrokenShieldGlyph,
        "diamond" => DiamondGlyph,
        _ => null,
    };

    // The inline animation-delay for a lit, popping fear skull at index i (issue #144): a 0.75 s base (lets the
    // TV's crossfade finish first) plus 0.12 s per skull past FearAnimateFrom, so the new skulls ignite in a
    // left-to-right cascade. Invariant-formatted so the CSS parses "0.87s" regardless of the device locale.
    private string? FearPopStyle(int i) =>
        FearAnimateFrom is { } from
            ? $"animation-delay:{(0.75 + (i - from) * 0.12).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)}s"
            : null;

    // The portrait fallback: the first (rune-safe, so an emoji name doesn't split a surrogate) letter of the name.
    private static string Initial(string name)
    {
        name = name.Trim();
        if (name.Length == 0) return "?";
        return name.EnumerateRunes().First().ToString().ToUpperInvariant();
    }
}
