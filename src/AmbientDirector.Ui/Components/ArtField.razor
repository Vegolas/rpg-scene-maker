@* Reusable tile-art picker: shows the current art thumbnail and an Upload/Remove pair. The browser
   crops + downscales the chosen image (rpgImageCrop) so only a small data URL crosses interop; we
   upload that and store the returned file name via @bind-Image. *@
@inject IJSRuntime JS
@inject ApiClient Api
@inject UiState Ui
@inject Localizer L

<div class="art-field">
    <label class="art-label">@L["artField.label"]</label>
    <div class="art-preview">
        @if (Api.ImageUrl(Image) is { } url)
        {
            <img class="art-thumb" src="@url" alt='@L["artField.altPreview"]' />
        }
        else
        {
            <span class="art-empty">@L["artField.noArt"]</span>
        }
    </div>
    <div class="btn-row" style="margin-top:0.6rem">
        <button class="btn btn--small" @onclick="Upload" disabled="@_busy">
            @(_busy ? L["artField.uploading"] : HasImage ? L["artField.replace"] : L["artField.upload"])
        </button>
        <button class="btn btn--small" @onclick="OpenSearch" disabled="@_busy">@L["artField.search"]</button>
        <button class="btn btn--small" @onclick="OpenPdf" disabled="@_busy">@L["artField.pdf"]</button>
        @if (HasImage)
        {
            <button class="btn btn--small btn--danger" @onclick="Remove" disabled="@_busy">@L["common.remove"]</button>
        }
    </div>
</div>

@if (_searchOpen)
{
    <ImageSearchPicker OnPicked="OnSearchPicked" OnClose="CloseSearch" />
}

@if (_pdfOpen)
{
    <PdfPagePicker OnPicked="OnPdfPicked" OnClose="ClosePdf" />
}

@code {
    [Parameter] public string? Image { get; set; }
    [Parameter] public EventCallback<string?> ImageChanged { get; set; }

    private bool _busy;
    private bool _searchOpen;
    private bool _pdfOpen;

    private bool HasImage => !string.IsNullOrEmpty(Image);

    private void OpenSearch() => _searchOpen = true;

    private void CloseSearch() => _searchOpen = false;

    // A picked search result was imported server-side; store its id exactly like a fresh upload, then close.
    private async Task OnSearchPicked(string? id)
    {
        Image = id;
        await ImageChanged.InvokeAsync(id);
        _searchOpen = false;
    }

    private void OpenPdf() => _pdfOpen = true;

    private void ClosePdf() => _pdfOpen = false;

    // A picked PDF page was rendered + stored server-side; store its id exactly like a search import.
    private async Task OnPdfPicked(string? id)
    {
        Image = id;
        await ImageChanged.InvokeAsync(id);
        _pdfOpen = false;
    }

    // Ensure the API key is cached so ImageUrl() builds the correct (key-bearing) src synchronously.
    protected override Task OnInitializedAsync() => Api.GetApiKeyAsync();

    private async Task Upload()
    {
        if (_busy) return;
        _busy = true;
        try
        {
            // 4:3 crop frame, longest side 640px — matches the tile art layer.
            var dataUrl = await JS.InvokeAsync<string?>("rpgImageCrop.cropFromFilePicker", 4, 3, 640);
            if (string.IsNullOrEmpty(dataUrl)) return; // cancelled

            var comma = dataUrl.IndexOf(',');
            if (comma < 0) { Ui.ReportError(L["artField.toast.cropReadFailed"]); return; }

            var isWebp = dataUrl[..comma].Contains("image/webp", StringComparison.OrdinalIgnoreCase);
            var contentType = isWebp ? "image/webp" : "image/jpeg";
            var ext = isWebp ? ".webp" : ".jpg";
            var bytes = Convert.FromBase64String(dataUrl[(comma + 1)..]);

            var (id, error) = await Api.UploadImageAsync(bytes, $"art{ext}", contentType);
            if (id is not null)
            {
                Image = id;
                await ImageChanged.InvokeAsync(id);
            }
            else
            {
                Ui.ReportError(error ?? L["artField.toast.uploadFailed"]);
            }
        }
        catch (Exception ex)
        {
            Ui.ReportError(L.Format("artField.toast.uploadFailedDetail", ex.Message));
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task Remove()
    {
        Image = null;
        await ImageChanged.InvokeAsync(null);
    }
}
