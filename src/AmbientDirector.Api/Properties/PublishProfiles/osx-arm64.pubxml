<?xml version="1.0" encoding="utf-8"?>
<!--
  One-artifact macOS (Apple Silicon) build (issue #83), the sibling of win-x64.pubxml.

  Produces a self-contained osx-arm64 build: a single AmbientDirector.Api executable (the .NET runtime, the
  API and all server DLLs collapsed into one file, native libs self-extracted at runtime) next to a small
  wwwroot/ folder (the hosted Blazor WASM panel) and a couple of editable config files. The publish folder is
  packaged by the publish workflow into ambient-director-osx-arm64.tar.gz — the user extracts it and runs
  ./AmbientDirector.Api, no SDK install. The cross-platform soundboard/local-music (#82) mixes through the
  bundled OpenAL Soft native, so audio works too.

  macOS note: the binary is unsigned/unnotarized, so Gatekeeper quarantines it on first run — clear it with
  `xattr -dr com.apple.quarantine AmbientDirector.Api` (or right-click → Open once).

  Same single-file caveats as win-x64: the Blazor WASM assets stay loose next to the exe (static-web-assets,
  not bundle-able content) and appsettings.json / scenes.json stay loose on purpose (user-editable / the
  starter-scene template LegacyImporter reads on first run).

  These flags live here (not on the `dotnet publish` command line) on purpose: command-line
  -p:PublishSingleFile=true propagates to the referenced Blazor WASM UI project, which cannot be single-file
  (NETSDK1098). A publish profile scopes them to this project only.

  Build it with:  dotnet publish src/AmbientDirector.Api -p:PublishProfile=osx-arm64
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishProtocol>FileSystem</PublishProtocol>
    <_TargetId>Folder</_TargetId>
    <RuntimeIdentifier>osx-arm64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
  </PropertyGroup>
</Project>
