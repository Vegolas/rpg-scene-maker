@page "/events"
@implements IDisposable
@inject ApiClient Api
@inject UiState Ui
@inject ViewTransition Vt
@inject Localizer L

<PageTitle>Ambient Director — @L["events.title"]</PageTitle>

<div class="page-head">
    <h1>@L["events.title"]</h1>
    @if (_events is not null)
    {
        <span class="count">@L.Plural("events.savedCount", _events.Count)</span>
    }
</div>

@if (_events is null)
{
    <p class="empty-note">@L["events.loading"]</p>
}
else
{
    var shown = _events.Where(EventMatches).ToList();
    @if (_events.Count == 0)
    {
        <p class="empty-note">@L["events.empty"]</p>
    }
    <div class="scene-grid">
        @foreach (var (evt, index) in shown.Select((e, i) => (e, i)))
        {
            var (emoji, label) = SceneNaming.SplitName(evt.Name, "", evt.Id);
            var artUrl = Api.ImageUrl(evt.Image);
            var hasArt = artUrl is not null;
            var running = _runningId == evt.Id;
            <button class="scene-card @(_busyId == evt.Id ? "busy" : "") @(running ? "playing" : "") @(hasArt ? "art" : "")"
                    style="animation-delay:@(index * 55)ms; --sc:@(SwatchColor(evt));@(hasArt ? $" --art:url('{artUrl}');" : "")"
                    @onclick="() => Trigger(evt.Id)">
                @if (hasArt)
                {
                    <span class="scene-art"></span>
                }
                <span class="scene-swatch"></span>
                <span class="card-edit" role="button" tabindex="0" aria-label='@L["events.editAria"]'
                      @onclick="() => Edit(evt.Id)" @onclick:stopPropagation="true"><Icon Name="edit" /></span>
                @if (running)
                {
                    <span class="card-stop" role="button" tabindex="0" aria-label='@L["events.stopAria"]'
                          @onclick="Stop" @onclick:stopPropagation="true"><Icon Name="stop" /></span>
                }
                <Glyph Emoji="@emoji" Fallback="events" />
                <span class="scene-name">@label</span>
            </button>
        }
        @if (!Searching)
        {
            <button class="scene-card ghost" @onclick="NewEvent">
                <span class="scene-emoji"><Icon Name="add" /></span>
                <span class="scene-name">@L["events.new"]</span>
            </button>
        }
    </div>
    @if (Searching && shown.Count == 0)
    {
        <p class="empty-note">@L.Format("events.noMatch", Ui.SearchQuery)</p>
    }
    else if (_events.Count > 0)
    {
        <p class="hint" style="margin-top:1rem">@L["events.hint"]</p>
    }
}

@code {
    private List<EventDto>? _events;
    private string? _busyId;
    private string? _runningId;
    private Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        Ui.SearchChanged += OnSearchChanged;
        await Api.GetApiKeyAsync(); // cache the key so tile-art urls carry it
        await RefreshAsync();
        _timer = new Timer(_ => _ = InvokeAsync(PollAsync), null, 1500, 1500);
    }

    private bool Searching => !string.IsNullOrWhiteSpace(Ui.SearchQuery);

    // Match the header search against the event's display label and its id.
    private bool EventMatches(EventDto evt)
    {
        var q = Ui.SearchQuery;
        if (string.IsNullOrWhiteSpace(q)) return true;
        var (_, label) = SceneNaming.SplitName(evt.Name, "", evt.Id);
        return label.Contains(q, StringComparison.OrdinalIgnoreCase)
            || evt.Id.Contains(q, StringComparison.OrdinalIgnoreCase);
    }

    private void OnSearchChanged() => InvokeAsync(StateHasChanged);

    private async Task RefreshAsync()
    {
        _events = await Api.GetEventsAsync();
        await PollAsync();
    }

    private async Task PollAsync()
    {
        var running = await Api.GetRunningEventIdAsync();
        if (running != _runningId)
        {
            _runningId = running;
            StateHasChanged();
        }
    }

    // Card tint: the first light clip's colour (or the legacy flash colour), like a scene's swatch.
    private static string SwatchColor(EventDto evt)
    {
        var color = evt.Timeline?.Lights?.FirstOrDefault(l => l.Color is not null)?.Color;
        return color ?? evt.Flash?.Color ?? "transparent";
    }

    private async Task Trigger(string id)
    {
        _busyId = id;
        StateHasChanged();
        try
        {
            var result = await Api.TriggerEventAsync(id);
            if (result is null) return;
            if (result.FullySucceeded)
                Ui.ReportOk(L.Format("events.toast.fired", id));
            else
                Ui.ReportError(L.Format("events.toast.partial", result.ProblemSummary(k => L[k])));
            await PollAsync();
        }
        finally
        {
            _busyId = null;
            StateHasChanged();
        }
    }

    private async Task Stop()
    {
        if (await Api.StopEventAsync())
        {
            _runningId = null;
            StateHasChanged();
        }
    }

    private Task NewEvent() => Vt.NavigateAsync("event-editor");

    private Task Edit(string id) => Vt.NavigateAsync($"event-editor/{id}");

    public void Dispose()
    {
        Ui.SearchChanged -= OnSearchChanged;
        _timer?.Dispose();
    }
}
