@page "/events/editor"
@page "/events/editor/{EventId}"
@implements IDisposable
@inject ApiClient Api
@inject UiState Ui
@inject NavigationManager Nav
@inject ViewTransition Vt

<PageTitle>Scene Maker — @(_isNew ? "New event" : "Edit event")</PageTitle>

@if (_loading)
{
    <p class="empty-note">Unrolling the scroll…</p>
}
else
{
    <div class="page-head"><h1>@(_isNew ? "New Event" : "Edit Event")</h1></div>

    <div class="panel">
        <div class="emoji-row">
            @foreach (var e in Palette.Emojis)
            {
                <button class="emoji-pick @(e == _emoji ? "picked" : "")" @onclick="() => ToggleEmoji(e)">@e</button>
            }
        </div>
        <div class="field" style="margin-top:1rem;margin-bottom:0">
            <label for="evt-label">Name</label>
            <input id="evt-label" type="text" value="@_label" @oninput="e => _label = e.Value?.ToString() ?? string.Empty"
                   placeholder="e.g. Thunder" />
        </div>
        <p class="hint" style="margin-top:0.6rem">
            @if (_isNew)
            {
                <span>Stream Deck URL: <code>/events/@(CurrentId is { Length: > 0 } cid ? cid : "…")/trigger</code></span>
            }
            else
            {
                <span>Id: <code>@_edit.Id</code> (fixed) — <code>/events/@_edit.Id/trigger</code></span>
            }
        </p>
        <ArtField @bind-Image="_edit.Image" />
    </div>

    <SectionHeading>Timeline</SectionHeading>
    <div class="panel">
        <p class="hint" style="margin-top:0">
            Lay sound and light clips along the time axis. Drag a clip to move it, drag its right edge to resize,
            tap it to edit below. Lights flash then restore the live scene; sounds overlay whatever's playing.
        </p>
        <TimelineEditor Model="_edit.Timeline" Sounds="_sounds" Lights="_lights" Fx="_fxLibrary" />
    </div>

    <SectionHeading>When it ends</SectionHeading>
    <div class="panel">
        <Segmented TValue="string" Options="AfterOptions" Value="_edit.After.Mode" ValueChanged="m => _edit.After.Mode = m" />
        @if (_edit.After.Mode == "scene")
        {
            <div class="field" style="margin-top:1rem;margin-bottom:0">
                <label for="evt-after-scene">Scene to activate</label>
                <select id="evt-after-scene" value="@(_edit.After.SceneId ?? "")"
                        @onchange="e => _edit.After.SceneId = (e.Value?.ToString() is { Length: > 0 } v ? v : null)">
                    <option value="">— pick a scene —</option>
                    @foreach (var s in _scenes)
                    {
                        <option value="@s.Id">@s.Name</option>
                    }
                    @if (_edit.After.SceneId is { Length: > 0 } sid && !_scenes.Any(s => string.Equals(s.Id, sid, StringComparison.OrdinalIgnoreCase)))
                    {
                        <option value="@sid">@sid (missing)</option>
                    }
                </select>
            </div>
            <p class="hint" style="margin-top:0.6rem">Fully activates that scene — lights <em>and</em> music — when the event finishes.</p>
        }
        else if (_edit.After.Mode == "default")
        {
            <p class="hint" style="margin-top:0.8rem">Resets the lights to the configured default when the event finishes (music is left playing).</p>
        }
        else
        {
            <p class="hint" style="margin-top:0.8rem">Returns to whatever was showing before — the live scene, or the default light.</p>
        }
    </div>

    <SectionHeading>Save</SectionHeading>
    <div class="btn-row">
        <button class="btn btn--primary" @onclick="() => Save(test: false)" disabled="@_busy">Save</button>
        <button class="btn" @onclick="() => Save(test: true)" disabled="@_busy">Save &amp; Test</button>
        @if (!_isNew && _runningId == _edit.Id)
        {
            <button class="btn btn--danger" @onclick="Stop" disabled="@_busy"><Icon Name="stop" /> Stop</button>
        }
        <button class="btn" @onclick="Cancel" disabled="@_busy">Cancel</button>
    </div>
    @if (!_isNew)
    {
        <div class="btn-row" style="margin-top:0.7rem">
            <button class="btn btn--danger" @onclick="DeleteTapped" disabled="@_busy">
                @(_confirmDelete ? "Really delete?" : "Delete event")
            </button>
        </div>
    }
}

@code {
    [Parameter] public string? EventId { get; set; }

    private bool _loading = true;
    private bool _busy;
    private bool _isNew;
    private EventEdit _edit = new();
    private List<string> _existingIds = [];
    private List<SoundDto> _sounds = [];
    private List<RegisteredLightInfo> _lights = [];
    private List<SceneDto> _scenes = [];
    private List<LightFxDto> _fxLibrary = [];

    // Endings offered in the "When it ends" segmented control.
    private static readonly (string, string)[] AfterOptions =
        [("previous", "Return to previous"), ("scene", "Go to scene"), ("default", "Default lights")];

    private string _emoji = "";
    private string _label = "";

    private string? _runningId;
    private Timer? _timer;
    private bool _confirmDelete;

    protected override async Task OnInitializedAsync()
    {
        _isNew = string.IsNullOrEmpty(EventId);

        var eventsTask = Api.GetEventsAsync();
        var soundsTask = Api.GetSoundsAsync();
        var lightsTask = Api.GetRegisteredLightsAsync();
        var scenesTask = Api.GetScenesAsync();
        var fxTask = Api.GetLightFxAsync();
        await Task.WhenAll(eventsTask, soundsTask, lightsTask, scenesTask, fxTask);
        _existingIds = (await eventsTask).Select(e => e.Id).ToList();
        _sounds = await soundsTask;
        _lights = await lightsTask;
        _scenes = await scenesTask;
        _fxLibrary = await fxTask;

        if (!_isNew)
        {
            var evt = await Api.GetEventAsync(EventId!);
            if (evt is null)
            {
                Ui.ReportError($"Couldn't load event \"{EventId}\".");
                Nav.NavigateTo("events");
                return;
            }
            LoadFrom(evt);
        }

        await PollAsync();
        _timer = new Timer(_ => _ = InvokeAsync(PollAsync), null, 1500, 1500);
        _loading = false;
    }

    private void LoadFrom(EventDto evt)
    {
        (_emoji, _label) = SceneNaming.SplitName(evt.Name);
        _edit = EventEdit.FromDto(evt, _sounds);
    }

    private async Task PollAsync()
    {
        var running = await Api.GetRunningEventIdAsync();
        if (running != _runningId)
        {
            _runningId = running;
            StateHasChanged();
        }
    }

    private void ToggleEmoji(string e) => _emoji = _emoji == e ? "" : e;

    private string ComposedName =>
        string.IsNullOrEmpty(_emoji) ? _label.Trim() : $"{_emoji} {_label.Trim()}";

    // On create the id follows the label; on edit it's fixed.
    private string CurrentId => _isNew ? SceneNaming.MakeUnique(SceneNaming.Slugify(_label), _existingIds) : _edit.Id;

    private async Task Stop()
    {
        if (await Api.StopEventAsync())
        {
            _runningId = null;
            StateHasChanged();
        }
    }

    private Task Cancel() => Vt.NavigateAsync("events");

    private async Task Save(bool test)
    {
        if (string.IsNullOrWhiteSpace(_label))
        {
            Ui.ReportError("Give the event a name first.");
            return;
        }
        if (_edit.Timeline.IsEmpty)
        {
            Ui.ReportError("An event needs at least one sound or light clip.");
            return;
        }
        if (_edit.Timeline.EndMs > TimelineEdit.MaxEndMs)
        {
            Ui.ReportError("The timeline must end within 10 minutes.");
            return;
        }
        // Drift needs at least two palette colours — catch it before the server 400s.
        var badDrift = _edit.Timeline.Lights.FirstOrDefault(l =>
            l.Mode is "color" or "white" && l.Effect.Type == "drift" && l.Effect.Colors.Count < 2);
        if (badDrift is not null)
        {
            Ui.ReportError("A Drift effect needs at least 2 colors.");
            return;
        }
        if (_edit.After.Mode == "scene" && string.IsNullOrWhiteSpace(_edit.After.SceneId))
        {
            Ui.ReportError("Pick a scene to go to when the event ends, or choose another ending.");
            return;
        }

        var id = CurrentId;
        if (string.IsNullOrEmpty(id))
        {
            Ui.ReportError("Couldn't derive an id from that name — use some letters or digits.");
            return;
        }

        _edit.Id = id;
        _edit.Name = ComposedName;

        _busy = true;
        try
        {
            var (_, error) = await Api.SaveEventAsync(id, _edit);
            if (error is not null)
            {
                Ui.ReportError(error);
                return;
            }

            if (test)
            {
                var result = await Api.TriggerEventAsync(id);
                if (result is null) return;
                if (result.FullySucceeded)
                    Ui.ReportOk($"Saved — event \"{id}\" fired");
                else
                    Ui.ReportError($"Saved, but partially fired. {result.ProblemSummary()}");
                await PollAsync();
                // On create, keep editing the freshly-made event rather than re-creating it.
                if (_isNew)
                    await Vt.NavigateAsync($"events/editor/{id}");
            }
            else
            {
                Ui.ReportOk($"Saved event \"{id}\"");
                await Vt.NavigateAsync("events");
            }
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task DeleteTapped()
    {
        if (!_confirmDelete) { _confirmDelete = true; return; }

        _busy = true;
        try
        {
            var (ok, error) = await Api.DeleteEventAsync(_edit.Id);
            if (ok)
            {
                Ui.ReportOk($"Deleted event \"{_edit.Id}\"");
                await Vt.NavigateAsync("events");
            }
            else
            {
                Ui.ReportError(error ?? "Delete failed.");
            }
        }
        finally { _busy = false; }
    }

    public void Dispose() => _timer?.Dispose();
}
