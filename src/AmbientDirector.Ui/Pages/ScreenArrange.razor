@page "/screens/{Id}/arrange"
@inject ApiClient Api
@inject UiState Ui
@inject NavigationManager Nav
@inject ViewTransition Vt
@inject Localizer L

<PageTitle>Ambient Director — @L["screenArrange.title"] @(_label is { Length: > 0 } l ? l : L["screenArrange.titleFallback"])</PageTitle>

@if (_loading)
{
    <p class="empty-note">@L["screenArrange.opening"]</p>
}
else
{
    <div class="page-head"><h1>@L["screenArrange.title"]</h1></div>
    <div class="panel">
        <div class="emoji-row">
            @foreach (var e in Palette.Emojis)
            {
                <button class="emoji-pick @(e == _emoji ? "picked" : "")" @onclick="() => ToggleEmoji(e)">@e</button>
            }
        </div>
        <div class="field" style="margin-top:1rem;margin-bottom:0">
            <label for="screen-label">@L["screenArrange.nameLabel"]</label>
            <input id="screen-label" type="text" value="@_label" @oninput="e => _label = e.Value?.ToString() ?? string.Empty" />
        </div>
        <ArtField @bind-Image="_edit.Image" />
        <div class="chip-row" style="margin-top:1rem">
            <Chip On="_edit.Compact" OnClick="() => _edit.Compact = !_edit.Compact"><Icon Name="screens" /> @L["screenArrange.compactLayout"]</Chip>
        </div>
        <p class="hint" style="margin-top:0.4rem">@L["screenArrange.compactHint"]</p>
    </div>

    <SectionHeading>@L["screenArrange.shortcutsHeading"]</SectionHeading>
    <div class="panel">
        @if (_edit.Tiles.Count == 0)
        {
            <p class="hint" style="margin:0">@L["screenArrange.noShortcuts"]</p>
        }
        else
        {
            <div class="klist">
                @foreach (var (tile, index) in _edit.Tiles.Select((t, i) => (t, i)))
                {
                    var v = View(tile);
                    <div class="krow arrange @(v.Missing ? "missing" : "")">
                        <span class="krow-ico">@if (!string.IsNullOrEmpty(v.Emoji)) { @v.Emoji } else { <Icon Name="@v.Icon" /> }</span>
                        <span class="krow-title">@v.Label <small class="hint">@L[KindLabel(tile.Kind)]</small></span>
                        <button class="reorder" @onclick="() => Move(index, -1)" disabled="@(index == 0)" aria-label='@L["screenArrange.moveUp"]'><Icon Name="move-up" /></button>
                        <button class="reorder" @onclick="() => Move(index, 1)" disabled="@(index == _edit.Tiles.Count - 1)" aria-label='@L["screenArrange.moveDown"]'><Icon Name="move-down" /></button>
                        <button class="reorder danger" @onclick="() => RemoveAt(index)" aria-label='@L["screenArrange.removeShortcut"]'><Icon Name="close" /></button>
                    </div>
                }
            </div>
        }
    </div>

    <SectionHeading>@L["screenArrange.addHeading"]</SectionHeading>
    <div class="panel">
        <Segmented TValue="string" Options="AddOptions" Value="_addKind" ValueChanged="@(k => _addKind = k)" IconFor="AddKindIcon" />

        @if (_addKind is "scene" or "event" or "sound")
        {
            var items = PickerItems();
            @if (items.Count == 0)
            {
                <p class="hint" style="margin-top:1rem">@L[EmptyHint()]</p>
            }
            else
            {
                <div class="klist" style="margin-top:1rem">
                    @foreach (var it in items)
                    {
                        var present = HasTile(_addKind, it.Id);
                        <KRow IconName="@(present ? "check-on" : "check-off")" Title="@it.Label" Selected="present"
                              OnClick="() => ToggleRef(_addKind, it.Id)" />
                    }
                </div>
            }
        }
        else if (_addKind == "music")
        {
            <div class="field" style="margin-top:1rem;margin-bottom:0">
                <label for="screen-search">@L["screenArrange.searchLabel"]</label>
                <div class="field-row">
                    <input id="screen-search" type="text" @bind="_query" @bind:event="oninput"
                           @onkeydown="OnSearchKeyDown" placeholder='@L["screenArrange.searchPlaceholder"]' />
                    <button class="btn" @onclick="SearchAsync" disabled="@_searching">@L["screenArrange.searchBtn"]</button>
                </div>
            </div>
            @if (_results is { Count: > 0 })
            {
                <div class="klist">
                    @foreach (var t in _results)
                    {
                        <KRow IconName="track" Title="@t.Name" Hint="@t.Artist"
                              OnClick="@(() => AddMusic(t.Uri, string.IsNullOrEmpty(t.Artist) ? t.Name : $"{t.Name} — {t.Artist}"))" />
                    }
                </div>
            }
            <p class="section-h">@L["screenArrange.playlists"]</p>
            <PlaylistPicker Playlists="_playlists" OnPick="pl => AddMusic(pl.Uri, pl.Name)">
                <EmptyContent>
                    <p class="hint" style="margin:0">@L["screenArrange.spotifyHintPre"]<a href="settings?tab=music">@L["screenArrange.settingsLink"]</a>@L["screenArrange.spotifyHintPost"]</p>
                </EmptyContent>
            </PlaylistPicker>
        }
        else if (_addKind == "lights")
        {
            <p class="hint" style="margin-top:1rem">@L["screenArrange.lightsHint"]</p>
            <div class="btn-row" style="margin-top:0.6rem">
                <button class="btn" @onclick="AddResetLights"><Icon Name="lights" /> @L["screenArrange.addResetBtn"]</button>
            </div>
        }
        else if (_addKind == "break")
        {
            <div class="field" style="margin-top:1rem;margin-bottom:0">
                <label for="break-label">@L["screenArrange.breakLabelLabel"]</label>
                <input id="break-label" type="text" @bind="_breakLabel" @bind:event="oninput" placeholder='@L["screenArrange.breakPlaceholder"]' />
            </div>
            <p class="hint" style="margin-top:0.6rem">@L["screenArrange.breakHint"]</p>
            <div class="btn-row" style="margin-top:0.6rem">
                <button class="btn" @onclick="AddBreak"><Icon Name="break" /> @L["screenArrange.addBreakBtn"]</button>
            </div>
        }
    </div>

    <SectionHeading>@L["common.save"]</SectionHeading>
    <div class="btn-row">
        <button class="btn btn--primary" @onclick="Save" disabled="@_busy">@L["common.save"]</button>
        <button class="btn" @onclick="Cancel" disabled="@_busy">@L["common.cancel"]</button>
    </div>
    <div class="btn-row" style="margin-top:0.7rem">
        <ConfirmButton Disabled="_busy" OnConfirmed="DeleteConfirmed">@L["screenArrange.deleteBtn"]</ConfirmButton>
    </div>
}

@code {
    [Parameter] public string Id { get; set; } = "";

    private bool _loading = true;
    private bool _busy;

    private ScreenEdit _edit = new();
    private string _emoji = "";
    private string _label = "";

    // Entities referenced by tiles — resolved for display and used by the add-picker.
    private List<SceneDto>? _scenes;
    private List<EventDto>? _events;
    private List<SoundDto>? _sounds;
    private List<SpotifyPlaylistDto>? _playlists;

    // Add-a-shortcut picker.
    private string _addKind = "scene";
    private string _query = "";
    private bool _searching;
    private List<SpotifyTrackDto>? _results;
    private string _breakLabel = "";

    // Icon-only kind picker (labels blank; AddKindIcon renders the glyph for each).
    private static readonly (string, string)[] AddOptions =
        [("scene", ""), ("event", ""), ("sound", ""), ("music", ""), ("lights", ""), ("break", "")];

    private static string AddKindIcon(string kind) => kind switch
    {
        "scene" => "scenes",
        "event" => "events",
        "sound" => "sounds",
        "music" => "music",
        "lights" => "lights",
        "break" => "break",
        _ => "",
    };

    protected override async Task OnInitializedAsync()
    {
        await Api.GetApiKeyAsync(); // cache the key so tile-art urls carry it
        var dto = (await Api.GetScreensAsync())
            .FirstOrDefault(s => string.Equals(s.Id, Id, StringComparison.OrdinalIgnoreCase));
        if (dto is null)
        {
            Ui.ReportError(L.Format("screenArrange.toast.loadFail", Id));
            Nav.NavigateTo("screens");
            return;
        }
        _edit = new ScreenEdit { Id = dto.Id, Name = dto.Name, Tiles = [.. dto.Tiles ?? []], Image = dto.Image, Compact = dto.Compact };
        (_emoji, _label) = SceneNaming.SplitName(dto.Name);

        // Referenced entities + the Spotify library (playlists are optional; empty/silent when not connected).
        _scenes = await Api.GetScenesAsync();
        _events = await Api.GetEventsAsync();
        _sounds = await Api.GetSoundsAsync();
        var (playlists, _) = await Api.GetSpotifyPlaylistsAsync();
        _playlists = playlists ?? [];

        _loading = false;
    }

    // ---------- tile display (for the shortcut list) ----------

    // Emoji = the user's picked name emoji (content, scene/event only); Icon = the chrome fallback / kind glyph.
    private record TileView(string Emoji, string Icon, string Label, bool Missing);

    private TileView View(ScreenTileDto tile)
    {
        switch (tile.Kind)
        {
            case "scene":
                var scene = _scenes?.FirstOrDefault(s => Eq(s.Id, tile.Ref));
                if (scene is null) return Gone(tile);
                var (se, sl) = SceneNaming.SplitName(scene.Name, "", scene.Id);
                return new TileView(se, "scenes", sl, false);
            case "event":
                var evt = _events?.FirstOrDefault(e => Eq(e.Id, tile.Ref));
                if (evt is null) return Gone(tile);
                var (ee, el) = SceneNaming.SplitName(evt.Name, "", evt.Id);
                return new TileView(ee, "events", el, false);
            case "sound":
                var snd = _sounds?.FirstOrDefault(s => Eq(s.Id, tile.Ref));
                if (snd is null) return Gone(tile);
                return new TileView("", snd.Loop ? "repeat" : "sounds", snd.Name, false);
            case "music":
                return new TileView("", "music", Label(tile), false);
            case "light-reset":
                return new TileView("", "lights", L["screenArrange.tile.resetLights"], false);
            case "break":
                return new TileView("", "break", string.IsNullOrWhiteSpace(tile.Label) ? L["screenArrange.tile.lineBreak"] : tile.Label, false);
            default:
                return Gone(tile);
        }
    }

    private static TileView Gone(ScreenTileDto tile) => new("", "warn", Label(tile), true);

    private static string Label(ScreenTileDto tile) => string.IsNullOrWhiteSpace(tile.Label) ? tile.Ref : tile.Label;

    private static string KindLabel(string kind) => kind switch
    {
        "scene" => "screenArrange.kind.scene", "event" => "screenArrange.kind.event", "sound" => "screenArrange.kind.sound",
        "music" => "screenArrange.kind.music", "light-reset" => "screenArrange.kind.lights", "break" => "screenArrange.kind.lineBreak", _ => kind,
    };

    private static bool Eq(string? a, string? b) => string.Equals(a, b, StringComparison.OrdinalIgnoreCase);

    // ---------- arrange ----------

    private void ToggleEmoji(string e) => _emoji = _emoji == e ? "" : e;

    private string ComposedName =>
        string.IsNullOrEmpty(_emoji) ? _label.Trim() : $"{_emoji} {_label.Trim()}";

    private bool HasTile(string kind, string reference) =>
        _edit.Tiles.Any(t => t.Kind == kind && Eq(t.Ref, reference));

    private void ToggleRef(string kind, string reference)
    {
        var existing = _edit.Tiles.FirstOrDefault(t => t.Kind == kind && Eq(t.Ref, reference));
        if (existing is not null) _edit.Tiles.Remove(existing);
        else _edit.Tiles.Add(new ScreenTileDto(kind, reference, ""));
    }

    private void AddMusic(string uri, string label)
    {
        _edit.Tiles.Add(new ScreenTileDto("music", uri, label));
        Ui.ReportOk(L.Format("screenArrange.toast.added", label));
    }

    private void AddResetLights()
    {
        if (_edit.Tiles.Any(t => t.Kind == "light-reset"))
        {
            Ui.ReportOk(L["screenArrange.toast.resetExists"]);
            return;
        }
        _edit.Tiles.Add(new ScreenTileDto("light-reset", "", L["screenArrange.tile.resetLights"]));
        Ui.ReportOk(L["screenArrange.toast.resetAdded"]);
    }

    private void AddBreak()
    {
        var label = _breakLabel.Trim();
        _edit.Tiles.Add(new ScreenTileDto("break", "", label));
        _breakLabel = "";
        Ui.ReportOk(label.Length > 0 ? L.Format("screenArrange.toast.sectionAdded", label) : L["screenArrange.toast.breakAdded"]);
    }

    private void Move(int index, int delta)
    {
        var target = index + delta;
        if (target < 0 || target >= _edit.Tiles.Count) return;
        (_edit.Tiles[index], _edit.Tiles[target]) = (_edit.Tiles[target], _edit.Tiles[index]);
    }

    private void RemoveAt(int index) => _edit.Tiles.RemoveAt(index);

    // (id, display-name) pairs for the current entity picker (scene/event/sound); empty otherwise.
    private List<(string Id, string Label)> PickerItems() => _addKind switch
    {
        "scene" => _scenes?.Select(s => (s.Id, Blank(s.Name) ?? s.Id)).ToList() ?? [],
        "event" => _events?.Select(e => (e.Id, Blank(e.Name) ?? e.Id)).ToList() ?? [],
        "sound" => _sounds?.Select(s => (s.Id, Blank(s.Name) ?? s.Id)).ToList() ?? [],
        _ => [],
    };

    private string EmptyHint() => _addKind switch
    {
        "scene" => "screenArrange.empty.scene",
        "event" => "screenArrange.empty.event",
        "sound" => "screenArrange.empty.sound",
        _ => "",
    };

    private static string? Blank(string? s) => string.IsNullOrWhiteSpace(s) ? null : s.Trim();

    private async Task SearchAsync()
    {
        if (string.IsNullOrWhiteSpace(_query)) return;
        _searching = true;
        try
        {
            var (results, error) = await Api.SearchSpotifyTracksAsync(_query);
            if (results is not null) _results = results;
            else if (error is not null) Ui.ReportError(error);
        }
        finally { _searching = false; }
    }

    private async Task OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchAsync();
    }

    private Task Cancel() => Vt.NavigateAsync($"screens/{Id}");

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_label))
        {
            Ui.ReportError(L["screenArrange.toast.nameFirst"]);
            return;
        }
        _edit.Name = ComposedName;

        _busy = true;
        try
        {
            var (_, error) = await Api.SaveScreenAsync(_edit.Id, _edit);
            if (error is not null)
            {
                Ui.ReportError(error);
                return;
            }
            Ui.ReportOk(L.Format("screenArrange.toast.saved", _edit.Id));
            await Vt.NavigateAsync($"screens/{Id}");
        }
        finally { _busy = false; }
    }

    private async Task DeleteConfirmed()
    {
        _busy = true;
        try
        {
            var (ok, error) = await Api.DeleteScreenAsync(_edit.Id);
            if (ok)
            {
                Ui.ReportOk(L.Format("screenArrange.toast.deleted", _edit.Id));
                await Vt.NavigateAsync("screens");
            }
            else
            {
                Ui.ReportError(error ?? L["screenArrange.toast.deleteFail"]);
            }
        }
        finally { _busy = false; }
    }
}
